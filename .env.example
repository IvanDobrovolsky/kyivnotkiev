# KyivNotKiev Environment Variables
# Copy to .env and fill in your keys: cp .env.example .env
#
# NOTE: The analysis pipeline (make reproduce) needs NO keys at all.
# Keys are only needed for data ingestion and LLM audit scripts.

# ── Data Ingestion ────────────────────────────────────────────────────────────

# YouTube Data API v3 (required for: make ingest-youtube)
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Google Cloud (required for: make ingest-gdelt, make export-dataset)
# Get from: https://console.cloud.google.com/iam-admin/serviceaccounts
# Point to your service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=

# GCP project (used by ingestion scripts that query GDELT's public BigQuery)
GCP_PROJECT_ID=kyivnotkiev-research

# ── LLM Audit (make llm-audit) ───────────────────────────────────────────────

# OpenAI (GPT models)
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# xAI (Grok models)
XAI_API_KEY=

# Groq (fast inference for open models)
GROQ_API_KEY=

# OpenRouter (fallback for multiple providers)
OPENROUTER_API_KEY=

# Ollama (local models — no key needed, just the base URL)
OLLAMA_BASE_URL=http://localhost:11434

# ── CL Pipeline (make cl-classify) ───────────────────────────────────────────

# vLLM server URL for Llama 3.1 70B annotation
# Run locally or on vast.ai, then set the URL here
VLLM_API_URL=

# ── Publishing ────────────────────────────────────────────────────────────────

# Hugging Face (required for: make publish-dataset, make publish-cl-model)
HF_TOKEN=
