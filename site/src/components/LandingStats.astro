---
interface Props {
  manifest: any;
  fmtBig: (n: string | number) => string;
}

const { manifest: m, fmtBig } = Astro.props;
---

<div style="display:flex; align-items:center; gap:1.5rem; padding:2rem 0.5rem 1.5rem; margin-bottom:1rem;">
  <img src="/logo.svg" alt="Kyiv chestnut" style="height:100px; width:auto; flex-shrink:0;">
  <div>
    <h1 style="font-size:1.8rem; font-weight:800; margin:0; line-height:1.2; color:#0057B8;">
      #KyivNotKiev
    </h1>
    <p style="color:var(--text); font-size:0.95rem; margin:0.4rem 0 0; line-height:1.5;">
      A Large-Scale Computational Study of Ukrainian Toponym Adoption
    </p>
  </div>
</div>

<!-- Three Layers — top strip -->
<div class="resp-grid-3" style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:3px; margin-bottom:0.75rem;">
  <div style="padding:0.5rem 0.7rem; background:var(--card-bg); border-bottom:2px solid #f59e0b; border-radius:4px;">
    <div style="font-size:0.6rem; text-transform:uppercase; color:#f59e0b; font-weight:700; letter-spacing:0.05em;">1. Big Data</div>
    <div style="font-size:0.65rem; color:var(--text-muted); margin-top:0.15rem;">{m.records_scanned} scanned, {fmtBig(m.toponym_matches)} matches</div>
  </div>
  <div style="padding:0.5rem 0.7rem; background:var(--card-bg); border-bottom:2px solid #8b5cf6; border-radius:4px;">
    <div style="font-size:0.6rem; text-transform:uppercase; color:#8b5cf6; font-weight:700; letter-spacing:0.05em;">2. Statistics</div>
    <div style="font-size:0.65rem; color:var(--text-muted); margin-top:0.15rem;">Validating patterns are real</div>
  </div>
  <div style="padding:0.5rem 0.7rem; background:var(--card-bg); border-bottom:2px solid #06b6d4; border-radius:4px;">
    <div style="font-size:0.6rem; text-transform:uppercase; color:#06b6d4; font-weight:700; letter-spacing:0.05em;">3. Computational Linguistics</div>
    <div style="font-size:0.65rem; color:var(--text-muted); margin-top:0.15rem;">Extracting context and patterns with ML</div>
  </div>
</div>

<div class="stats resp-grid-6" style="grid-template-columns: repeat(6, 1fr);">
  <div class="stat-card">
    <div class="stat-value">{m.records_scanned}</div>
    <div class="stat-label">Records Scanned</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">{fmtBig(m.toponym_matches)}</div>
    <div class="stat-label">Toponym Matches</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">{fmtBig(m.cl_corpus)}</div>
    <div class="stat-label">ML-Analyzed Texts</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">{m.analyzable_pairs}</div>
    <div class="stat-label">Toponym Pairs</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">{m.num_sources}</div>
    <div class="stat-label">Data Sources</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">{m.time_span}</div>
    <div class="stat-label">Time Span</div>
  </div>
</div>

<div class="stats source-stats" style="grid-template-columns: repeat(8, 1fr);">
  {Object.entries(m.sources).map(([key, s]: [string, any]) => (
    <div class="stat-card mini" style={`--accent: ${s.color}`}>
      <div class="stat-value">{fmtBig(s.records)}</div>
      <div class="stat-label">{s.label}</div>
      <div class="stat-source">{s.extra}</div>
    </div>
  ))}
</div>
