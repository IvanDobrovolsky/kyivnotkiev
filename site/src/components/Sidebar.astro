---
interface Props {
  grouped: Array<{
    id: string;
    name: string;
    color: string;
    pairs: Array<{
      id: number;
      russian: string;
      ukrainian: string;
      adoption: number;
    }>;
  }>;
}

function adoptionClass(pct: number) {
  if (pct >= 80) return 'high';
  if (pct >= 50) return 'mid';
  if (pct >= 20) return 'low';
  return 'very-low';
}

const { grouped } = Astro.props;
---

<div class="sidebar-overlay" id="sidebar-overlay"></div>
<aside class="sidebar" id="sidebar-aside">
  {grouped.map((cat, ci) => (
    <div class="sidebar-section">
      <div class={`sidebar-header ${ci === 0 ? 'open' : ''}`} data-category={cat.id}>
        <span class="dot" style={`background: ${cat.color}`}></span>
        {cat.name}
        <span class="arrow">▶</span>
      </div>
      <div class={`sidebar-items ${ci === 0 ? 'open' : ''}`}>
        {cat.pairs.map((pair) => (
          <div class="sidebar-item" data-pair-id={pair.id}>
            <div class="pair-name">
              <span>{pair.ukrainian}</span>
              <span class="old">{pair.russian}</span>
            </div>
            <span class={`adoption-badge ${adoptionClass(pair.adoption)}`}>
              {pair.adoption}%
            </span>
          </div>
        ))}
      </div>
    </div>
  ))}
</aside>
