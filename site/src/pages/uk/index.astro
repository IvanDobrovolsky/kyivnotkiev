          </div>
          <div class="top6-card" data-pair-id="61" style="cursor:pointer; padding:0.75rem; border:1px solid #e5e7eb; border-radius:8px; transition:all 0.15s;">
            <div style="display:flex; justify-content:space-between; align-items:baseline;">
