---
import '../../styles/global.css';
import m from '../../data/manifest.json';
import toolsPerPair from '../../data/tools_per_pair.json';

// manifest.json is the single source of truth — all stats, pairs, categories
const grouped = m.categories.map(cat => ({
  ...cat,
  pairs: m.pairs.filter(p => p.category === cat.id).sort((a, b) => {
    if (a.id === 1) return -1;
    if (b.id === 1) return 1;
    return b.total - a.total;
  })
})).filter(g => g.pairs.length > 0);

function fmtBig(n: string | number) {
  const v = typeof n === 'string' ? parseInt(n) : n;
  if (v >= 1_000_000_000) return (v / 1_000_000_000).toFixed(1) + 'B';
  if (v >= 1_000_000) return (v / 1_000_000).toFixed(1) + 'M';
  if (v >= 1_000) return (v / 1_000).toFixed(1) + 'K';
  return v.toString();
}

function adoptionClass(pct: number) {
  if (pct >= 70) return 'adoption-high';
  if (pct >= 30) return 'adoption-mid';
  return 'adoption-low';
}

const src = (name: string) => (m.sources as any)[name];

function formatNum(n: number) {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(0) + 'K';
  return n.toString();
}
---

<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>#KyivNotKiev — Вимірювання топонімічних змін у реальному часі</title>
  <meta name="description" content={`Мультиджерельна обчислювальна платформа для відстеження прийняття українського правопису у понад ${m.records_scanned} записів, ${fmtBig(m.toponym_matches)}+ топонімічних збігів з ${m.num_sources} джерел, ${m.time_span}.`}>

  <!-- Open Graph -->
  <meta property="og:title" content="#KyivNotKiev — Вимірювання топонімічних змін у реальному часі">
  <meta property="og:description" content={`Вимірювання топонімічних змін у реальному часі у понад ${m.records_scanned} записів, ${fmtBig(m.toponym_matches)}+ збігів. Найбільше обчислювальне дослідження прийняття українського правопису у світі.`}>
  <meta property="og:image" content="https://kyivnotkiev.org/og.png">
  <meta property="og:url" content="https://kyivnotkiev.org/uk/">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="uk_UA">
  <meta property="og:locale:alternate" content="en_US">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="#KyivNotKiev — Вимірювання топонімічних змін у реальному часі">
  <meta name="twitter:description" content={`${fmtBig(m.toponym_matches)}+ записів, ${m.num_sources} джерел, ${m.num_countries} країн. Вимірювання топонімічних змін у реальному часі ${m.time_span}.`}>
  <meta name="twitter:image" content="https://kyivnotkiev.org/og.png">

  <!-- Favicon -->
  <link rel="icon" href="/logo.svg" type="image/svg+xml">
  <link rel="alternate" hreflang="uk" href="https://kyivnotkiev.org/uk/">
  <link rel="alternate" hreflang="en" href="https://kyivnotkiev.org/">
  <link rel="canonical" href="https://kyivnotkiev.org/uk/">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="app">
    <nav class="topbar">
      <a href="/uk/" class="topbar-logo" style="text-decoration:none;">
        <img src="/logo.svg" alt="Kyiv chestnut" style="height:28px; width:auto; margin-right:0.4rem;">
        <span style="font-size:0.9rem; font-weight:800; color:#0057B8;">#KyivNotKiev</span>
      </a>
      <div class="topbar-links">
        <a href="/">EN</a>
        <a href="https://github.com/IvanDobrovolsky/kyivnotkiev" target="_blank">GitHub</a>
        <a href="/uk/" id="about-link">Про проєкт</a>
      </div>
    </nav>

    <aside class="sidebar">
      {grouped.map((cat, ci) => (
        <div class="sidebar-section">
          <div class={`sidebar-header ${ci === 0 ? 'open' : ''}`} data-category={cat.id}>
            <span class="dot" style={`background: ${cat.color}`}></span>
            {cat.name}
            <span class="arrow">▶</span>
          </div>
          <div class={`sidebar-items ${ci === 0 ? 'open' : ''}`}>
            {cat.pairs.map((pair, pi) => (
              <div class="sidebar-item" data-pair-id={pair.id}>
                <div class="pair-name">
                  <span>{[1,3,10,61,70,72].includes(pair.id) ? '★ ' : ''}{pair.ukrainian}</span>
                  <span class="old">{pair.russian}</span>
                </div>
                <span class={`adoption-badge ${adoptionClass(pair.adoption)}`}>
                  {pair.adoption}%
                </span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </aside>

    <main class="main" style="opacity:0; transition:opacity 0.15s;">
      <!-- ══ LANDING VIEW (visible when no pair selected) ══ -->
      <div id="landing-view" style="display:none;">
        <div style="display:flex; align-items:center; gap:1.5rem; padding:2rem 0.5rem 1.5rem; margin-bottom:1rem;">
          <img src="/logo.svg" alt="Kyiv chestnut" style="height:100px; width:auto; flex-shrink:0;">
          <div>
            <h1 style="font-size:1.8rem; font-weight:800; margin:0; line-height:1.2; color:#0057B8;">
              #KyivNotKiev
            </h1>
            <p style="color:var(--text); font-size:0.95rem; margin:0.4rem 0 0; line-height:1.5;">
              Відстеження прийняття українського правопису у {fmtBig(m.toponym_matches)} записах з {m.num_sources} джерел, {m.num_countries} країн, 2010–2026.
            </p>
          </div>
        </div>

      <div class="stats" style="grid-template-columns: repeat(5, 1fr);">
        <div class="stat-card">
          <div class="stat-value">{fmtBig(m.toponym_matches)}</div>
          <div class="stat-label">Записів проаналізовано</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">~{m.data_processed_pb} PB</div>
          <div class="stat-label">Даних оброблено</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">{m.analyzable_pairs}</div>
          <div class="stat-label">Пар топонімів</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">{m.num_sources}</div>
          <div class="stat-label">Джерел даних</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">{m.time_span}</div>
          <div class="stat-label">Період</div>
        </div>
      </div>
      <div class="stats source-stats" style="grid-template-columns: repeat(7, 1fr);">
        {Object.entries(m.sources).map(([key, s]: [string, any]) => (
          <div class="stat-card mini" style={`--accent: ${s.color}`}>
            <div class="stat-value">{fmtBig(s.records)}</div>
            <div class="stat-label">{s.label}</div>
            <div class="stat-source">{s.extra}</div>
          </div>
        ))}
      </div>

      </div><!-- end landing-view -->

      <!-- ══ PAIR VIEW (visible when pair selected) ══ -->
      <div id="pair-view" style="display:none;">

      <div class="chart-container">
        <div class="chart-header" style="flex-direction:column; align-items:stretch; gap:0.3rem;">
          <div style="display:flex; align-items:baseline; gap:0.5rem; flex-wrap:wrap;">
            <div class="chart-title" style="margin:0; white-space:nowrap;">
              <span class="old-name" id="chart-old">Kiev</span>
              <span class="arrow">→</span>
              <span class="new-name" id="chart-new">Kyiv</span>
            </div>
            <span id="chart-range" style="font-size:0.72rem; color:var(--text-muted);"></span>
            <span id="chart-info" style="font-size:0.68rem; color:var(--text-dim); font-style:italic;"></span>
            <span id="chart-adoption-formula" style="font-size:0.68rem; color:var(--text-dim);"></span>
          </div>
          <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:0.4rem;">
            <div class="chart-controls" style="margin:0;">
              <button class="source-toggle active" data-source="gdelt" style="--source-color: #1e3a5f"><span class="source-dot"></span>GDELT</button>
              <button class="source-toggle" data-source="trends" style="--source-color: #4285F4"><span class="source-dot"></span>Trends</button>
              <button class="source-toggle" data-source="wikipedia" style="--source-color: #636466"><span class="source-dot"></span>Вікі</button>
              <button class="source-toggle" data-source="reddit" style="--source-color: #FF4500"><span class="source-dot"></span>Reddit</button>
              <button class="source-toggle" data-source="youtube" style="--source-color: #FF0000"><span class="source-dot"></span>YouTube</button>
              <button class="source-toggle" data-source="ngrams" style="--source-color: #7c3aed"><span class="source-dot"></span>Ngrams</button>
              <button class="source-toggle" data-source="openalex" style="--source-color: #06b6d4"><span class="source-dot"></span>Наукові</button>
            </div>
            <div class="chart-controls" style="margin:0;">
              <button class="chart-mode active" data-chart="volume" id="volume-btn">Обсяг</button>
              <button class="chart-mode" data-chart="adoption">Адопція %</button>
              <span class="toggle-sep"></span>
              <button class="line-mode active" data-mode="both">Усі</button>
              <button class="line-mode" data-mode="ukrainian">УКР</button>
              <button class="line-mode" data-mode="russian">РОС</button>
              <span class="toggle-sep"></span>
              <button class="event-toggle active" id="events-toggle">Події</button>
            </div>
          </div>
        </div>
        <div id="chart"></div>
        <div class="chart-legend" id="chart-legend"></div>
      </div>

      <!-- Per-pair source stats -->
      <div id="pair-stats" class="stats source-stats" style="grid-template-columns: repeat(7, 1fr); margin-bottom: 0.75rem;"></div>

      <!-- Adoption + Reference side by side -->
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1rem;">
        <div id="adoption-calc" class="chart-container" style="margin-bottom:0; padding:0.75rem 1rem;">
          <div style="font-size:0.8rem; font-weight:600; color:var(--text); margin-bottom:0.4rem;">Розрахунок адопції</div>
          <div id="adoption-calc-body" style="font-size:0.75rem; color:var(--text-muted); line-height:1.6;"></div>
        </div>
        <div class="chart-container" id="dict-container" style="margin-bottom:0; padding:0.75rem 1rem;">
          <div style="font-size:0.8rem; font-weight:600; color:var(--text); margin-bottom:0.4rem;">Аудит посилань</div>
          <div id="search-preview"></div>
          <script type="application/json" id="tools-per-pair-data" set:html={JSON.stringify(toolsPerPair)} />
        </div>
      </div>

      <!-- Source Comparison -->
      <div id="comparison-row" style="display:grid; grid-template-columns:1fr; gap:1rem; margin-bottom:1rem;">
        <div class="chart-container" style="margin-bottom:0;">
          <div style="font-size:0.8rem; font-weight:600; color:var(--text); margin-bottom:0.3rem;">Порівняння джерел</div>
          <div id="pair-source-chart" style="width:100%;"></div>
        </div>
      </div>

      <!-- Per-pair world map (GDELT only) -->
      <div class="chart-container" id="map-container">
        <div class="chart-header">
          <div>
            <div class="chart-title" style="color: var(--text)">Карта адопції: <span id="map-pair-name">Kiev → Kyiv</span></div>
            <div class="chart-subtitle" id="map-subtitle">Адопція за країнами (%) — новинний корпус GDELT 2024–2026</div>
          </div>
        </div>
        <div id="world-map" style="width:100%; height:400px;"></div>
        <div class="chart-legend" id="map-legend" style="justify-content: center; gap: 0.5rem;">
          <span style="font-size:0.75rem; color:var(--text-muted)">0%</span>
          <div style="display:flex; height:12px; width:240px; border-radius:6px; overflow:hidden;">
            <div style="flex:1; background:#dc2626"></div>
            <div style="flex:1; background:#f97316"></div>
            <div style="flex:1; background:#eab308"></div>
            <div style="flex:1; background:#22c55e"></div>
            <div style="flex:1; background:#047857"></div>
          </div>
          <span style="font-size:0.75rem; color:var(--text-muted)">100%</span>
        </div>
      </div>

      <!-- Per-pair: GDELT Analysis (3 pie charts) -->
      <div id="media-origin-container" style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:0.75rem; margin-bottom:1rem;">
        <div class="chart-container" style="margin-bottom:0; padding:0.6rem 0.75rem;">
          <div style="font-size:0.78rem; font-weight:600; color:var(--text); margin-bottom:0.2rem;">Загальний правопис</div>
          <div style="font-size:0.65rem; color:var(--text-muted); margin-bottom:0.4rem;">Українська vs Російська (24 міс.)</div>
          <div id="spelling-pie" style="display:flex; align-items:center; justify-content:center;"></div>
        </div>
        <div class="chart-container" style="margin-bottom:0; padding:0.6rem 0.75rem;">
          <div style="font-size:0.78rem; font-weight:600; color:#0057B8; margin-bottom:0.2rem;">Джерела українського правопису</div>
          <div style="font-size:0.65rem; color:var(--text-muted); margin-bottom:0.4rem;">Звідки надходять статті з УКР-формою?</div>
          <div id="ua-origin-pie" style="display:flex; align-items:center; justify-content:center;"></div>
        </div>
        <div class="chart-container" style="margin-bottom:0; padding:0.6rem 0.75rem;">
          <div style="font-size:0.78rem; font-weight:600; color:#dc2626; margin-bottom:0.2rem;">Джерела російського правопису</div>
          <div style="font-size:0.65rem; color:var(--text-muted); margin-bottom:0.4rem;">Звідки надходять статті з РОС-формою?</div>
          <div id="ru-origin-pie" style="display:flex; align-items:center; justify-content:center;"></div>
        </div>
      </div>

      <!-- Source comparison moved to comparison-row above -->

      <!-- Per-pair holdouts (GDELT only) -->
      <div class="chart-container" id="holdout-container">
        <div class="chart-header">
          <div>
            <div class="chart-title" style="color: var(--text)">Holdouts: <span id="holdout-pair-name">Kiev</span></div>
            <div class="chart-subtitle">Домени, що досі використовують стару назву — натисніть для перевірки у GDELT</div>
          </div>
          <div class="chart-controls">
            <button class="line-mode" data-holdout="intl">Міжнародні</button>
            <button class="line-mode active" data-holdout="all">Усі</button>
            <button class="line-mode" data-holdout="ru">Показати .ru</button>
            <button class="line-mode" data-holdout="ua">.ua</button>
          </div>
        </div>
        <div id="holdout-table" style="max-height: 500px; overflow-y: auto;"></div>
      </div>

      <!-- Data source availability note -->
      <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 1rem; padding: 0.5rem 0.75rem; background: #f8f9fb; border-radius: 4px; border-left: 3px solid var(--border);">
        Доступність джерел: Trends (2010–2026), GDELT (2015–2026), Вікіпедія (2015–2026), Reddit (2007–2026), Ngrams (книги, 2000–2019)
      </div>

      <!-- Reference Audit moved to grid above -->

      </div><!-- end pair-view -->

      <!-- ══ GLOBAL VIEWS (visible on landing, hidden on pair view) ══ -->
      <div id="global-view">

      <!-- Statistical Highlights — values from analysis.json (recomputed from BQ) -->
      <div class="chart-container" style="margin-bottom: 1rem;">
        <div class="chart-title" style="color: var(--text); font-size: 1.1rem; margin-bottom: 1rem;">Статистичний аналіз</div>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem;">
          <div style="padding:1rem; background:#f0f9ff; border-radius:6px; text-align:center;">
            <div style="font-size:1.8rem; font-weight:700; color:#0057B8;">R²=0.87</div>
            <div style="font-size:0.75rem; color:#6b7280;">Регресійна модель</div>
            <div style="font-size:0.65rem; color:#9ca3af; margin-top:0.2rem;">Стрибок при вторгненні (β=0.87) — головний предиктор поточної адопції</div>
          </div>
          <div style="padding:1rem; background:#fef2f2; border-radius:6px; text-align:center;">
            <div style="font-size:1.8rem; font-weight:700; color:#dc2626;">p&lt;0.001</div>
            <div style="font-size:0.75rem; color:#6b7280;">Ефект вторгнення</div>
            <div style="font-size:0.65rem; color:#9ca3af; margin-top:0.2rem;">Значущий у всіх 4 тестованих джерелах (Wilcoxon); Reddit d=1.38</div>
          </div>
          <div style="padding:1rem; background:#f0fdf4; border-radius:6px; text-align:center;">
            <div style="font-size:1.8rem; font-weight:700; color:#059669;">99.8%</div>
            <div style="font-size:0.75rem; color:#6b7280;">Точність Regex</div>
            <div style="font-size:0.65rem; color:#9ca3af; margin-top:0.2rem;">1 444 збіги GDELT перевірено — 3 хибних спрацювання (лише Odessa)</div>
          </div>
          <div style="padding:1rem; background:#fefce8; border-radius:6px; text-align:center;">
            <div style="font-size:1.8rem; font-weight:700; color:#d97706;">p=0.035</div>
            <div style="font-size:0.75rem; color:#6b7280;">Тест категорій</div>
            <div style="font-size:0.65rem; color:#9ca3af; margin-top:0.2rem;">Kruskal-Wallis H=13.54: категорії відрізняються суттєво</div>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem; margin-top: 0.75rem;">
          <div style="padding:0.75rem 1rem; background:#f8f9fb; border-radius:6px;">
            <div style="font-size:0.8rem; font-weight:600; color:var(--text);">Розкид між джерелами</div>
            <div style="font-size:0.75rem; color:#6b7280;">Медіана 54пп — адопція дуже залежить від домену</div>
          </div>
          <div style="padding:0.75rem 1rem; background:#f8f9fb; border-radius:6px;">
            <div style="font-size:0.8rem; font-weight:600; color:var(--text);">Історична ідентичність</div>
            <div style="font-size:0.75rem; color:#6b7280;">Kyiv 74%, але Volodymyr the Great лише 7% — історія й досі в російських рамках</div>
          </div>
          <div style="padding:0.75rem 1rem; background:#f8f9fb; border-radius:6px;">
            <div style="font-size:0.8rem; font-weight:600; color:var(--text);">Міжмовний аналіз</div>
            <div style="font-size:0.75rem; color:#6b7280;">US 47% → FR 4% → IT 2% — кампанія ледь вийшла за межі англомовного світу</div>
          </div>
          <div style="padding:0.75rem 1rem; background:#f8f9fb; border-radius:6px;">
            <div style="font-size:0.8rem; font-weight:600; color:var(--text);">Бренд-катастрофа</div>
            <div style="font-size:0.75rem; color:#6b7280;">Chernobyl: 1% у Trends, 0% у Вікіпедії — несприйнятливий до змін</div>
          </div>
        </div>
      </div>

      <!-- Category chart -->
      <div class="chart-container" style="margin-bottom: 1rem;">
        <div class="chart-title" style="color: var(--text); font-size: 1.1rem;">Адопція за категоріями</div>
        <div class="chart-subtitle" style="margin-bottom: 0.5rem;">Середня адопція (%) за категоріями — рівна вага кожного джерела</div>
        <div id="category-chart" style="width:100%; height:260px;"></div>
      </div>

      <!-- Top 6 Deep Dive -->
      <div class="chart-container" style="margin-bottom: 1rem;">
        <div class="chart-title" style="color: var(--text); font-size: 1.1rem; margin-bottom: 0.5rem;">Ключові пари: Детальний аналіз</div>
        <div class="chart-subtitle" style="margin-bottom: 1rem;">6 пар, що представляють увесь спектр — від успіху кампанії до історичного спротиву</div>
        <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:0.75rem;">
          <div class="top6-card" data-pair-id="1" style="cursor:pointer; padding:0.75rem; border:1px solid #e5e7eb; border-radius:8px; transition:all 0.15s;">
            <div style="display:flex; justify-content:space-between; align-items:baseline;">
              <div style="font-weight:600; color:var(--text);">Kiev → Kyiv</div>
              <div style="font-size:0.8rem; font-weight:700; color:#059669;">60.3%</div>
            </div>
            <div style="font-size:0.7rem; color:var(--text-muted); margin-top:0.2rem;">Флагман — історія успіху кампанії</div>
            <div style="height:4px; background:#f0f0f0; border-radius:2px; margin-top:0.4rem;"><div style="height:100%; width:60.3%; background:#059669; border-radius:2px;"></div></div>
          </div>
          <div class="top6-card" data-pair-id="10" style="cursor:pointer; padding:0.75rem; border:1px solid #e5e7eb; border-radius:8px; transition:all 0.15s;">
            <div style="display:flex; justify-content:space-between; align-items:baseline;">
              <div style="font-weight:600; color:var(--text);">Chernobyl → Chornobyl</div>
              <div style="font-size:0.8rem; font-weight:700; color:#dc2626;">26.8%</div>
            </div>
