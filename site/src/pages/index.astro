        .attr('stroke', '#e5e7eb').attr('stroke-dasharray', '3,3');

      // Header
      svg.append('text').attr('x', x(0)).attr('y', -6).text('0%').attr('font-size', '10px').attr('fill', '#9ca3af');
      svg.append('text').attr('x', x(100)).attr('y', -6).text('100%').attr('font-size', '10px').attr('fill', '#9ca3af').attr('text-anchor', 'end');

      items.forEach(item => {
        const yi = y(item.geo)!;
        const h = y.bandwidth();

        // Country label
        svg.append('text').attr('x', -8).attr('y', yi + h/2 + 4)
