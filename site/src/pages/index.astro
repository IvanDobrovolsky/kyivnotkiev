    // ── Category bar chart ──────────────────────────────
    function drawCategoryChart() {
      const container = document.getElementById('category-chart')!;
      container.innerHTML = '';

      const rect = container.getBoundingClientRect();
      const margin = { top: 10, right: 60, bottom: 20, left: 180 };
      const width = rect.width - margin.left - margin.right;
      const height = rect.height - margin.top - margin.bottom;

      const svg = d3.select('#category-chart')
        .append('svg')
        .attr('viewBox', `0 0 ${rect.width} ${rect.height}`)
        .append('g')
        .attr('transform', `translate(${margin.left},${margin.top})`);

      // Aggregate by category
      const catData = pairs.categories.map((cat: any) => {
        const catPairs = pairs.pairs.filter((p: any) => p.category === cat.id);
        const avg = catPairs.length ? catPairs.reduce((s: number, p: any) => s + p.adoption, 0) / catPairs.length : 0;
        return { name: cat.name, avg: Math.round(avg * 10) / 10, color: cat.color, count: catPairs.length };
      }).sort((a: any, b: any) => b.avg - a.avg);

      const y = d3.scaleBand()
        .domain(catData.map((d: any) => d.name))
        .range([0, height])
        .padding(0.3);

      const x = d3.scaleLinear().domain([0, 100]).range([0, width]);

      // Background bars
      svg.selectAll('.bg-bar')
        .data(catData)
        .enter().append('rect')
        .attr('x', 0).attr('width', width)
        .attr('y', (d: any) => y(d.name)!)
        .attr('height', y.bandwidth())
        .attr('fill', '#f3f4f6')
        .attr('rx', 3);

      // Value bars
      svg.selectAll('.val-bar')
        .data(catData)
        .enter().append('rect')
        .attr('x', 0)
        .attr('width', (d: any) => x(d.avg))
        .attr('y', (d: any) => y(d.name)!)
        .attr('height', y.bandwidth())
        .attr('fill', (d: any) => d.color)
        .attr('opacity', 0.8)
        .attr('rx', 3);

      // Labels
      svg.selectAll('.cat-label')
        .data(catData)
        .enter().append('text')
        .attr('x', -8)
        .attr('y', (d: any) => y(d.name)! + y.bandwidth() / 2 + 4)
        .attr('text-anchor', 'end')
        .attr('fill', '#374151')
        .attr('font-size', '12px')
        .attr('font-weight', '500')
        .text((d: any) => d.name);

      // Value labels
      svg.selectAll('.val-label')
        .data(catData)
        .enter().append('text')
        .attr('x', (d: any) => x(d.avg) + 8)
        .attr('y', (d: any) => y(d.name)! + y.bandwidth() / 2 + 4)
        .attr('fill', '#6b7280')
        .attr('font-size', '12px')
        .attr('font-weight', '600')
        .text((d: any) => d.avg + '%');
    }

    // ── Heatmap / pair overview ──────────────────────────
    function drawHeatmap() {
      const container = document.getElementById('heatmap-chart')!;
      container.innerHTML = '';

      const sorted = [...pairs.pairs].sort((a: any, b: any) => b.adoption - a.adoption);

      const catColors: Record<string, string> = {};
      pairs.categories.forEach((c: any) => { catColors[c.id] = c.color; });

      const rowHeight = 28;
      const totalHeight = sorted.length * rowHeight;
      container.style.height = totalHeight + 'px';

      const rect = container.getBoundingClientRect();
      const margin = { top: 0, right: 55, bottom: 0, left: 180 };
      const barWidth = rect.width - margin.left - margin.right;

      const svg = d3.select('#heatmap-chart')
        .append('svg')
        .attr('viewBox', `0 0 ${rect.width} ${totalHeight}`)
        .append('g')
        .attr('transform', `translate(${margin.left},0)`);

      const x = d3.scaleLinear().domain([0, 100]).range([0, barWidth]);

      const colorScale = (pct: number) => {
        if (pct >= 80) return '#059669';
        if (pct >= 50) return '#d97706';
        if (pct >= 20) return '#ea580c';
        return '#dc2626';
      };

      sorted.forEach((pair: any, i: number) => {
        const yPos = i * rowHeight;

        // Category dot
        svg.append('circle')
          .attr('cx', -170).attr('cy', yPos + rowHeight / 2)
          .attr('r', 4)
          .attr('fill', catColors[pair.category] || '#999');

        // Label: Ukrainian name
        svg.append('text')
          .attr('x', -160).attr('y', yPos + rowHeight / 2 + 4)
          .attr('fill', '#374151')
          .attr('font-size', '11px')
          .attr('font-weight', '500')
          .text(pair.ukrainian);

        // Old name (strikethrough)
        svg.append('text')
          .attr('x', -160).attr('y', yPos + rowHeight / 2 + 4)
          .attr('fill', 'transparent')
          .attr('font-size', '0px')
          .text('');

        // Background bar
        svg.append('rect')
          .attr('x', 0).attr('width', barWidth)
          .attr('y', yPos + 4)
          .attr('height', rowHeight - 8)
          .attr('fill', '#f3f4f6')
          .attr('rx', 2);

        // Value bar
        svg.append('rect')
          .attr('x', 0)
          .attr('width', x(pair.adoption))
          .attr('y', yPos + 4)
          .attr('height', rowHeight - 8)
          .attr('fill', colorScale(pair.adoption))
          .attr('opacity', 0.75)
          .attr('rx', 2);

        // Percentage
        svg.append('text')
          .attr('x', barWidth + 8)
          .attr('y', yPos + rowHeight / 2 + 4)
          .attr('fill', colorScale(pair.adoption))
          .attr('font-size', '11px')
          .attr('font-weight', '700')
          .attr('font-family', 'var(--font-mono)')
          .text(pair.adoption + '%');

        // Divider
        if (i > 0 && sorted[i - 1].category !== pair.category) {
          svg.append('line')
            .attr('x1', -175).attr('x2', barWidth + 50)
            .attr('y1', yPos).attr('y2', yPos)
            .attr('stroke', '#e5e7eb')
            .attr('stroke-width', 1);
        }
      });
    }

    // ── World map ─────────────────────────────────────────
    // Crimea is Ukraine. The default world-atlas TopoJSON incorrectly
    // shows it as part of Russia. We overlay a corrected Crimea polygon.
    const CRIMEA_GEOJSON = {
      type: "Feature",
      properties: { name: "Crimea (Ukraine)" },
      geometry: {
        type: "Polygon",
        coordinates: [[
          [33.0, 46.1], [33.5, 46.1], [34.0, 46.05], [34.5, 45.95],
          [35.0, 45.7], [35.4, 45.35], [35.8, 45.0], [36.2, 45.2],
          [36.6, 45.35], [36.4, 45.5], [35.8, 45.7], [35.2, 45.5],
          [35.0, 45.55], [34.5, 45.55], [34.0, 45.6], [33.7, 45.8],
          [33.5, 45.95], [33.65, 46.2], [33.85, 46.25], [34.1, 46.3],
          [34.5, 46.15], [34.8, 46.1], [35.2, 46.0], [35.5, 45.75],
          [35.8, 45.4], [36.0, 45.15], [36.5, 45.05], [36.8, 45.0],
          [36.6, 44.7], [36.2, 44.5], [35.6, 44.4], [35.0, 44.55],
          [34.4, 44.55], [33.8, 44.4], [33.5, 44.55], [33.0, 44.4],
