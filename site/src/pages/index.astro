          </td>
          <td style="padding:0.4rem 0.6rem; font-size:0.8rem; color:#dc2626; font-weight:600; font-family:var(--font-mono);">${h.russian_pct}%</td>
          <td style="padding:0.4rem 0.6rem; font-size:0.8rem; color:#9ca3af; font-family:var(--font-mono);">${h.total.toLocaleString()}</td>
          <td style="padding:0.4rem 0.6rem;"><a href="${searchUrl}" target="_blank" rel="noopener" style="font-size:0.65rem; color:#4285F4; text-decoration:none;">verify →</a></td>
        </tr>`;
      }).join('');

      container.innerHTML = `
        <table style="width:100%; border-collapse:collapse;">
          <thead><tr style="border-bottom:2px solid #e5e7eb;">
            <th style="padding:0.4rem 0.6rem; text-align:left; font-size:0.65rem; text-transform:uppercase; color:#6b7280;">Domain</th>
            <th style="padding:0.4rem 0.6rem; text-align:left; font-size:0.65rem; text-transform:uppercase; color:#6b7280;">Old %</th>
            <th style="padding:0.4rem 0.6rem; text-align:left; font-size:0.65rem; text-transform:uppercase; color:#6b7280;">Articles</th>
            <th style="padding:0.4rem 0.6rem; text-align:left; font-size:0.65rem; text-transform:uppercase; color:#6b7280;"></th>
          </tr></thead>
          <tbody>${rows}</tbody>
        </table>
        <div style="font-size:0.65rem; color:#9ca3af; padding:0.4rem 0.6rem;">${filtered.length} domains · ${pairHoldouts.length} total</div>
      `;
