---
import Base from '../layouts/Base.astro';
import m from '../data/manifest.json';

function fmtBig(n: string | number) {
  const v = typeof n === 'string' ? parseInt(n) : n;
  if (v >= 1_000_000_000) return (v / 1_000_000_000).toFixed(1) + 'B';
  if (v >= 1_000_000) return (v / 1_000_000).toFixed(1) + 'M';
  if (v >= 1_000) return (v / 1_000).toFixed(1) + 'K';
  return v.toString();
}

function adoptionColor(pct: number) {
  if (pct >= 70) return '#059669';
  if (pct >= 40) return '#d97706';
  return '#dc2626';
}

const pairs = m.pairs.filter((p: any) => !p.is_control).sort((a: any, b: any) => (b.total || 0) - (a.total || 0));
const categories = m.categories || [];
---

<Base activeNav="home">

<!-- Hero -->
<div style="display:flex; align-items:center; gap:1.5rem; padding:1.5rem 0 1rem;">
  <img src="/logo.svg" alt="Kyiv chestnut" style="height:80px; width:auto; flex-shrink:0;">
  <div>
    <h1 style="font-size:1.6rem; font-weight:800; margin:0; line-height:1.2; color:#0057B8;">
      #KyivNotKiev
    </h1>
    <p style="color:var(--text); font-size:0.9rem; margin:0.3rem 0 0; line-height:1.5;">
      Measuring how the world spells Ukrainian place names — {fmtBig(m.toponym_matches)} matches across {m.num_sources} sources, {m.time_span}.
    </p>
  </div>
</div>

<!-- Stats strip -->
<div class="stats resp-grid-5" style="grid-template-columns: repeat(5, 1fr); margin-bottom: 1rem;">
  <div class="stat-card">
    <div class="stat-value">{m.records_scanned}</div>
    <div class="stat-label">Records Scanned</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">{fmtBig(m.toponym_matches)}</div>
    <div class="stat-label">Toponym Matches</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">{m.analyzable_pairs}</div>
    <div class="stat-label">Toponym Pairs</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">{m.num_sources}</div>
    <div class="stat-label">Data Sources</div>
  </div>
  <div class="stat-card">
    <div class="stat-value">{m.time_span}</div>
    <div class="stat-label">Time Span</div>
  </div>
</div>

<!-- Filter/sort controls -->
<div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.75rem; flex-wrap:wrap;">
  <span style="font-size:0.75rem; color:var(--text-muted);">Sort:</span>
  <button class="sort-btn active" data-sort="volume">Volume</button>
  <button class="sort-btn" data-sort="adoption">Adoption %</button>
  <button class="sort-btn" data-sort="alpha">A-Z</button>
  <span style="flex:1;"></span>
  <span style="font-size:0.75rem; color:var(--text-muted);">Filter:</span>
  <button class="filter-btn active" data-cat="all">All</button>
  {categories.map((cat: any) => (
    <button class="filter-btn" data-cat={cat.id} style={`--cat-color: ${cat.color}`}>{cat.name}</button>
  ))}
</div>

<!-- Pair cards grid -->
<div id="pair-grid" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:0.6rem;">
  {pairs.map((p: any) => {
    const pct = p.adoption || 0;
    const color = adoptionColor(pct);
    return (
      <a href={`/pair/${p.id}`} class="pair-card" data-category={p.category} data-adoption={pct} data-total={p.total || 0} data-name={p.ukrainian}
         style="text-decoration:none; display:block; padding:0.7rem 0.9rem; border:1px solid var(--border); border-radius:8px; background:var(--card-bg); transition:all 0.15s; cursor:pointer;">
        <div style="display:flex; justify-content:space-between; align-items:baseline; gap:0.5rem;">
          <div style="min-width:0; overflow:hidden;">
            <span style="font-size:0.7rem; color:var(--text-muted); text-decoration:line-through;">{p.russian}</span>
            <span style="font-size:0.7rem; color:var(--text-muted); margin:0 0.2rem;">→</span>
            <span style="font-size:0.85rem; font-weight:600; color:var(--text);">{p.ukrainian}</span>
          </div>
          <span style={`font-size:0.9rem; font-weight:700; color:${color}; flex-shrink:0;`}>{pct}%</span>
        </div>
        <div style="height:3px; background:#f0f0f0; border-radius:2px; margin-top:0.35rem;">
          <div style={`height:100%; width:${Math.min(pct, 100)}%; background:${color}; border-radius:2px;`}></div>
        </div>
        <div style="display:flex; justify-content:space-between; margin-top:0.25rem;">
          <span style="font-size:0.6rem; color:var(--text-dim);">{p.category}</span>
          <span style="font-size:0.6rem; color:var(--text-dim);">{fmtBig(p.total || 0)} matches</span>
        </div>
      </a>
    );
  })}
</div>

<!-- About -->
<div style="margin-top:1.5rem; padding:1rem; font-size:0.8rem; color:var(--text-muted); line-height:1.6; border-top:1px solid var(--border);">
  <p style="margin:0 0 0.5rem;">
    In 2018 Ukraine's MFA launched #KyivNotKiev — a campaign to change how the world spells Ukrainian place names.
    This project measures whether it worked, tracking {m.analyzable_pairs} toponym pairs across {m.num_sources} independent
    data sources spanning {m.time_span}.
  </p>
  <p style="margin:0;">
    Built by <a href="https://github.com/IvanDobrovolsky" target="_blank" style="color:#0057B8;">Ivan Dobrovolsky</a>.
    Dataset and model on <a href="https://huggingface.co/KyivNotKiev" target="_blank" style="color:#0057B8;">Hugging Face</a>.
  </p>
</div>

<script>
  // Sort and filter
  const grid = document.getElementById('pair-grid')!;
  const cards = Array.from(grid.querySelectorAll('.pair-card')) as HTMLElement[];

  document.querySelectorAll('.sort-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const mode = (btn as HTMLElement).dataset.sort;
      const sorted = [...cards].sort((a, b) => {
        if (mode === 'volume') return (Number(b.dataset.total) || 0) - (Number(a.dataset.total) || 0);
        if (mode === 'adoption') return (Number(b.dataset.adoption) || 0) - (Number(a.dataset.adoption) || 0);
        return (a.dataset.name || '').localeCompare(b.dataset.name || '');
      });
      sorted.forEach(c => grid.appendChild(c));
    });
  });

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = (btn as HTMLElement).dataset.cat;
      cards.forEach(c => {
        c.style.display = (cat === 'all' || c.dataset.category === cat) ? '' : 'none';
      });
    });
  });
</script>

<style>
  .sort-btn, .filter-btn {
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--card-bg);
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.15s;
  }
  .sort-btn.active, .filter-btn.active {
    background: #0057B8;
    color: white;
    border-color: #0057B8;
  }
  .pair-card:hover {
    border-color: #0057B8 !important;
    box-shadow: 0 2px 8px rgba(0,87,184,0.1);
  }
</style>

</Base>
