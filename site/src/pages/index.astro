          .text(item.name);

        // GDELT bar only
        if (item.gdelt !== null) {
          svg.append('rect')
            .attr('x', x(0)).attr('y', yi + h * 0.15)
            .attr('width', Math.max(2, x(item.gdelt))).attr('height', h * 0.7)
            .attr('fill', '#1e3a5f').attr('rx', 3).attr('opacity', 0.85);
          svg.append('text').attr('x', x(item.gdelt) + 6).attr('y', yi + h/2 + 4)
            .attr('font-size', '11px').attr('fill', '#1e3a5f').attr('font-weight', '600')
