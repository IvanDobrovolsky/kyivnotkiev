    function drawHoldoutTable() {
      const container = document.getElementById('holdout-table')!;
      const pairHoldouts = (holdoutsByPair as any)[String(activePairId)];

      const nameEl = document.getElementById('holdout-pair-name');
      const pair = (pairs as any).pairs.find((p: any) => p.id === activePairId);
      if (nameEl && pair) nameEl.textContent = pair.russian;

      if (!pairHoldouts || pairHoldouts.length === 0) {
        container.innerHTML = '<div style="padding:2rem; text-align:center; color:#9ca3af; font-size:0.85rem;">No holdout data for this pair</div>';
        return;
      }

      // Filter by domain type
      let filtered = pairHoldouts;
      if (holdoutFilter === 'intl') filtered = pairHoldouts.filter((h: any) => !h.is_ru && !h.domain.endsWith('.ua'));
      else if (holdoutFilter === 'ru') filtered = pairHoldouts.filter((h: any) => h.is_ru);
      else if (holdoutFilter === 'ua') filtered = pairHoldouts.filter((h: any) => h.domain.endsWith('.ua'));

      if (filtered.length === 0) {
        container.innerHTML = `<div style="padding:1.5rem; text-align:center; color:#9ca3af; font-size:0.8rem;">No holdouts in this category</div>`;
        return;
      }

      const rows = filtered.map((h: any) => {
        const searchUrl = `https://www.google.com/search?q=site:${h.domain}+${pair?.russian || ''}`;
        const isRu = h.is_ru;
        const isUa = h.domain.endsWith('.ua');
        const tag = isRu ? '<span style="font-size:0.6rem; color:#dc2626; background:#fef2f2; padding:0.1rem 0.3rem; border-radius:3px; margin-left:0.3rem;">.ru</span>'
                  : isUa ? '<span style="font-size:0.6rem; color:#0057B8; background:#f0f9ff; padding:0.1rem 0.3rem; border-radius:3px; margin-left:0.3rem;">.ua</span>'
