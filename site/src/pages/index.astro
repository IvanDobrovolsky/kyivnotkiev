---
import Base from '../layouts/Base.astro';
import m from '../data/manifest.json';

function fmtBig(n: string | number) {
  const v = typeof n === 'string' ? parseInt(n) : n;
  if (v >= 1_000_000_000) return (v / 1_000_000_000).toFixed(1) + 'B';
  if (v >= 1_000_000) return (v / 1_000_000).toFixed(1) + 'M';
  if (v >= 1_000) return (v / 1_000).toFixed(1) + 'K';
  return v.toString();
}

function adoptionColor(pct: number) {
  if (pct >= 70) return '#059669';
  if (pct >= 40) return '#d97706';
  return '#dc2626';
}

const pairs = m.pairs.filter((p: any) => !p.is_control).sort((a: any, b: any) => (b.total || 0) - (a.total || 0));
const categories = (m.categories || []).filter((c: any) => pairs.some((p: any) => p.category === c.id));
---

<Base activeNav="home">

<!-- Hero -->
<div style="display:flex; align-items:center; gap:1.5rem; padding:1.5rem 0 0.75rem;">
  <img src="/logo.svg" alt="Kyiv chestnut" style="height:80px; width:auto; flex-shrink:0;">
  <div>
    <h1 style="font-size:1.6rem; font-weight:800; margin:0; line-height:1.2; color:#0057B8;">
      #KyivNotKiev
    </h1>
    <p style="color:var(--text); font-size:0.9rem; margin:0.3rem 0 0; line-height:1.6;">
      In 2018, Ukraine's foreign ministry <a href="https://en.wikipedia.org/wiki/KyivNotKiev" target="_blank" style="color:#0057B8;">launched a campaign</a> to change
      how the world spells Ukrainian place names. We built a data pipeline to measure whether it worked.
    </p>
  </div>
</div>

<!-- Stats strip -->
<div style="display:grid; grid-template-columns:repeat(5, 1fr); gap:3px; margin-bottom:1rem;">
  <div class="stat-pill">
    <span class="stat-pill-value">{m.records_scanned}</span>
    <span class="stat-pill-label">records scanned</span>
  </div>
  <div class="stat-pill">
    <span class="stat-pill-value">{fmtBig(m.toponym_matches)}</span>
    <span class="stat-pill-label">toponym matches</span>
  </div>
  <div class="stat-pill">
    <span class="stat-pill-value">{m.analyzable_pairs}</span>
    <span class="stat-pill-label">pairs tracked</span>
  </div>
  <div class="stat-pill">
    <span class="stat-pill-value">{m.num_sources}</span>
    <span class="stat-pill-label">data sources</span>
  </div>
  <div class="stat-pill">
    <span class="stat-pill-value">{m.time_span}</span>
    <span class="stat-pill-label">time span</span>
  </div>
</div>

<!-- Sort + Filter -->
<div class="controls-bar">
  <div class="controls-group">
    <span class="controls-label">Sort</span>
    <button class="ctrl-btn active" data-sort="volume">Volume</button>
    <button class="ctrl-btn" data-sort="adoption">Adoption</button>
    <button class="ctrl-btn" data-sort="alpha">A-Z</button>
  </div>
  <div class="controls-group">
    <span class="controls-label">Filter</span>
    <button class="ctrl-btn active" data-cat="all">All</button>
    {categories.map((cat: any) => (
      <button class="ctrl-btn" data-cat={cat.id}>{cat.name}</button>
    ))}
  </div>
</div>

<!-- Pair cards -->
<div id="pair-grid" class="pair-grid">
  {pairs.map((p: any) => {
    const pct = p.adoption || 0;
    const color = adoptionColor(pct);
    return (
      <a href={`/pair/${p.id}`} class="pair-card" data-category={p.category} data-adoption={pct} data-total={p.total || 0} data-name={p.ukrainian}>
        <div class="pair-card-top">
          <div class="pair-card-names">
            <span class="pair-old">{p.russian}</span>
            <span class="pair-arrow">→</span>
            <span class="pair-new">{p.ukrainian}</span>
          </div>
          <span class="pair-pct" style={`color:${color}`}>{pct}%</span>
        </div>
        <div class="pair-card-bar">
          <div style={`width:${Math.min(pct, 100)}%; background:${color};`}></div>
        </div>
        <div class="pair-card-meta">
          <span>{p.category}</span>
          <span>{fmtBig(p.total || 0)} matches</span>
        </div>
      </a>
    );
  })}
</div>

<!-- About -->
<div class="about-footer">
  <p>
    This dashboard tracks {m.analyzable_pairs} Ukrainian toponym pairs across {m.num_sources} independent data sources
    (news, search, encyclopedias, social media, books, and academic papers) from {m.time_span}.
    Each pair measures a single question: did the author write the Ukrainian or Russian spelling?
  </p>
  <p>
    Built by <a href="https://github.com/IvanDobrovolsky" target="_blank">Ivan Dobrovolsky</a>.
    Dataset and model on <a href="https://huggingface.co/KyivNotKiev" target="_blank">Hugging Face</a>.
    <a href="https://www.bbc.com/ukrainian/news-45718643" target="_blank">BBC Ukraine coverage</a>.
  </p>
</div>

<script>
  const grid = document.getElementById('pair-grid')!;
  const cards = Array.from(grid.querySelectorAll('.pair-card')) as HTMLElement[];

  document.querySelectorAll('[data-sort]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-sort]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const mode = (btn as HTMLElement).dataset.sort;
      const sorted = [...cards].sort((a, b) => {
        if (mode === 'volume') return (Number(b.dataset.total) || 0) - (Number(a.dataset.total) || 0);
        if (mode === 'adoption') return (Number(b.dataset.adoption) || 0) - (Number(a.dataset.adoption) || 0);
        return (a.dataset.name || '').localeCompare(b.dataset.name || '');
      });
      sorted.forEach(c => grid.appendChild(c));
    });
  });

  document.querySelectorAll('[data-cat]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-cat]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = (btn as HTMLElement).dataset.cat;
      cards.forEach(c => {
        c.style.display = (cat === 'all' || c.dataset.category === cat) ? '' : 'none';
      });
    });
  });
</script>

<style>
  .stat-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.5rem;
    background: var(--card-bg);
    border-radius: 6px;
    border: 1px solid var(--border);
  }
  .stat-pill-value {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text);
  }
  .stat-pill-label {
    font-size: 0.6rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .controls-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .controls-group {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
  .controls-label {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-right: 0.2rem;
  }
  .ctrl-btn {
    font-size: 0.72rem;
    padding: 0.3rem 0.65rem;
    border: 1px solid var(--border);
    border-radius: 5px;
    background: var(--card-bg);
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.15s;
    font-weight: 500;
  }
  .ctrl-btn:hover { border-color: #0057B8; color: var(--text); }
  .ctrl-btn.active {
    background: #0057B8;
    color: white;
    border-color: #0057B8;
  }

  .pair-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.6rem;
  }
  .pair-card {
    text-decoration: none;
    display: block;
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card-bg);
    transition: all 0.15s;
    cursor: pointer;
  }
  .pair-card:hover {
    border-color: #0057B8;
    box-shadow: 0 2px 8px rgba(0,87,184,0.08);
  }
  .pair-card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
  }
  .pair-card-names { min-width: 0; overflow: hidden; }
  .pair-old {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-decoration: line-through;
  }
  .pair-arrow {
    font-size: 0.68rem;
    color: var(--text-dim);
    margin: 0 0.15rem;
  }
  .pair-new {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text);
  }
  .pair-pct {
    font-size: 0.95rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .pair-card-bar {
    height: 3px;
    background: #f0f0f0;
    border-radius: 2px;
    margin-top: 0.3rem;
    overflow: hidden;
  }
  .pair-card-bar div {
    height: 100%;
    border-radius: 2px;
  }
  .pair-card-meta {
    display: flex;
    justify-content: space-between;
    margin-top: 0.2rem;
    font-size: 0.6rem;
    color: var(--text-dim);
  }

  .about-footer {
    margin-top: 1.5rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border);
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .about-footer p { margin: 0 0 0.4rem; }
  .about-footer a { color: #0057B8; }
</style>

</Base>
