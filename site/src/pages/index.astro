        container.style.display = 'none';
        return;
      }

      const margin = { top: 20, right: 20, bottom: 10, left: 120 };
      const width = chartEl.getBoundingClientRect().width - margin.left - margin.right;
      const rowH = 32;
      const height = items.length * rowH;

      const svg = d3.select('#cross-lingual-chart')
        .append('svg')
        .attr('viewBox', `0 0 ${width + margin.left + margin.right} ${height + margin.top + margin.bottom}`)
        .append('g')
        .attr('transform', `translate(${margin.left},${margin.top})`);

      const x = d3.scaleLinear().domain([0, 100]).range([0, width]);
      const y = d3.scaleBand().domain(items.map(d => d.geo)).range([0, height]).padding(0.3);

