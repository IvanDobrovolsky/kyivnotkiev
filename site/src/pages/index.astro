  <script>
    import * as d3 from 'd3';
    import * as topojson from 'topojson-client';
    import timeseriesData from '../data/timeseries.json';
    import manifest from '../data/manifest.json';
    import holdoutsData from '../data/holdouts.json';
    import holdoutsByPair from '../data/holdouts_by_pair.json';
    import countriesByPair from '../data/countries_by_pair.json';
    import pairEvents from '../data/pair_events.json';
    import trendsCountries from '../data/trends_countries.json';
    import errorAnalysis from '../data/error_analysis.json';

    // Use manifest as the single pairs source
    const pairs = { categories: manifest.categories, pairs: manifest.pairs };

    const sourceColors: Record<string, string> = {
      trends: '#4285F4',
      gdelt: '#1e3a5f',
      wikipedia: '#636466',
      reddit: '#FF4500',
      youtube: '#FF0000',
      ngrams: '#7c3aed',
      openalex: '#06b6d4',
    };

    const sourceLabels: Record<string, string> = {
      trends: 'Google Trends',
      gdelt: 'GDELT News',
      wikipedia: 'Wikipedia',
      reddit: 'Reddit',
      youtube: 'YouTube',
      ngrams: 'Google Books',
      openalex: 'Academic Papers',
    };

    let activeSource = 'trends';  // single source at a time
    let activeSources = new Set(['trends']);  // kept as set for chart compatibility
    let hideRuDomains = false;
    let lineMode: 'both' | 'ukrainian' | 'russian' = 'both';
    let chartMode: 'adoption' | 'volume' = 'adoption';
    let showEvents = true;

    // Read pair from URL query param (?pair=1), default to Kyiv (1)
    function getPairFromUrl(): number {
      const params = new URLSearchParams(window.location.search);
      const p = params.get('pair');
      if (p) {
        const id = parseInt(p);
        if (!isNaN(id) && (pairs as any).pairs.some((pp: any) => pp.id === id)) return id;
      }
      return 1;
    }

    function updateUrl(pairId: number) {
      const url = new URL(window.location.href);
      if (pairId === 1) {
        url.searchParams.delete('pair');
      } else {
        url.searchParams.set('pair', String(pairId));
      }
      window.history.replaceState({}, '', url.toString());
    }

    let activePairId = getPairFromUrl();

    function drawChart() {
      const container = document.getElementById('chart')!;
      const legendContainer = document.getElementById('chart-legend')!;

      // Fade out, redraw, fade in
      container.style.opacity = '0';
      container.style.transition = 'opacity 0.15s ease';
      container.innerHTML = '';
      legendContainer.innerHTML = '';

      requestAnimationFrame(() => {
        container.style.opacity = '1';
      });

      const rect = container.getBoundingClientRect();
      const margin = { top: 52, right: 55, bottom: 30, left: 45 };
      const width = rect.width - margin.left - margin.right;
      const height = rect.height - margin.top - margin.bottom;

      const svg = d3.select('#chart')
        .append('svg')
        .attr('viewBox', `0 0 ${rect.width} ${rect.height}`)
        .append('g')
        .attr('transform', `translate(${margin.left},${margin.top})`);

      const pairData = (timeseriesData as any)[String(activePairId)];
      if (!pairData) {
        svg.append('text')
          .attr('x', width / 2).attr('y', height / 2)
          .attr('text-anchor', 'middle')
          .attr('fill', '#9ca3af')
          .attr('font-size', '14px')
          .text('No data available for this pair');
        return;
      }

      // Check if active source has data for this pair
      const hasData = activeSources.size > 0 && [...activeSources].some(s => pairData[s] && pairData[s].length > 0);
      if (!hasData) {
        svg.append('text')
          .attr('x', width / 2).attr('y', height / 2 - 10)
          .attr('text-anchor', 'middle')
          .attr('fill', '#9ca3af')
          .attr('font-size', '14px')
          .text(`No ${sourceLabels[activeSource] || activeSource} data for this pair`);
        svg.append('text')
          .attr('x', width / 2).attr('y', height / 2 + 14)
          .attr('text-anchor', 'middle')
          .attr('fill', '#d1d5db')
          .attr('font-size', '12px')
          .text('Try switching to Trends or Wikipedia for broader coverage');
        return;
      }

      const parseDate = d3.timeParse('%Y-%m');
      const allDates: Date[] = [];

      for (const src of activeSources) {
        const series = pairData[src];
        if (!series) continue;
        for (const d of series) {
          const date = parseDate(d.date);
          if (date) allDates.push(date);
        }
      }

      if (allDates.length === 0) return;

      // Dynamic range based on actual data for this pair + source
      const seriesData = pairData[activeSource] || [];
      const dataMinDate = d3.min(allDates) as Date;
      const dataMaxDate = d3.max(allDates) as Date;

      // Pad 6 months before/after data range
      const xStart = new Date(dataMinDate.getFullYear(), dataMinDate.getMonth() - 6, 1);
      const xEnd = new Date(dataMaxDate.getFullYear(), dataMaxDate.getMonth() + 6, 1);
      const x = d3.scaleTime()
        .domain([xStart, xEnd])
        .range([0, width]);

      // Update title range and info text
      const rangeEl = document.getElementById('chart-range');
      const infoEl = document.getElementById('chart-info');
      const sourceInfo: Record<string, string> = {
        trends: 'Monthly search interest',
        gdelt: 'GDELT v2 news monitoring',
        wikipedia: 'Pageviews API',
        reddit: 'Reddit posts, annual',
        youtube: 'Video title matches, annual',
        ngrams: 'Google Books corpus',
        openalex: 'OpenAlex academic papers',
      };
      const startYear = dataMinDate.getFullYear();
      const endYear = dataMaxDate.getFullYear();
      if (rangeEl) rangeEl.textContent = `${startYear}–${endYear}`;
      if (infoEl) infoEl.textContent = sourceInfo[activeSource] || '';

      // Y-axis depends on chart mode
      let y: d3.ScaleLinear<number, number>;
      if (chartMode === 'volume') {
        // Find max count across all data points
        const maxCount = Math.max(...(seriesData || []).map((d: any) => Math.max(d.ukr || 0, d.rus || 0, (d.ukr || 0) + (d.rus || 0))), 10);
        y = d3.scaleLinear().domain([0, maxCount * 1.1]).range([height, 0]);
      } else {
        y = d3.scaleLinear().domain([0, 100]).range([height, 0]);
      }

      // Grid
      const gridTicks = chartMode === 'volume' ? y.ticks(5) : [25, 50, 75, 100];
      svg.append('g').selectAll('line')
        .data(gridTicks)
        .enter().append('line')
        .attr('x1', 0).attr('x2', width)
        .attr('y1', (d: number) => y(d)).attr('y2', (d: number) => y(d))
        .attr('stroke', '#e5e7eb')
        .attr('stroke-dasharray', '3,4');

      // Y-axis labels
      svg.append('g').selectAll('text')
        .data([0, 25, 50, 75, 100])
        .enter().append('text')
        .attr('x', -8).attr('y', (d: number) => y(d) + 4)
        .attr('text-anchor', 'end')
        .attr('fill', '#9ca3af').attr('font-size', '11px')
        .text((d: number) => chartMode === 'volume' ? (d >= 1000 ? (d/1000).toFixed(0) + 'K' : String(d)) : d + '%');

      // X-axis — decades for Ngrams, years for others
      const xTicks = activeSource === 'ngrams'
        ? d3.axisBottom(x).ticks(d3.timeYear.every(10)).tickSize(0).tickPadding(8).tickFormat(d3.timeFormat('%Y') as any)
        : d3.axisBottom(x).ticks(d3.timeYear.every(1)).tickSize(0).tickPadding(8).tickFormat(d3.timeFormat('%Y') as any);

      svg.append('g')
        .attr('transform', `translate(0,${height})`)
        .call(xTicks)
        .selectAll('text').attr('fill', '#9ca3af').attr('font-size', '12px');

      svg.selectAll('.domain').attr('stroke', '#e5e7eb');

      // Event markers — positioned by date on x-scale
      if (showEvents) {
        const globalEvents = ((timeseriesData as any).events || []).map((e: any) => ({...e, type: 'global'}));
        const customEvents = ((pairEvents as any)[String(activePairId)] || []).map((e: any) => ({...e, type: 'pair'}));
        const events = [...globalEvents, ...customEvents].sort((a: any, b: any) => a.date.localeCompare(b.date));

        let eventNum = 0;
        events.forEach((evt: any) => {
          const date = parseDate(evt.date);
          if (!date || date < xStart || date > xEnd) return;
          eventNum++;
          const xPos = x(date);
          const isPair = evt.type === 'pair';

          // Vertical dashed line
          svg.append('line')
            .attr('x1', xPos).attr('x2', xPos)
            .attr('y1', -10).attr('y2', height)
            .attr('stroke', isPair ? '#0057B8' : '#d1d5db')
            .attr('stroke-width', 1)
            .attr('stroke-dasharray', '4,3')
            .attr('opacity', isPair ? 0.5 : 0.3);

          // Numbered circle at top
          svg.append('circle')
            .attr('cx', xPos).attr('cy', -18)
            .attr('r', 9)
            .attr('fill', isPair ? '#0057B8' : '#e5e7eb');
          svg.append('text')
            .attr('x', xPos).attr('y', -14)
            .attr('text-anchor', 'middle')
            .attr('fill', isPair ? '#fff' : '#6b7280')
            .attr('font-size', '10px')
            .attr('font-weight', '700')
            .text(eventNum);

          // Legend entry below chart
          const legendItem = document.createElement('span');
          legendItem.className = 'legend-item';
          legendItem.style.cssText = `font-size:0.78rem; color:${isPair ? '#0057B8' : '#6b7280'}; ${isPair ? 'font-weight:600;' : ''}`;
          legendItem.innerHTML = `<span style="display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;background:${isPair ? '#0057B8' : '#e5e7eb'};color:${isPair ? '#fff' : '#6b7280'};font-size:10px;font-weight:700;margin-right:4px;">${eventNum}</span>${evt.label} (${evt.date})`;
          legendContainer.appendChild(legendItem);
        });
      }

      // Data lines + crosshair tooltip
      const chartContainer = document.getElementById('chart')!;
      chartContainer.style.position = 'relative';

      const tooltip = d3.select('#chart')
        .append('div')
        .style('position', 'absolute')
        .style('background', 'white')
        .style('border', '1px solid #d1d5db')
        .style('border-radius', '8px')
        .style('padding', '10px 14px')
        .style('font-size', '13px')
        .style('pointer-events', 'none')
        .style('opacity', '0')
        .style('box-shadow', '0 4px 16px rgba(0,0,0,0.12)')
        .style('z-index', '10')
        .style('white-space', 'nowrap')
        .style('line-height', '1.6');

      const crosshairLine = svg.append('line')
        .attr('y1', 0).attr('y2', height)
        .attr('stroke', '#d1d5db')
        .attr('stroke-width', 1)
        .attr('stroke-dasharray', '4,3')
        .style('opacity', 0);

      // Build all series data for crosshair lookup
      const allSeriesData: Record<string, any[]> = {};
      const activeLegend: {label: string; color: string; value: number}[] = [];

      for (const src of activeSources) {
        const series = pairData[src];
        if (!series) continue;
        allSeriesData[src] = series;

        if (chartMode === 'volume') {
          // ── VOLUME MODE: stacked bar chart ──
          const barWidth = Math.max(2, Math.min(20, width / series.length - 2));
          series.forEach((d: any) => {
            const date = parseDate(d.date);
            if (!date) return;
            const ukr = d.ukr || 0;
            const rus = d.rus || 0;
            const cx = x(date);

            if (lineMode !== 'russian' && ukr > 0) {
              svg.append('rect')
                .attr('x', cx - barWidth / 2)
                .attr('y', y(ukr + (lineMode === 'both' ? rus : 0)))
                .attr('width', barWidth)
                .attr('height', Math.max(0, height - y(ukr)))
                .attr('fill', sourceColors[src])
                .attr('opacity', 0.8)
                .attr('rx', 1);
            }

            if (lineMode !== 'ukrainian' && rus > 0) {
              svg.append('rect')
                .attr('x', cx - barWidth / 2)
                .attr('y', lineMode === 'both' ? y(rus) : y(rus))
                .attr('width', barWidth)
                .attr('height', Math.max(0, height - y(rus)))
                .attr('fill', '#dc2626')
                .attr('opacity', lineMode === 'russian' ? 0.8 : 0.4)
                .attr('rx', 1);
            }
          });
        } else {
          // ── ADOPTION MODE: line chart ──
          const line = d3.line<any>()
            .x((d: any) => x(parseDate(d.date)!))
            .y((d: any) => y(d.adoption))
            .curve(d3.curveBasis);

          if (lineMode !== 'russian') {
            svg.append('path')
              .datum(series)
              .attr('fill', 'none')
              .attr('stroke', sourceColors[src])
              .attr('stroke-width', 3)
              .attr('d', line);
          }

          if (lineMode !== 'ukrainian') {
            const russianLine = d3.line<any>()
              .x((d: any) => x(parseDate(d.date)!))
              .y((d: any) => y(100 - d.adoption))
              .curve(d3.curveBasis);

            svg.append('path')
              .datum(series)
              .attr('fill', 'none')
              .attr('stroke', '#dc2626')
              .attr('stroke-width', lineMode === 'russian' ? 3 : 1.5)
              .attr('stroke-dasharray', lineMode === 'russian' ? 'none' : '6,4')
              .attr('opacity', lineMode === 'russian' ? 1 : 0.5)
              .attr('d', russianLine);
          }
        }

        // Start indicator (if doesn't start at 2010)
        const first = series[0];
        const firstDate = parseDate(first.date)!;
        if (firstDate > new Date(2010, 6, 1)) {
          const sx = x(firstDate);
          const sy = y(first.adoption);
          svg.append('circle')
            .attr('cx', sx).attr('cy', sy)
            .attr('r', 3)
            .attr('fill', 'none')
            .attr('stroke', sourceColors[src])
            .attr('stroke-width', 1.5);
          svg.append('text')
            .attr('x', sx - 4).attr('y', sy - 8)
            .attr('text-anchor', 'end')
            .attr('fill', sourceColors[src])
            .attr('font-size', '9px')
            .attr('opacity', 0.7)
            .text(first.date);
        }

        // End dot + label
        const last = series[series.length - 1];
        const cx = x(parseDate(last.date)!);
        const cy = y(last.adoption);

        svg.append('circle')
          .attr('cx', cx).attr('cy', cy)
          .attr('r', 4)
          .attr('fill', sourceColors[src]);

        svg.append('text')
          .attr('x', cx + 10).attr('y', cy + 5)
          .attr('fill', sourceColors[src])
          .attr('font-size', '13px')
          .attr('font-weight', '700')
          .text(last.adoption + '%');

        // End date if doesn't reach 2026
        const lastDate = parseDate(last.date)!;
        if (lastDate < new Date(2025, 6, 1)) {
          svg.append('text')
            .attr('x', cx + 8).attr('y', cy + 16)
            .attr('fill', sourceColors[src])
            .attr('font-size', '9px')
            .attr('opacity', 0.6)
            .text('ends ' + last.date);
        }

        activeLegend.push({
          label: sourceLabels[src],
          color: sourceColors[src],
          value: last.adoption,
        });
      }

      // Crosshair overlay — interpolates between data points
      svg.append('rect')
        .attr('width', width).attr('height', height)
        .attr('fill', 'transparent')
        .on('mousemove', function(event: MouseEvent) {
          const [mx] = d3.pointer(event);
          const hoveredDate = x.invert(mx);
          const dateStr = d3.timeFormat('%b %Y')(hoveredDate);

          crosshairLine.attr('x1', mx).attr('x2', mx).style('opacity', 1);

          let html = `<strong>${dateStr}</strong>`;
          for (const src of Object.keys(allSeriesData)) {
            const series = allSeriesData[src];
            if (series.length < 2) continue;

            // Convert to date-value pairs for bisection
            const dates = series.map((d: any) => parseDate(d.date)!.getTime());
            const vals = series.map((d: any) => d.adoption);

            const t = hoveredDate.getTime();
            // Check if within data range
            if (t < dates[0] || t > dates[dates.length - 1]) continue;

            // Binary search for bracketing points
            let lo = 0, hi = dates.length - 1;
            while (hi - lo > 1) {
              const mid = (lo + hi) >> 1;
              if (dates[mid] <= t) lo = mid; else hi = mid;
            }

            // Linear interpolation between lo and hi
            const frac = (t - dates[lo]) / (dates[hi] - dates[lo] || 1);
            const interpolated = vals[lo] + frac * (vals[hi] - vals[lo]);
            const value = Math.round(interpolated * 10) / 10;

            html += `<br/><span style="color:${sourceColors[src]}">● ${sourceLabels[src]}: <strong>${value}%</strong></span>`;
          }

          tooltip.style('opacity', '1').html(html);
          const cr = chartContainer.getBoundingClientRect();
          const left = event.clientX - cr.left;
          tooltip.style('left', (left > width / 2 ? left - 200 : left + 20) + 'px')
            .style('top', '10px');
        })
        .on('mouseleave', function() {
          crosshairLine.style('opacity', 0);
          tooltip.style('opacity', '0');
        });

      // Legend
      if (lineMode !== 'russian') {
        for (const item of activeLegend) {
          const el = document.createElement('div');
          el.className = 'legend-item';
          el.innerHTML = `<span class="legend-line" style="background: ${item.color}"></span>${item.label}: ${item.value}%`;
          legendContainer.appendChild(el);
        }
      }
      if (lineMode !== 'ukrainian') {
        const el = document.createElement('div');
        el.className = 'legend-item';
        const lastVal = activeLegend[0] ? (100 - activeLegend[0].value).toFixed(1) : '?';
        el.innerHTML = `<span class="legend-line" style="background: #dc2626"></span>Old spelling: ${lastVal}%`;
        legendContainer.appendChild(el);
      }
    }

    // Sidebar
    document.querySelectorAll('.sidebar-header').forEach(header => {
      header.addEventListener('click', () => {
        header.classList.toggle('open');
        header.nextElementSibling?.classList.toggle('open');
      });
    });

    function selectPair(pairId: number) {
      activePairId = pairId;
      updateUrl(pairId);
      document.querySelectorAll('.sidebar-item').forEach(i => {
        const id = parseInt((i as HTMLElement).dataset.pairId || '0');
        i.classList.toggle('active', id === pairId);
        // Open parent category if needed
        if (id === pairId) {
          const section = i.closest('.sidebar-section');
          if (section) {
            section.querySelector('.sidebar-header')?.classList.add('open');
            section.querySelector('.sidebar-items')?.classList.add('open');
          }
        }
      });
      const pair = (pairs as any).pairs.find((p: any) => p.id === pairId);
      if (pair) {
        document.getElementById('chart-new')!.textContent = pair.ukrainian;
        document.getElementById('chart-old')!.textContent = pair.russian;
      }
      drawChart();
      drawWorldMap();
      drawHoldoutTable();
    }

    document.querySelectorAll('.sidebar-item').forEach(item => {
      item.addEventListener('click', () => {
        selectPair(parseInt((item as HTMLElement).dataset.pairId || '1'));
      });
    });

    // Initialize from URL param
    if (activePairId !== 1) {
      selectPair(activePairId);
    }

    // Source toggles — radio behavior (one at a time)
    document.querySelectorAll('.source-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const src = (btn as HTMLElement).dataset.source!;
        // Deactivate all, activate clicked
        document.querySelectorAll('.source-toggle').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeSource = src;
        activeSources = new Set([src]);
        drawChart();

        // Show map for GDELT and Trends (both have country data)
        const mapEl = document.getElementById('map-container');
        if (mapEl) {
          if (src === 'gdelt' || src === 'trends') {
            mapEl.style.display = 'block';
            drawWorldMap();
          } else {
            mapEl.style.display = 'none';
          }
        }
      });
    });

    // Chart mode radio (Adoption % / Volume)
    document.querySelectorAll('.chart-mode').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.chart-mode').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        chartMode = (btn as HTMLElement).dataset.chart as any;
        drawChart();
      });
    });

    // Line mode radio (All / UA / RU)
    document.querySelectorAll('.line-mode').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.line-mode').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        lineMode = (btn as HTMLElement).dataset.mode as any;
        drawChart();
      });
    });

    // Events toggle
    document.getElementById('events-toggle')?.addEventListener('click', (e) => {
      const btn = e.currentTarget as HTMLElement;
      btn.classList.toggle('active');
      showEvents = btn.classList.contains('active');
      drawChart();
    });

    // ── Category bar chart ──────────────────────────────
    function drawCategoryChart() {
      const container = document.getElementById('category-chart')!;
      container.innerHTML = '';

      const rect = container.getBoundingClientRect();
      const margin = { top: 10, right: 60, bottom: 20, left: 180 };
      const width = rect.width - margin.left - margin.right;
      const height = rect.height - margin.top - margin.bottom;

      const svg = d3.select('#category-chart')
        .append('svg')
        .attr('viewBox', `0 0 ${rect.width} ${rect.height}`)
        .append('g')
        .attr('transform', `translate(${margin.left},${margin.top})`);

      // Aggregate by category
      const catData = pairs.categories.map((cat: any) => {
        const catPairs = pairs.pairs.filter((p: any) => p.category === cat.id);
        const avg = catPairs.length ? catPairs.reduce((s: number, p: any) => s + p.adoption, 0) / catPairs.length : 0;
        return { name: cat.name, avg: Math.round(avg * 10) / 10, color: cat.color, count: catPairs.length };
      }).sort((a: any, b: any) => b.avg - a.avg);

      const y = d3.scaleBand()
        .domain(catData.map((d: any) => d.name))
        .range([0, height])
        .padding(0.3);

      const x = d3.scaleLinear().domain([0, 100]).range([0, width]);

      // Background bars
      svg.selectAll('.bg-bar')
        .data(catData)
        .enter().append('rect')
        .attr('x', 0).attr('width', width)
        .attr('y', (d: any) => y(d.name)!)
        .attr('height', y.bandwidth())
        .attr('fill', '#f3f4f6')
        .attr('rx', 3);

      // Value bars
      svg.selectAll('.val-bar')
        .data(catData)
        .enter().append('rect')
        .attr('x', 0)
        .attr('width', (d: any) => x(d.avg))
        .attr('y', (d: any) => y(d.name)!)
        .attr('height', y.bandwidth())
        .attr('fill', (d: any) => d.color)
        .attr('opacity', 0.8)
        .attr('rx', 3);

      // Labels
      svg.selectAll('.cat-label')
        .data(catData)
        .enter().append('text')
        .attr('x', -8)
        .attr('y', (d: any) => y(d.name)! + y.bandwidth() / 2 + 4)
        .attr('text-anchor', 'end')
        .attr('fill', '#374151')
        .attr('font-size', '12px')
        .attr('font-weight', '500')
        .text((d: any) => d.name);

      // Value labels
      svg.selectAll('.val-label')
        .data(catData)
        .enter().append('text')
        .attr('x', (d: any) => x(d.avg) + 8)
        .attr('y', (d: any) => y(d.name)! + y.bandwidth() / 2 + 4)
        .attr('fill', '#6b7280')
        .attr('font-size', '12px')
        .attr('font-weight', '600')
        .text((d: any) => d.avg + '%');
    }

    // ── Heatmap / pair overview ──────────────────────────
    function drawHeatmap() {
      const container = document.getElementById('heatmap-chart')!;
      container.innerHTML = '';

      const sorted = [...pairs.pairs].sort((a: any, b: any) => {
        if (a.category !== b.category) return a.category.localeCompare(b.category);
        return b.adoption - a.adoption;
      });

      const catColors: Record<string, string> = {};
      pairs.categories.forEach((c: any) => { catColors[c.id] = c.color; });

      const rowHeight = 28;
      const totalHeight = sorted.length * rowHeight;
      container.style.height = totalHeight + 'px';

      const rect = container.getBoundingClientRect();
      const margin = { top: 0, right: 55, bottom: 0, left: 180 };
      const barWidth = rect.width - margin.left - margin.right;

      const svg = d3.select('#heatmap-chart')
        .append('svg')
        .attr('viewBox', `0 0 ${rect.width} ${totalHeight}`)
        .append('g')
        .attr('transform', `translate(${margin.left},0)`);

      const x = d3.scaleLinear().domain([0, 100]).range([0, barWidth]);

      const colorScale = (pct: number) => {
        if (pct >= 80) return '#059669';
        if (pct >= 50) return '#d97706';
        if (pct >= 20) return '#ea580c';
        return '#dc2626';
      };

      sorted.forEach((pair: any, i: number) => {
        const yPos = i * rowHeight;

        // Category dot
        svg.append('circle')
          .attr('cx', -170).attr('cy', yPos + rowHeight / 2)
          .attr('r', 4)
          .attr('fill', catColors[pair.category] || '#999');

        // Label: Ukrainian name
        svg.append('text')
          .attr('x', -160).attr('y', yPos + rowHeight / 2 + 4)
          .attr('fill', '#374151')
          .attr('font-size', '11px')
          .attr('font-weight', '500')
          .text(pair.ukrainian);

        // Old name (strikethrough)
        svg.append('text')
          .attr('x', -160).attr('y', yPos + rowHeight / 2 + 4)
          .attr('fill', 'transparent')
          .attr('font-size', '0px')
          .text('');

        // Background bar
        svg.append('rect')
          .attr('x', 0).attr('width', barWidth)
          .attr('y', yPos + 4)
          .attr('height', rowHeight - 8)
          .attr('fill', '#f3f4f6')
          .attr('rx', 2);

        // Value bar
        svg.append('rect')
          .attr('x', 0)
          .attr('width', x(pair.adoption))
          .attr('y', yPos + 4)
          .attr('height', rowHeight - 8)
          .attr('fill', colorScale(pair.adoption))
          .attr('opacity', 0.75)
          .attr('rx', 2);

        // Percentage
        svg.append('text')
          .attr('x', barWidth + 8)
          .attr('y', yPos + rowHeight / 2 + 4)
          .attr('fill', colorScale(pair.adoption))
          .attr('font-size', '11px')
          .attr('font-weight', '700')
          .attr('font-family', 'var(--font-mono)')
          .text(pair.adoption + '%');

        // Divider
        if (i > 0 && sorted[i - 1].category !== pair.category) {
          svg.append('line')
            .attr('x1', -175).attr('x2', barWidth + 50)
            .attr('y1', yPos).attr('y2', yPos)
            .attr('stroke', '#e5e7eb')
            .attr('stroke-width', 1);
        }
      });
    }

