---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import LandingStats from '../components/LandingStats.astro';
import PairView from '../components/PairView.astro';
import AboutSection from '../components/AboutSection.astro';
import m from '../data/manifest.json';
import religious from '../data/religious.json';
import religiousProp from '../data/religious_propagation.json';
import llmTraj from '../data/llm_trajectory.json';
import llmPerPair from '../data/llm_per_pair.json';
import toolsPerPair from '../data/tools_per_pair.json';

// manifest.json is the single source of truth — all stats, pairs, categories
const grouped = m.categories.map(cat => ({
  ...cat,
  pairs: m.pairs.filter(p => p.category === cat.id).sort((a, b) => {
    if (a.id === 1) return -1;
    if (b.id === 1) return 1;
    return b.total - a.total;
  })
})).filter(g => g.pairs.length > 0);

function fmtBig(n: string | number) {
  const v = typeof n === 'string' ? parseInt(n) : n;
  if (v >= 1_000_000_000) return (v / 1_000_000_000).toFixed(1) + 'B';
  if (v >= 1_000_000) return (v / 1_000_000).toFixed(1) + 'M';
  if (v >= 1_000) return (v / 1_000).toFixed(1) + 'K';
  return v.toString();
}

function adoptionClass(pct: number) {
  if (pct >= 70) return 'adoption-high';
  if (pct >= 30) return 'adoption-mid';
  return 'adoption-low';
}

const src = (name: string) => (m.sources as any)[name];

function formatNum(n: number) {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(0) + 'K';
  return n.toString();
}
---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>#KyivNotKiev: A Large-Scale Computational Study of Ukrainian Toponym Adoption</title>
  <meta name="description" content={`Scanning ${m.records_scanned} records, analyzing ${fmtBig(m.toponym_matches)}+ toponym matches across ${m.num_sources} sources. The largest computational study of Ukrainian spelling adoption.`}>

  <!-- Open Graph -->
  <meta property="og:title" content="#KyivNotKiev: A Large-Scale Computational Study of Ukrainian Toponym Adoption">
  <meta property="og:description" content={`${m.records_scanned} records scanned, ${fmtBig(m.toponym_matches)}+ toponym matches, ${fmtBig(m.cl_corpus)} ML-analyzed texts. The largest computational study of Ukrainian spelling adoption.`}>
  <meta property="og:image" content="https://kyivnotkiev.org/og.png">
  <meta property="og:url" content="https://kyivnotkiev.org">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="en_US">
  <meta property="og:locale:alternate" content="uk_UA">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="#KyivNotKiev: A Large-Scale Computational Study of Ukrainian Toponym Adoption">
  <meta name="twitter:description" content={`${m.records_scanned} scanned, ${fmtBig(m.toponym_matches)}+ matches, ${fmtBig(m.cl_corpus)} ML texts. Largest Ukrainian spelling adoption study.`}>
  <meta name="twitter:image" content="https://kyivnotkiev.org/og.png">

  <!-- Favicon -->
  <link rel="icon" href="/logo.svg" type="image/svg+xml">
  <link rel="alternate" hreflang="uk" href="https://kyivnotkiev.org/uk/">
  <link rel="alternate" hreflang="en" href="https://kyivnotkiev.org/">
  <link rel="canonical" href="https://kyivnotkiev.org/">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="app">
    <nav class="topbar">
      <a href="/" class="topbar-logo" style="text-decoration:none;">
        <img src="/logo.svg" alt="Kyiv chestnut" style="height:28px; width:auto; margin-right:0.4rem;">
        <span style="font-size:0.9rem; font-weight:800; color:#0057B8;">#KyivNotKiev</span>
      </a>
      <div class="topbar-links">
        <a href="/report" id="topbar-report-link">Full Report</a>
        <a href="/uk/">UA</a>
        <a href="https://github.com/IvanDobrovolsky/kyivnotkiev" target="_blank">GitHub</a>
        <a href="/" id="about-link">About</a>
        <button class="hamburger" id="hamburger-btn" aria-label="Open pair menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </nav>

    <Sidebar grouped={grouped} />

    <main class="main" style="opacity:0; transition:opacity 0.15s;">
      <!-- ══ LANDING VIEW (visible when no pair selected) ══ -->
      <div id="landing-view" style="display:none;">
        <LandingStats manifest={m} fmtBig={fmtBig} />
      </div><!-- end landing-view -->

      <PairView llmTraj={llmTraj} llmPerPair={llmPerPair} toolsPerPair={toolsPerPair} religious={religious} timeSpan={m.time_span} />

      <!-- ══ GLOBAL VIEWS (visible on landing, hidden on pair view) ══ -->
      <div id="global-view">

      <!-- Top 6 Deep Dive -->
      <div class="chart-container" style="margin-bottom: 0.75rem;">
        <div class="chart-title" style="color: var(--text)">Key Pairs: Deep Dive</div>
        <div class="chart-subtitle" style="margin-bottom: 0.75rem;">6 pairs representing the full spectrum — from campaign success to historical resistance</div>
        <div id="top6-grid" class="resp-grid-3" style="display:grid; grid-template-columns:repeat(3, 1fr); gap:0.75rem;"></div>
      </div>

      <!-- Statistical Analysis + Confusion Matrix side by side -->
      <div class="resp-grid-2" style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; margin-bottom:0.75rem;">
        <div class="chart-container" style="margin-bottom:0; padding:0.75rem 1rem; display:flex; flex-direction:column; justify-content:space-between;">
          <div class="chart-title" style="color: var(--text); margin-bottom:0.4rem;">Statistical Analysis</div>
          <div id="stat-analysis-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.4rem;"></div>
          <div id="stat-analysis-findings" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.35rem; margin-top: 0.4rem;"></div>
        </div>
        <div class="chart-container" style="margin-bottom:0;">
          <div class="chart-title" style="color: var(--text)">Confusion Matrix</div>
          <div class="chart-subtitle" id="cm-subtitle" style="margin-bottom: 0.5rem;"></div>
          <div id="cl-confusion-matrix" style="display:flex;justify-content:center;"></div>
        </div>
      </div>

      <!-- Context Distribution + Benchmark side by side -->
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; margin-bottom:0.75rem;">
        <div class="chart-container" id="cl-context-chart" style="margin-bottom:0;">
          <div class="chart-title" style="color: var(--text)">Context Distribution</div>
          <div class="chart-subtitle" style="margin-bottom: 0.5rem;">Russian vs Ukrainian form usage across discourse domains</div>
          <div id="cl-context-bars"></div>
        </div>
        <div class="chart-container" id="cl-benchmark" style="margin-bottom:0;">
          <div class="chart-title" style="color: var(--text)">Encoder Benchmark</div>
          <div class="chart-subtitle" id="benchmark-subtitle" style="margin-bottom: 0.5rem;"></div>
          <div id="cl-benchmark-table"></div>
        </div>
      </div>

      <!-- Adoption by Category -->
      <div class="chart-container" style="margin-bottom: 0.75rem;">
        <div class="chart-title" style="color: var(--text)">Adoption by Category</div>
        <div class="chart-subtitle" style="margin-bottom: 0.5rem;">Mean adoption (%) per category — equal weight per source</div>
        <div id="category-chart" style="width:100%; height:260px;"></div>
      </div>

      <!-- All Pairs Overview -->
      <div class="chart-container" style="margin-bottom: 0.75rem;">
        <div class="chart-title" style="color: var(--text)">All Pairs Overview</div>
        <div class="chart-subtitle">Current adoption rate — mean across sources, last 12 months</div>
        <div id="heatmap-chart" style="width:100%; min-height:400px;"></div>
      </div>

      <!-- ══ AI Search: what LLMs tell you about Ukraine ══ -->
      <div class="chart-container" style="margin-bottom: 0.75rem;">
        <div class="chart-title" style="color: var(--text)">What AI Tells You About Ukraine</div>
        <div class="chart-subtitle" style="margin-bottom: 0.75rem;">
          Search is being replaced by chat. Google AI Overviews answer queries directly,
          ChatGPT and Claude have become how millions of people first learn about a place.
          We asked <strong>{(llmTraj as any).summary.n_models} frontier models</strong> from
          {Object.keys((llmTraj as any).families).length} labs to spell Ukrainian places —
          three different ways each — to see how the answer changes between recognition and
          free recall.
        </div>

        {/* Methodology blurb */}
        <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:0.5rem; margin-bottom:1rem; font-size:0.65rem;">
          <div style="padding:0.5rem 0.6rem; background:rgba(0,87,184,0.05); border-left:2px solid #0057B8; border-radius:3px;">
            <div style="font-weight:700; color:var(--text); margin-bottom:0.2rem;">Test 1 · Forced choice (RU first)</div>
            <div style="color:var(--text-muted); font-family:monospace;">"Kiev or Kyiv? Answer with one word."</div>
          </div>
          <div style="padding:0.5rem 0.6rem; background:rgba(0,87,184,0.05); border-left:2px solid #0057B8; border-radius:3px;">
            <div style="font-weight:700; color:var(--text); margin-bottom:0.2rem;">Test 2 · Forced choice (UA first)</div>
            <div style="color:var(--text-muted); font-family:monospace;">"Kyiv or Kiev? Answer with one word."</div>
          </div>
          <div style="padding:0.5rem 0.6rem; background:rgba(213,43,30,0.05); border-left:2px solid #D52B1E; border-radius:3px;">
            <div style="font-weight:700; color:var(--text); margin-bottom:0.2rem;">Test 3 · Free recall</div>
            <div style="color:var(--text-muted); font-family:monospace;">"What is the capital of Ukraine? One word."</div>
          </div>
        </div>

        {/* Heatmap: rows = lab/family, columns = quarter (release date),
            cell color intensity = average TAS for that family in that quarter.
            Cell numbers show actual TAS for direct readability. */}
        {(() => {
          const traj = llmTraj;
          const models = traj.models.filter(m => m.release_date && m.tas != null);
          const families = traj.families;

          const MONTH_NAMES = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
          const dateToMonths = (d) => {
            const [yr, mo] = d.split('-').map(Number);
            return yr * 12 + (mo - 1);
          };
          // Bucket models by quarter for cleaner columns
          const monToQuarter = (m) => {
            const yr = Math.floor(m / 12);
            const mo = m % 12;
            const q = Math.floor(mo / 3);
            return yr * 4 + q;
          };
          const qLabel = (q) => {
            const yr = Math.floor(q / 4);
            const qi = q % 4;
            return `Q${qi + 1} ${String(yr).slice(-2)}`;
          };

          // family list ordered by total TAS desc
          const famList = Object.keys(families).sort((a, b) => {
            const ta = models.filter(m => m.family === a).map(m => m.tas);
            const tb = models.filter(m => m.family === b).map(m => m.tas);
            const ma = ta.length ? ta.reduce((x, y) => x + y, 0) / ta.length : 0;
            const mb = tb.length ? tb.reduce((x, y) => x + y, 0) / tb.length : 0;
            return mb - ma;
          });

          // Quarter range
          const qs = models.map(m => monToQuarter(dateToMonths(m.release_date)));
          const qMin = Math.min(...qs);
          const qMax = Math.max(...qs);
          const quarters = Array.from({length: qMax - qMin + 1}, (_, i) => qMin + i);

          // Build cells: cells[fam][q] = {tas, n, models}
          const cells = {};
          for (const fam of famList) {
            cells[fam] = {};
            for (const q of quarters) {
              cells[fam][q] = {tasSum: 0, openSum: 0, forcedSum: 0, n: 0, models: []};
            }
          }
          for (const m of models) {
            const q = monToQuarter(dateToMonths(m.release_date));
            const c = cells[m.family]?.[q];
            if (!c) continue;
            c.tasSum += m.tas;
            c.openSum += m.open || 0;
            c.forcedSum += m.forced || 0;
            c.n += 1;
            c.models.push(m);
          }

          // TAS color scale: lower → red, higher → blue
          const tasColor = (v) => {
            if (v == null || isNaN(v)) return '#f8f9fb';
            const t = Math.max(0, Math.min(1, (v - 40) / 60));
            if (t < 0.5) {
              const u = t * 2;
              const r = 220 - Math.round(u * 60);
              const g = 60 + Math.round(u * 180);
              const b = 60 + Math.round(u * 180);
              return `rgb(${r}, ${g}, ${b})`;
            } else {
              const u = (t - 0.5) * 2;
              const r = 160 - Math.round(u * 130);
              const g = 240 - Math.round(u * 100);
              const b = 240 - Math.round(u * 56);
              return `rgb(${r}, ${g}, ${b})`;
            }
          };

          // Pure HTML/CSS grid heatmap so text uses real rem units and never
          // scales with viewBox. Always 100% container width.
          const gridCols = `minmax(140px, 180px) repeat(${quarters.length}, minmax(0, 1fr))`;

          return (
            <div style="width:100%; margin-bottom:0.75rem;">
              <div style={`display:grid; grid-template-columns:${gridCols}; gap:3px; align-items:stretch;`}>
                {/* Header row */}
                <div></div>
                {quarters.map((q) => (
                  <div style="text-align:center; font-size:0.65rem; font-weight:600; color:var(--text-muted); padding:0.2rem 0;">
                    {qLabel(q)}
                  </div>
                ))}

                {/* Family rows */}
                {famList.map((fam) => {
                  const fcolor = families[fam]?.color || '#888';
                  const nFam = (families[fam] || {}).n_models || 0;
                  return [
                    <div style="display:flex; align-items:center; gap:0.4rem; padding:0.2rem 0.3rem; min-width:0;">
                      <span style={`flex:0 0 4px; height:14px; border-radius:2px; background:${fcolor};`}></span>
                      <span style="font-size:0.72rem; font-weight:600; color:var(--text); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{fam}</span>
                      <span style="font-size:0.62rem; color:var(--text-muted); margin-left:auto; font-family:monospace;">×{nFam}</span>
                    </div>,
                    ...quarters.map((q) => {
                      const cell = cells[fam][q];
                      if (!cell || cell.n === 0) {
                        return (
                          <div style="background:#f9fafb; border:1px solid #e5e7eb; border-radius:3px; min-height:24px;"></div>
                        );
                      }
                      const tas = cell.tasSum / cell.n;
                      const open = cell.openSum / cell.n;
                      const forced = cell.forcedSum / cell.n;
                      const fill = tasColor(tas);
                      const textColor = tas < 60 || tas > 90 ? 'white' : '#111827';
                      const tip = `${fam} · ${qLabel(q)}\n${cell.n} model${cell.n === 1 ? '' : 's'}\nTAS avg: ${tas.toFixed(1)}%\nFree recall avg: ${open.toFixed(1)}%\nForced choice avg: ${forced.toFixed(1)}%\nModels: ${cell.models.map(m => m.key).join(', ')}`;
                      return (
                        <div title={tip} style={`background:${fill}; border:1px solid #d1d5db; border-radius:3px; min-height:24px; display:flex; align-items:center; justify-content:center; font-size:0.7rem; font-weight:600; color:${textColor};`}>
                          {tas.toFixed(0)}
                        </div>
                      );
                    }),
                  ];
                })}
              </div>

              {/* Color scale legend */}
              <div style="display:flex; align-items:center; gap:0.5rem; margin-top:0.6rem; padding:0.2rem 0.3rem; flex-wrap:wrap;">
                <span style="font-size:0.65rem; font-weight:600; color:var(--text-muted);">TAS legend (% Kyiv)</span>
                {[40, 50, 60, 70, 80, 90, 100].map((v) => (
                  <div style="display:flex; flex-direction:column; align-items:center; gap:0.1rem;">
                    <div style={`width:28px; height:12px; background:${tasColor(v)}; border:1px solid #d1d5db; border-radius:2px;`}></div>
                    <span style="font-size:0.6rem; color:var(--text-muted);">{v}</span>
                  </div>
                ))}
              </div>

              <div style="font-size:0.65rem; color:var(--text-muted); padding:0.5rem 0.3rem 0; line-height:1.6;">
                <strong>How to read.</strong> Rows are model families, columns are calendar quarters. Each cell shows the
                <em> average TAS</em> across all models that family released that quarter (color and number).
                Empty cells = no models released. Hover any cell for the list of models, average free recall
                and forced choice. Read left to right within a row to see whether that lab's models are getting
                more Ukrainian-leaning over time. <strong>Meta Llama is the only family whose row visibly
                lightens (gets more pro-Kyiv) from left to right.</strong>
              </div>
            </div>
          );
        })()}

        {/* Family legend + summary stats */}
        <div style="display:grid; grid-template-columns:auto 1fr; gap:0.75rem; align-items:start;">
          <div style="display:flex; flex-direction:column; gap:0.3rem; min-width:140px;">
            {Object.entries((llmTraj as any).families).sort((a, b) => (b[1] as any).n_models - (a[1] as any).n_models).map(([fam, info]) => (
              <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.7rem;">
                <span style={`display:inline-block; width:12px; height:12px; border-radius:2px; background:${(info as any).color};`}></span>
                <span style="color:var(--text);">{fam}</span>
                <span style="color:var(--text-muted); font-family:monospace;">({(info as any).n_models})</span>
              </div>
            ))}
          </div>
          <div style="font-size:0.7rem; color:var(--text); line-height:1.6; padding-left:1rem; border-left:2px solid rgba(0,87,184,0.15);">
            <strong>The story.</strong> Every single model has a gap between forced-choice (recognition) and free
            recall (generation) — the filled dot is always above the hollow dot. Forced-choice runs from
            <strong> {(llmTraj as any).summary.forced_min}% to {(llmTraj as any).summary.forced_max}% Kyiv</strong>;
            free recall is much lower at <strong>{(llmTraj as any).summary.open_min}% to {(llmTraj as any).summary.open_max}%</strong>.
            That gap is the size of the alignment correction layer — models trained to <em>pick</em> Kyiv when shown both,
            but still <em>generate</em> Kiev a third of the time. Largest gaps come from heavily-aligned reasoning models
            (Claude Opus, gpt-5-nano, o1, o3) — exactly the models that have had the most post-training. xAI Grok and
            small Haiku variants have the smallest gaps because they're closer to base-model behavior.
          </div>
        </div>

        {/* Top + bottom 5 table */}
        <div style="margin-top:1rem; display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
          <div>
            <div style="font-size:0.7rem; font-weight:700; color:var(--text); margin-bottom:0.4rem;">
              Most Ukrainian-leaning (highest TAS)
            </div>
            <div style="font-size:0.65rem; font-family:monospace; color:var(--text);">
              {(llmTraj as any).models.slice().sort((a, b) => (b.tas || 0) - (a.tas || 0)).slice(0, 5).map(m => (
                <div style="display:grid; grid-template-columns:1fr auto auto; gap:0.5rem; padding:0.2rem 0; border-bottom:1px solid rgba(0,0,0,0.04);">
                  <span style={`color:${(llmTraj as any).families[m.family]?.color || '#666'}; font-weight:600;`}>{m.key}</span>
                  <span style="color:var(--text-muted);">{m.tas}%</span>
                  <span style="color:var(--text-muted);">gap {m.gap}pp</span>
                </div>
              ))}
            </div>
          </div>
          <div>
            <div style="font-size:0.7rem; font-weight:700; color:var(--text); margin-bottom:0.4rem;">
              Most Russian-leaning (lowest TAS)
            </div>
            <div style="font-size:0.65rem; font-family:monospace; color:var(--text);">
              {(llmTraj as any).models.slice().sort((a, b) => (a.tas || 0) - (b.tas || 0)).slice(0, 5).map(m => (
                <div style="display:grid; grid-template-columns:1fr auto auto; gap:0.5rem; padding:0.2rem 0; border-bottom:1px solid rgba(0,0,0,0.04);">
                  <span style={`color:${(llmTraj as any).families[m.family]?.color || '#666'}; font-weight:600;`}>{m.key}</span>
                  <span style="color:var(--text-muted);">{m.tas}%</span>
                  <span style="color:var(--text-muted);">gap {m.gap}pp</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div style="margin-top:0.75rem; padding:0.5rem 0.75rem; background:rgba(0,87,184,0.04); border-radius:4px; font-size:0.65rem; color:var(--text-muted);">
          <strong style="color:var(--text);">Toponymic Alignment Score (TAS) = 0.4 × (forced₁ + forced₂)/2 + 0.6 × open</strong> —
          weights favor free recall because it measures parametric memory rather than instruction-following.
          {(llmTraj as any).summary.n_models} hosted-API models tested, {(llmTraj as any).summary.release_min}–{(llmTraj as any).summary.release_max}.
          Open-weight Llama, Gemma, Qwen, Mistral version archaeology pending tomorrow's GPU run.
        </div>
      </div>

      <!-- Religious Institutions: policy not population -->
      <div class="chart-container" style="margin-bottom: 0.75rem;">
        <div class="chart-title" style="color: var(--text)">Institutional Voices: Policy, Not Population</div>
        <div class="chart-subtitle" style="margin-bottom: 0.75rem;">
          The 8 corpus sources above measure populations of writers — millions of independent
          choices that drift with culture. Major religious bodies are different: each one has a
          single editorial policy decided by a small group at the top. When their English
          publications shift from "Kiev" to "Kyiv", it's a discrete political decision tied to
          a specific event. The contrasts are the story.
        </div>

        {/* Hero: switch-date timeline */}
        <div style="margin: 1rem 0 1.25rem 0;">
          {(() => {
            const denoms = (religious as any).denominations.filter((d: any) => d.totals.ru + d.totals.ua > 0);
            const minYear = 2010;
            const maxYear = 2026;
            const yearWidth = 100 / (maxYear - minYear);
            return (
              <div>
                <div style="display:flex; justify-content:space-between; font-size:0.65rem; color:var(--text-muted); margin-bottom:0.4rem; padding:0 4px;">
                  <span>{minYear}</span>
                  <span>2014 Maidan</span>
                  <span>2019 OCU</span>
                  <span>2022 invasion</span>
                  <span>{maxYear}</span>
                </div>
                {denoms.map((d: any) => {
                  const switchPct = d.switch_year ? ((d.switch_year - minYear) / (maxYear - minYear)) * 100 : null;
                  const labelText = d.switch_year
                    ? `switched ${d.switch_year} — ${d.stance_event}`
                    : `${d.ua_pct ?? 0}% Kyiv lifetime`;
                  return (
                    <div style="display:grid; grid-template-columns:160px 1fr 200px; gap:0.5rem; align-items:center; margin-bottom:0.5rem;">
                      <div style="font-size:0.75rem; font-weight:600; color:var(--text); text-align:right;">
                        {d.short}
                      </div>
                      <div style="position:relative; height:24px; background:linear-gradient(90deg,#fde6e6 0%,#fde6e6 100%); border-radius:4px; overflow:hidden;">
                        {switchPct !== null && (
                          <div style={`position:absolute; left:${switchPct}%; top:0; width:${100 - switchPct}%; height:100%; background:linear-gradient(90deg,#dceaff,#0057B8);`}></div>
                        )}
                        {[2014, 2019, 2022].map(yr => (
                          <div style={`position:absolute; left:${((yr - minYear) / (maxYear - minYear)) * 100}%; top:0; bottom:0; width:1px; background:rgba(0,0,0,0.15);`}></div>
                        ))}
                        {switchPct !== null && (
                          <div style={`position:absolute; left:${switchPct}%; top:-2px; bottom:-2px; width:2px; background:#0057B8;`}></div>
                        )}
                      </div>
                      <div style="font-size:0.7rem; color:var(--text-muted);">
                        {labelText}
                      </div>
                    </div>
                  );
                })}
                <div style="margin-top:0.5rem; padding:0.5rem 0.75rem; background:rgba(213,43,30,0.05); border-left:3px solid #D52B1E; font-size:0.7rem; color:var(--text-muted);">
                  <strong style="color:var(--text);">Reading the chart:</strong> red = institution still uses "Kiev" in
                  English publications; blue = switched to "Kyiv". Vertical markers show 2014 (Maidan), 2019
                  (Constantinople grants Ukrainian autocephaly), 2022 (Russian invasion).
                </div>
              </div>
            );
          })()}
        </div>

        {/* Stacked bars: volume + ratio */}
        <div style="margin-top:1.25rem;">
          <div style="font-size:0.8rem; font-weight:600; color:var(--text); margin-bottom:0.5rem;">
            Volume and ratio across all toponym pairs
          </div>
          {(religious as any).denominations.filter((d: any) => d.totals.ru + d.totals.ua > 0).map((d: any) => {
            const total = d.totals.ru + d.totals.ua;
            const uaPct = (d.totals.ua / total) * 100;
            return (
              <div style="display:grid; grid-template-columns:160px 1fr 100px; gap:0.5rem; align-items:center; margin-bottom:0.4rem;">
                <div style="font-size:0.7rem; color:var(--text); text-align:right;">{d.short}</div>
                <div style="display:flex; height:18px; border-radius:3px; overflow:hidden; background:#f0f0f0;">
                  <div style={`width:${uaPct}%; background:#0057B8;`} title={`${d.totals.ua} Ukrainian`}></div>
                  <div style={`width:${100 - uaPct}%; background:#D52B1E;`} title={`${d.totals.ru} Russian`}></div>
                </div>
                <div style="font-size:0.65rem; color:var(--text-muted); font-family:monospace;">
                  {d.totals.ua}/{total} ({d.ua_pct}%)
                </div>
              </div>
            );
          })}
        </div>

        {/* Propagation graph: how a single Moscow editorial decision reaches half a billion non-English speakers */}
        <div style="margin-top:1.5rem; padding:1rem 0.5rem; background:linear-gradient(180deg, rgba(213,43,30,0.02), rgba(0,87,184,0.02)); border-radius:6px;">
          <div style="font-size:0.85rem; font-weight:700; color:var(--text); margin-bottom:0.25rem;">
            {(religiousProp as any).title}
          </div>
          <div style="font-size:0.7rem; color:var(--text-muted); margin-bottom:1rem; line-height:1.5;">
            {(religiousProp as any).subtitle}
          </div>

          {/* Pure HTML/CSS vertical flow — text uses real rem units. */}
          <div style="width:100%; display:flex; flex-direction:column; align-items:stretch; gap:0.85rem;">
            {/* Source row */}
            <div style="display:flex; justify-content:center;">
              <div style={`max-width:340px; width:100%; background:${(religiousProp as any).source.color}; border-radius:6px; padding:0.5rem 0.65rem; color:white;`}>
                <div style="font-size:0.72rem; font-weight:700; line-height:1.25;">Moscow Patriarchate</div>
                <div style="font-size:0.62rem; opacity:0.88; margin-top:0.2rem; line-height:1.3;">mospat.ru · 6,000+ EN articles</div>
                <div style="font-size:0.6rem; opacity:0.7; margin-top:0.15rem;">since 2015</div>
              </div>
            </div>

            {/* Vertical connector */}
            <div style="display:flex; justify-content:center;">
              <div style="width:1px; height:14px; background:rgba(0,0,0,0.15);"></div>
            </div>

            {/* Tier rows */}
            {(religiousProp as any).tiers.map((tier: any) => {
              const tierColors = {
                direct: "#D52B1E",
                state: "#FF6B35",
                republication: "#B45309",
                audience: "#0057B8",
              };
              const fill = tierColors[tier.id] || "#888";
              return (
                <div style="display:flex; flex-direction:column; gap:0.4rem;">
                  <div style={`font-size:0.7rem; font-weight:700; color:${fill}; text-align:center;`}>
                    {tier.title}
                  </div>
                  <div style={`display:grid; grid-template-columns:repeat(${tier.nodes.length}, minmax(0, 1fr)); gap:0.5rem;`}>
                    {tier.nodes.map((n: any) => (
                      <div style={`background:${fill}; border-radius:6px; padding:0.5rem 0.65rem; color:white; min-width:0;`}>
                        <div style="font-size:0.72rem; font-weight:700; line-height:1.25; overflow:hidden; text-overflow:ellipsis;">{n.label}</div>
                        <div style="font-size:0.62rem; opacity:0.88; margin-top:0.2rem; line-height:1.3;">{n.metric}</div>
                        <div style="font-size:0.6rem; opacity:0.7; margin-top:0.15rem;">{n.since}</div>
                      </div>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>

          <div style="margin-top:0.75rem; padding:0.75rem 1rem; background:rgba(213,43,30,0.06); border-left:3px solid #D52B1E; font-size:0.7rem; color:var(--text); line-height:1.6;">
            <strong>Key finding.</strong> {(religiousProp as any).key_finding}
          </div>

          <div style="margin-top:0.4rem; font-size:0.55rem; color:var(--text-muted); line-height:1.5;">
            Sources: {(religiousProp as any).sources.map((s: any, i: number) => (
              <span>
                {i > 0 && " · "}
                <a href={s.url} target="_blank" rel="noopener" style="color:inherit; text-decoration:underline;">{s.short || s.label}</a>
              </span>
            ))}
          </div>
        </div>

        {/* Per-denomination key findings */}
        <div style="margin-top:1.25rem; display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
          {(religious as any).denominations.filter((d: any) => d.totals.ru + d.totals.ua > 0).map((d: any) => (
            <div style="padding:0.6rem 0.75rem; background:rgba(0,87,184,0.03); border:1px solid rgba(0,87,184,0.1); border-radius:4px;">
              <div style="font-size:0.75rem; font-weight:600; color:var(--text);">
                <a href={d.url} target="_blank" rel="noopener" style="color:inherit; text-decoration:none;">
                  {d.name} ↗
                </a>
              </div>
              <div style="font-size:0.65rem; color:var(--text-muted); margin-top:0.3rem; line-height:1.5;">
                {d.stance}
              </div>
              {d.pairs.length > 0 && (
                <div style="font-size:0.6rem; color:var(--text-muted); margin-top:0.4rem; font-family:monospace;">
                  Top pairs: {d.pairs.slice(0, 3).map((p: any) => `${p.ru_term}/${p.ua_term} (${p.ua_pct}%)`).join(' · ')}
                </div>
              )}
            </div>
          ))}
        </div>

        <div style="margin-top:0.75rem; font-size:0.65rem; color:var(--text-muted);">
          Sources: ec-patr.org (Constantinople, {religious.denominations.find((d: any) => d.id === 'constantinople')?.totals.ru + religious.denominations.find((d: any) => d.id === 'constantinople')?.totals.ua || 0} mentions),
          vatican.va (Vatican, {religious.denominations.find((d: any) => d.id === 'vatican')?.totals.ru + religious.denominations.find((d: any) => d.id === 'vatican')?.totals.ua || 0} mentions).
          Moscow Patriarchate (mospat.ru) and World Council of Churches (oikoumene.org) crawls in progress.
        </div>
      </div>

      <!-- Methodology moved to top, below stats -->

      <AboutSection manifest={m} formatNum={formatNum} />

      </div><!-- end global-view -->
    </main>
  </div>

  <script>
    import * as d3 from 'd3';
    import * as topojson from 'topojson-client';
    import timeseriesData from '../data/timeseries.json';
    import manifest from '../data/manifest.json';
    import holdoutsData from '../data/holdouts.json';
    import holdoutsByPair from '../data/holdouts_by_pair.json';
    import countriesByPair from '../data/countries_by_pair.json';
    import pairEvents from '../data/pair_events.json';
    import trendsCountries from '../data/trends_countries.json';
    import errorAnalysis from '../data/error_analysis.json';
    import dictCombined from '../data/dictionary_combined.json';
    import enforcementData from '../data/enforcement.json';
    import domainOrigins from '../data/domain_origins.json';
    import clCollocations from '../data/cl_collocations.json';
    import clAnalysis from '../data/cl_analysis.json';
    import confusionMatrix from '../data/confusion_matrix.json';
    import analysisData from '../data/analysis.json';
    import regexPrecision from '../data/regex_precision.json';

    // Use manifest as the single pairs source
    const pairs = { categories: manifest.categories, pairs: manifest.pairs };

    // Declared early to avoid TDZ in drawWorldMap
    let cachedWorld: any = null;

    const sourceColors: Record<string, string> = {
      trends: '#4285F4',
      gdelt: '#1e3a5f',
      wikipedia: '#636466',
      reddit: '#FF4500',
      youtube: '#FF0000',
      ngrams: '#7c3aed',
      openalex: '#06b6d4',
    };

    const sourceLabels: Record<string, string> = {
      trends: 'Google Trends',
      gdelt: 'GDELT News',
      wikipedia: 'Wikipedia',
      reddit: 'Reddit',
      youtube: 'YouTube',
      ngrams: 'Google Books',
      openalex: 'Academic Papers',
    };

    let activeSource = 'gdelt';  // GDELT first — news coverage is most precise
    let activeSources = new Set(['gdelt']);
    // hideRuDomains replaced by holdoutFilter
    let lineMode: 'both' | 'ukrainian' | 'russian' = 'both';
    let chartMode: 'adoption' | 'volume' = 'volume';  // Volume by default — shows actual data density
    let showEvents = true;

    // Read pair from URL query param (?pair=1), default to Kyiv (1)
    function getPairFromUrl(): number {
      const params = new URLSearchParams(window.location.search);
      const p = params.get('pair');
      if (p) {
        const id = parseInt(p);
        if (!isNaN(id) && (pairs as any).pairs.some((pp: any) => pp.id === id)) return id;
      }
      return 0; // 0 = landing/overview, no pair selected
    }

    function updateUrl(pairId: number) {
      const url = new URL(window.location.href);
      if (pairId === 0) {
        url.searchParams.delete('pair');
      } else {
        url.searchParams.set('pair', String(pairId));
      }
      window.history.replaceState({}, '', url.toString());
    }

    function showView(mode: 'landing' | 'pair') {
      const landing = document.getElementById('landing-view');
      const global = document.getElementById('global-view');
      const pair = document.getElementById('pair-view');
      const main = document.querySelector('.main') as HTMLElement;
      if (landing) landing.style.display = mode === 'landing' ? 'block' : 'none';
      if (global) global.style.display = mode === 'landing' ? 'block' : 'none';
      if (pair) pair.style.display = mode === 'pair' ? 'block' : 'none';
      // Fade in on first render
      if (main) main.style.opacity = '1';
    }

    function renderTop6Cards() {
      const starredPairs = (pairs as any).pairs.filter((p: any) => p.starred);
      const grid = document.getElementById('top6-grid');
      if (!grid) return;
      grid.innerHTML = '';
      starredPairs.forEach((p: any) => {
        const id = p.id;
        const desc = p.starred_label || '';
        const pct = p.adoption;
        const color = pct >= 55 ? '#059669' : pct >= 25 ? '#d97706' : '#dc2626';
        const coll = (clCollocations as any)?.[String(id)];
        const card = document.createElement('div');
        card.className = 'top6-card';
        card.dataset.pairId = String(id);
        card.style.cssText = 'cursor:pointer; padding:0.75rem; border:1px solid var(--border); border-radius:8px; transition:all 0.15s;';

        // Header + adoption
        let html = `
          <div style="display:flex; justify-content:space-between; align-items:baseline; gap:0.5rem;">
            <div style="font-weight:600; color:var(--text); min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${p.russian} → ${p.ukrainian}</div>
            <div style="font-size:0.8rem; font-weight:700; color:${color}; flex-shrink:0;">${pct}%</div>
          </div>
          <div style="font-size:0.65rem; color:var(--text-muted); margin-top:0.15rem;">${desc}</div>
          <div style="height:3px; background:#f0f0f0; border-radius:2px; margin-top:0.3rem; margin-bottom:0.4rem;"><div style="height:100%; width:${pct}%; background:${color}; border-radius:2px;"></div></div>`;

        // Collocations inline
        if (coll) {
          for (const [variant, vcolor, label] of [['russian', '#dc2626', 'RU'], ['ukrainian', '#2563eb', 'UA']]) {
            const words = coll[variant]?.collocates?.slice(0, 5) || [];
            if (!words.length) continue;
            const maxC = Math.max(...words.map((w: any) => w.count));
            html += `<div style="margin-bottom:0.2rem;"><span style="font-size:0.55rem;color:${vcolor};font-weight:700;text-transform:uppercase;letter-spacing:0.04em;margin-right:0.25rem;">${label}</span>`;
            words.forEach((w: any, i: number) => {
              const sz = 0.68 + (w.count / maxC) * 0.3;
              const fw = i < 2 ? 700 : 400;
              html += `<span style="font-size:${sz}rem;color:${vcolor};font-weight:${fw};margin-right:0.25rem;">${w.word}</span>`;
            });
            html += `</div>`;
          }
        }

        card.innerHTML = html;
        card.addEventListener('click', () => {
          selectPair(id);
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        card.addEventListener('mouseenter', () => { card.style.borderColor = '#0057B8'; card.style.boxShadow = '0 2px 8px rgba(0,87,184,0.1)'; });
        card.addEventListener('mouseleave', () => { card.style.borderColor = '#e5e7eb'; card.style.boxShadow = 'none'; });
        grid.appendChild(card);
      });
    }

    function showLanding() {
      activePairId = 0;
      updateUrl(0);
      showView('landing');
      document.querySelectorAll('.sidebar-item').forEach(i => i.classList.remove('active'));
      renderTop6Cards();
      drawCategoryChart();
      drawHeatmap();
      drawErrorAnalysis();
      requestAnimationFrame(() => {
        drawClContextChart();
        drawClBenchmark();
      });
    }

    let activePairId = getPairFromUrl();

    function drawChart() {
      const container = document.getElementById('chart')!;
      const legendContainer = document.getElementById('chart-legend')!;

      // Fade out, redraw, fade in
      container.style.opacity = '0';
      container.style.transition = 'opacity 0.15s ease';
      container.innerHTML = '';
      legendContainer.innerHTML = '';

      requestAnimationFrame(() => {
        container.style.opacity = '1';
      });

      const rect = container.getBoundingClientRect();
      const margin = { top: 30, right: 10, bottom: 28, left: 45 };
      const width = rect.width - margin.left - margin.right;
      const height = rect.height - margin.top - margin.bottom;

      const svg = d3.select('#chart')
        .append('svg')
        .attr('viewBox', `0 0 ${rect.width} ${rect.height}`)
        .append('g')
        .attr('transform', `translate(${margin.left},${margin.top})`);

      const pairData = (timeseriesData as any)[String(activePairId)];
      if (!pairData) {
        svg.append('text')
          .attr('x', width / 2).attr('y', height / 2)
          .attr('text-anchor', 'middle')
          .attr('fill', '#9ca3af')
          .attr('font-size', '14px')
          .text('No data available for this pair');
        return;
      }

      // Check if active source has data for this pair
      const hasData = activeSources.size > 0 && [...activeSources].some(s => pairData[s] && pairData[s].length > 0);
      if (!hasData) {
        svg.append('text')
          .attr('x', width / 2).attr('y', height / 2 - 10)
          .attr('text-anchor', 'middle')
          .attr('fill', '#9ca3af')
          .attr('font-size', '14px')
          .text(`No ${sourceLabels[activeSource] || activeSource} data for this pair`);
        svg.append('text')
          .attr('x', width / 2).attr('y', height / 2 + 14)
          .attr('text-anchor', 'middle')
          .attr('fill', '#d1d5db')
          .attr('font-size', '12px')
          .text('Try switching to Trends or Wikipedia for broader coverage');
        return;
      }

      const parseDate = d3.timeParse('%Y-%m');
      const allDates: Date[] = [];

      for (const src of activeSources) {
        const series = pairData[src];
        if (!series) continue;
        for (const d of series) {
          const date = parseDate(d.date);
          if (date) allDates.push(date);
        }
      }

      if (allDates.length === 0) return;

      // Dynamic range based on actual data for this pair + source
      const seriesData = pairData[activeSource] || [];
      const dataMinDate = d3.min(allDates) as Date;
      const dataMaxDate = d3.max(allDates) as Date;

      // Pad 1 month before/after data range (tight fit)
      const xStart = new Date(dataMinDate.getFullYear(), dataMinDate.getMonth() - 1, 1);
      const xEnd = new Date(dataMaxDate.getFullYear(), dataMaxDate.getMonth() + 2, 1);
      const x = d3.scaleTime()
        .domain([xStart, xEnd])
        .range([0, width]);

      // Update title range and info text
      const rangeEl = document.getElementById('chart-range');
      const infoEl = document.getElementById('chart-info');
      const sourceInfo: Record<string, string> = {
        trends: 'Monthly search interest',
        gdelt: 'GDELT v2 news monitoring',
        wikipedia: 'Pageviews API',
        reddit: 'Reddit posts, annual',
        youtube: 'Video title matches, annual',
        ngrams: 'Google Books corpus (English All 2022, 1900–2022)',
        openalex: 'OpenAlex academic papers',
      };
      const startYear = dataMinDate.getFullYear();
      const endYear = dataMaxDate.getFullYear();
      if (rangeEl) rangeEl.textContent = `${startYear}–${endYear}`;
      if (infoEl) infoEl.textContent = sourceInfo[activeSource] || '';

      // Show adoption formula
      const formulaEl = document.getElementById('chart-adoption-formula');
      if (formulaEl && seriesData.length > 0) {
        const last = seriesData[seriesData.length - 1];
        const ukr = last.ukr || 0;
        const rus = last.rus || 0;
        const total = ukr + rus;
        if (total > 0) {
          const fN = (n: number) => n >= 1e6 ? (n/1e6).toFixed(1)+'M' : n >= 1e3 ? (n/1e3).toFixed(1)+'K' : String(n);
          if (chartMode === 'adoption') {
            formulaEl.innerHTML = `· Adoption = <strong>${fN(ukr)}</strong> / (<strong>${fN(ukr)}</strong> + ${fN(rus)}) = <strong>${last.adoption}%</strong>`;
          } else {
            formulaEl.innerHTML = `· Latest: <strong style="color:#0057B8">${fN(ukr)}</strong> UA + <strong style="color:#dc2626">${fN(rus)}</strong> RU = ${fN(total)} total`;
          }
        } else {
          formulaEl.textContent = '';
        }
      }

      // Y-axis depends on chart mode
      let y: d3.ScaleLinear<number, number>;
      let yTicks: number[];

      if (chartMode === 'volume') {
        // Max = highest single bar value (side-by-side, not stacked)
        const getVal = (d: any) => {
          if (lineMode === 'ukrainian') return d.ukr || 0;
          if (lineMode === 'russian') return d.rus || 0;
          return Math.max(d.ukr || 0, d.rus || 0);  // side-by-side: max of either
        };
        const allVals = (seriesData || []).map(getVal).filter((v: number) => v > 0);
        const maxVal = allVals.length > 0 ? Math.max(...allVals) : 1;
        const yMax = maxVal * 1.1;
        y = d3.scaleLinear().domain([0, yMax]).range([height, 0]);

        // Dynamic grid: 4 evenly spaced ticks based on actual data
        const step = yMax / 4;
        yTicks = [0, step, step * 2, step * 3, yMax].map(v => Math.round(v));
      } else {
        y = d3.scaleLinear().domain([0, 100]).range([height, 0]);
        yTicks = [0, 25, 50, 75, 100];
      }

      // Grid lines
      svg.append('g').selectAll('line')
        .data(yTicks)
        .enter().append('line')
        .attr('x1', 0).attr('x2', width)
        .attr('y1', (d: number) => y(d)).attr('y2', (d: number) => y(d))
        .attr('stroke', '#e5e7eb')
        .attr('stroke-dasharray', '3,4');

      // Y-axis labels — same ticks as grid
      const fmtY = (d: number) => {
        if (chartMode === 'volume') {
          if (d >= 1e6) return (d / 1e6).toFixed(1) + 'M';
          if (d >= 1e3) return (d / 1e3).toFixed(0) + 'K';
          return d === 0 ? '0' : String(Math.round(d));
        }
        return d + '%';
      };
      svg.append('g').selectAll('text')
        .data(yTicks)
        .enter().append('text')
        .attr('x', -8).attr('y', (d: number) => y(d) + 4)
        .attr('text-anchor', 'end')
        .attr('fill', '#9ca3af').attr('font-size', '10px')
        .text(fmtY);

      // X-axis — decades for Ngrams, years for others
      const xTicks = activeSource === 'ngrams'
        ? d3.axisBottom(x).ticks(d3.timeYear.every(10)).tickSize(0).tickPadding(8).tickFormat(d3.timeFormat('%Y') as any)
        : d3.axisBottom(x).ticks(d3.timeYear.every(1)).tickSize(0).tickPadding(8).tickFormat(d3.timeFormat('%Y') as any);

      svg.append('g')
        .attr('transform', `translate(0,${height})`)
        .call(xTicks)
        .selectAll('text').attr('fill', '#9ca3af').attr('font-size', '12px');

      svg.selectAll('.domain').attr('stroke', '#e5e7eb');

      // Event markers — positioned by date on x-scale
      if (showEvents) {
        const globalEvents = ((timeseriesData as any).events || []).map((e: any) => ({...e, type: 'global'}));
        const customEvents = ((pairEvents as any)[String(activePairId)] || []).map((e: any) => ({...e, type: 'pair'}));
        const events = [...globalEvents, ...customEvents].sort((a: any, b: any) => a.date.localeCompare(b.date));

        let eventNum = 0;
        events.forEach((evt: any) => {
          const date = parseDate(evt.date);
          if (!date || date < xStart || date > xEnd) return;
          eventNum++;
          const xPos = x(date);
          const isPair = evt.type === 'pair';

          // Vertical dashed line
          svg.append('line')
            .attr('x1', xPos).attr('x2', xPos)
            .attr('y1', -10).attr('y2', height)
            .attr('stroke', isPair ? '#0057B8' : '#d1d5db')
            .attr('stroke-width', 1)
            .attr('stroke-dasharray', '4,3')
            .attr('opacity', isPair ? 0.5 : 0.3);

          // Numbered circle at top
          svg.append('circle')
            .attr('cx', xPos).attr('cy', -18)
            .attr('r', 9)
            .attr('fill', isPair ? '#0057B8' : '#e5e7eb');
          svg.append('text')
            .attr('x', xPos).attr('y', -14)
            .attr('text-anchor', 'middle')
            .attr('fill', isPair ? '#fff' : '#6b7280')
            .attr('font-size', '10px')
            .attr('font-weight', '700')
            .text(eventNum);

          // Legend entry below chart
          const legendItem = document.createElement('span');
          legendItem.className = 'legend-item';
          legendItem.style.cssText = `font-size:0.78rem; color:${isPair ? '#0057B8' : '#6b7280'}; ${isPair ? 'font-weight:600;' : ''}`;
          legendItem.innerHTML = `<span style="display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;background:${isPair ? '#0057B8' : '#e5e7eb'};color:${isPair ? '#fff' : '#6b7280'};font-size:10px;font-weight:700;margin-right:4px;">${eventNum}</span>${evt.label} (${evt.date})`;
          legendContainer.appendChild(legendItem);
        });
      }

      // Data lines + crosshair tooltip
      const chartContainer = document.getElementById('chart')!;
      chartContainer.style.position = 'relative';

      const tooltip = d3.select('#chart')
        .append('div')
        .style('position', 'absolute')
        .style('background', 'white')
        .style('border', '1px solid #d1d5db')
        .style('border-radius', '8px')
        .style('padding', '10px 14px')
        .style('font-size', '13px')
        .style('pointer-events', 'none')
        .style('opacity', '0')
        .style('box-shadow', '0 4px 16px rgba(0,0,0,0.12)')
        .style('z-index', '10')
        .style('white-space', 'nowrap')
        .style('line-height', '1.6');

      const crosshairLine = svg.append('line')
        .attr('y1', 0).attr('y2', height)
        .attr('stroke', '#d1d5db')
        .attr('stroke-width', 1)
        .attr('stroke-dasharray', '4,3')
        .style('opacity', 0);

      // Build all series data for crosshair lookup
      const allSeriesData: Record<string, any[]> = {};
      const activeLegend: {label: string; color: string; value: number}[] = [];

      for (const src of activeSources) {
        const series = pairData[src];
        if (!series) continue;
        allSeriesData[src] = series;

        if (chartMode === 'volume') {
          // ── VOLUME MODE: stacked bar chart ──
          // Bar width based on the *minimum* gap between consecutive points,
          // so dense regions don't overlap when the series has uneven spacing.
          let minGapMs = Infinity;
          for (let i = 1; i < series.length; i++) {
            const da = parseDate(series[i - 1].date);
            const db = parseDate(series[i].date);
            if (!da || !db) continue;
            const gap = (db as any) - (da as any);
            if (gap > 0 && gap < minGapMs) minGapMs = gap;
          }
          if (!isFinite(minGapMs)) {
            const timeSpanMs = (x.domain()[1] as any) - (x.domain()[0] as any);
            minGapMs = series.length > 1 ? timeSpanMs / series.length : timeSpanMs;
          }
          const minGapPx = Math.abs(x(new Date((x.domain()[0] as any).getTime() + minGapMs)) - x(x.domain()[0] as any));
          const barWidth = Math.max(2, Math.min(minGapPx * 0.85, 25));

          series.forEach((d: any) => {
            const date = parseDate(d.date);
            if (!date) return;
            const ukr = d.ukr || 0;
            const rus = d.rus || 0;
            const cx = x(date);

            if (lineMode === 'both') {
              // Side-by-side: Russian left, Ukrainian right (no overlap)
              const halfW = barWidth / 2;
              if (rus > 0) {
                svg.append('rect')
                  .attr('x', cx - halfW).attr('y', y(rus))
                  .attr('width', halfW - 0.5).attr('height', Math.max(0, height - y(rus)))
                  .attr('fill', '#dc2626').attr('opacity', 0.45).attr('rx', 1);
              }
              if (ukr > 0) {
                svg.append('rect')
                  .attr('x', cx + 0.5).attr('y', y(ukr))
                  .attr('width', halfW - 0.5).attr('height', Math.max(0, height - y(ukr)))
                  .attr('fill', sourceColors[src]).attr('opacity', 0.85).attr('rx', 1);
              }
            } else if (lineMode === 'ukrainian' && ukr > 0) {
              svg.append('rect')
                .attr('x', cx - barWidth / 2).attr('y', y(ukr))
                .attr('width', barWidth).attr('height', height - y(ukr))
                .attr('fill', sourceColors[src]).attr('opacity', 0.8).attr('rx', 1);
            } else if (lineMode === 'russian' && rus > 0) {
              svg.append('rect')
                .attr('x', cx - barWidth / 2).attr('y', y(rus))
                .attr('width', barWidth).attr('height', height - y(rus))
                .attr('fill', '#dc2626').attr('opacity', 0.8).attr('rx', 1);
            }
          });
        } else {
          // ── ADOPTION MODE: line chart ──
          const line = d3.line<any>()
            .x((d: any) => x(parseDate(d.date)!))
            .y((d: any) => y(d.adoption))
            .curve(d3.curveBasis);

          if (lineMode !== 'russian') {
            svg.append('path')
              .datum(series)
              .attr('fill', 'none')
              .attr('stroke', sourceColors[src])
              .attr('stroke-width', 3)
              .attr('d', line);
          }

          if (lineMode !== 'ukrainian') {
            const russianLine = d3.line<any>()
              .x((d: any) => x(parseDate(d.date)!))
              .y((d: any) => y(100 - d.adoption))
              .curve(d3.curveBasis);

            svg.append('path')
              .datum(series)
              .attr('fill', 'none')
              .attr('stroke', '#dc2626')
              .attr('stroke-width', lineMode === 'russian' ? 3 : 1.5)
              .attr('stroke-dasharray', lineMode === 'russian' ? 'none' : '6,4')
              .attr('opacity', lineMode === 'russian' ? 1 : 0.5)
              .attr('d', russianLine);
          }
        }

        const last = series[series.length - 1];

        activeLegend.push({
          label: sourceLabels[src],
          color: sourceColors[src],
          value: last.adoption,
        });
      }

      // Crosshair overlay — interpolates between data points
      svg.append('rect')
        .attr('width', width).attr('height', height)
        .attr('fill', 'transparent')
        .on('mousemove', function(event: MouseEvent) {
          const [mx] = d3.pointer(event);
          const hoveredDate = x.invert(mx);
          const dateStr = d3.timeFormat('%b %Y')(hoveredDate);

          crosshairLine.attr('x1', mx).attr('x2', mx).style('opacity', 1);

          let html = `<strong>${dateStr}</strong>`;
          for (const src of Object.keys(allSeriesData)) {
            const series = allSeriesData[src];
            if (series.length < 2) continue;

            const dates = series.map((d: any) => parseDate(d.date)!.getTime());
            const vals = series.map((d: any) => d.adoption);
            const t = hoveredDate.getTime();
            if (t < dates[0] || t > dates[dates.length - 1]) continue;

            let lo = 0, hi = dates.length - 1;
            while (hi - lo > 1) {
              const mid = (lo + hi) >> 1;
              if (dates[mid] <= t) lo = mid; else hi = mid;
            }

            const closest = Math.abs(t - dates[lo]) < Math.abs(t - dates[hi]) ? lo : hi;
            const d = series[closest];
            const value = Math.round(d.adoption * 10) / 10;

            if (chartMode === 'volume' && d.ukr !== undefined) {
              html += `<br/><span style="color:${sourceColors[src]}">● ${sourceLabels[src]}</span>`;
              html += `<br/>&nbsp;&nbsp;<span style="color:${sourceColors[src]}">UA: <strong>${(d.ukr || 0).toLocaleString()}</strong></span>`;
              html += `<br/>&nbsp;&nbsp;<span style="color:#dc2626">RU: <strong>${(d.rus || 0).toLocaleString()}</strong></span>`;
              html += `<br/>&nbsp;&nbsp;<span style="color:#6b7280">Adoption: ${value}%</span>`;
            } else {
              html += `<br/><span style="color:${sourceColors[src]}">● ${sourceLabels[src]}: <strong>${value}%</strong></span>`;
              if (d.ukr !== undefined) {
                html += ` <span style="color:#9ca3af;font-size:0.8em">(UA:${(d.ukr||0).toLocaleString()} / RU:${(d.rus||0).toLocaleString()})</span>`;
              }
            }
          }

          tooltip.style('opacity', '1').html(html);
          const cr = chartContainer.getBoundingClientRect();
          const left = event.clientX - cr.left;
          tooltip.style('left', (left > width / 2 ? left - 200 : left + 20) + 'px')
            .style('top', '10px');
        })
        .on('mouseleave', function() {
          crosshairLine.style('opacity', 0);
          tooltip.style('opacity', '0');
        });

      // Legend
      if (lineMode !== 'russian') {
        for (const item of activeLegend) {
          const el = document.createElement('div');
          el.className = 'legend-item';
          el.innerHTML = `<span class="legend-line" style="background: ${item.color}"></span>${item.label}: ${item.value}%`;
          legendContainer.appendChild(el);
        }
      }
      if (lineMode !== 'ukrainian') {
        const el = document.createElement('div');
        el.className = 'legend-item';
        const lastVal = activeLegend[0] ? (100 - activeLegend[0].value).toFixed(1) : '?';
        el.innerHTML = `<span class="legend-line" style="background: #dc2626"></span>Old spelling: ${lastVal}%`;
        legendContainer.appendChild(el);
      }
    }

    // Sidebar
    document.querySelectorAll('.sidebar-header').forEach(header => {
      header.addEventListener('click', () => {
        header.classList.toggle('open');
        header.nextElementSibling?.classList.toggle('open');
      });
    });

    function selectPair(pairId: number) {
      activePairId = pairId;
      updateUrl(pairId);
      showView('pair');
      // Close mobile menu on selection
      document.getElementById('sidebar-aside')?.classList.remove('mobile-open');
      document.getElementById('sidebar-overlay')?.classList.remove('open');
      document.querySelectorAll('.sidebar-item').forEach(i => {
        const id = parseInt((i as HTMLElement).dataset.pairId || '0');
        i.classList.toggle('active', id === pairId);
        // Open parent category if needed
        if (id === pairId) {
          const section = i.closest('.sidebar-section');
          if (section) {
            section.querySelector('.sidebar-header')?.classList.add('open');
            section.querySelector('.sidebar-items')?.classList.add('open');
          }
        }
      });
      const pair = (pairs as any).pairs.find((p: any) => p.id === pairId);
      if (pair) {
        document.getElementById('chart-new')!.textContent = pair.ukrainian;
        document.getElementById('chart-old')!.textContent = pair.russian;
        const reportLink = document.getElementById('topbar-report-link') as HTMLAnchorElement;
        if (reportLink) reportLink.href = `/report#pair-${pairId}`;
      }
      drawChart();
      drawPairStats();
      drawAdoptionCalc();
      drawSearchPreview();
      drawPairClContext();
      // setTimeout ensures browser has fully laid out pair-view before measuring widths.
      // Each draw is wrapped so a single failure doesn't cascade and leave later
      // panels (e.g. world map, holdouts) empty when an earlier panel throws.
      setTimeout(() => {
        const safeDraw = (name: string, fn: () => void) => {
          try { fn(); } catch (e) { console.error(`[${name}] failed:`, e); }
        };
        safeDraw('drawPairSourceChart', drawPairSourceChart);
        safeDraw('drawPairReligious', drawPairReligious);
        safeDraw('drawMediaOrigin', drawMediaOrigin);
        safeDraw('drawPairLLM', drawPairLLM);
        safeDraw('drawWorldMap', drawWorldMap);
        safeDraw('drawHoldoutTable', drawHoldoutTable);
      }, 50);
    }

    function drawAdoptionCalc() {
      const body = document.getElementById('adoption-calc-body');
      if (!body) return;

      const pairData = (timeseriesData as any)[String(activePairId)];
      if (!pairData) { body.innerHTML = ''; return; }

      const pair = (pairs as any).pairs.find((p: any) => p.id === activePairId);
      if (!pair) return;

      const srcOrder = ['gdelt', 'trends', 'wikipedia', 'reddit', 'youtube', 'ngrams', 'openalex'];
      const fN = (n: number) => n >= 1e6 ? (n/1e6).toFixed(1)+'M' : n >= 1e3 ? (n/1e3).toFixed(1)+'K' : String(n);

      // Put adoption % in card title
      const titleEl = document.getElementById('adoption-pct-title');
      if (titleEl) titleEl.textContent = `${pair.adoption}%`;

      let html = '';

      // Per-source bars
      html += '<div style="display:flex; flex-direction:column; gap:0.3rem;">';
      for (const src of srcOrder) {
        const series = pairData[src];
        if (!series || series.length === 0) continue;
        const last = series[series.length - 1];
        const pct = last.adoption;
        const ukr = last.ukr || 0;
        const rus = last.rus || 0;
        const total = ukr + rus;
        const countStr = total > 0 ? `${fN(ukr)}/${fN(total)}` : '';

        html += `<div style="display:flex; align-items:center; gap:0.4rem;">`;
        html += `<span style="width:60px; font-size:0.65rem; color:var(--text-muted); text-align:right; flex-shrink:0;">${sourceLabels[src].split(' ')[0]}</span>`;
        html += `<div style="flex:1; height:14px; background:#f0f0f0; border-radius:7px; overflow:hidden; position:relative;">`;
        html += `<div style="height:100%; width:${Math.min(100, pct)}%; background:${sourceColors[src]}; border-radius:7px; opacity:0.8;"></div>`;
        html += `</div>`;
        html += `<span style="width:38px; font-size:0.68rem; font-weight:600; color:${sourceColors[src]}; text-align:right; flex-shrink:0;">${pct}%</span>`;
        html += `</div>`;
      }
      html += '</div>';

      body.innerHTML = html;
    }

    function drawPairSourceChart() {
      const container = document.getElementById('pair-source-chart');
      if (!container) return;
      container.innerHTML = '';

      const pairData = (timeseriesData as any)[String(activePairId)];
      if (!pairData) return;

      const srcOrder = ['gdelt', 'trends', 'wikipedia', 'reddit', 'youtube', 'ngrams', 'openalex'];
      const items: {src: string; adoption: number; n: number}[] = [];

      for (const src of srcOrder) {
        const series = pairData[src];
        if (!series || series.length === 0) continue;
        const last = series[series.length - 1];
        items.push({src, adoption: last.adoption, n: series.length});
      }

      if (items.length === 0) return;

      const margin = {top: 5, right: 50, bottom: 5, left: 110};
      const rowH = 26;
      // Use fixed viewBox width — SVG scales via width:100%, avoids getBoundingClientRect timing issues
      const width = 500;
      const height = items.length * rowH;
      const totalH = height + margin.top + margin.bottom;
      const totalW = width + margin.left + margin.right;

      const svg = d3.select('#pair-source-chart')
        .append('svg')
        .attr('width', '100%')
        .attr('viewBox', `0 0 ${totalW} ${totalH}`)
        .append('g').attr('transform', `translate(${margin.left},${margin.top})`);

      const x = d3.scaleLinear().domain([0, 100]).range([0, width]);
      const y = d3.scaleBand().domain(items.map(d => d.src)).range([0, height]).padding(0.3);

      // 50% line
      svg.append('line').attr('x1', x(50)).attr('x2', x(50)).attr('y1', 0).attr('y2', height)
        .attr('stroke', '#e5e7eb').attr('stroke-dasharray', '3,3');

      items.forEach(item => {
        svg.append('text').attr('x', -6).attr('y', y(item.src)! + y.bandwidth()/2 + 4)
          .attr('text-anchor', 'end').attr('font-size', '11px').attr('fill', 'var(--text)')
          .text(sourceLabels[item.src] || item.src);

        svg.append('rect')
          .attr('x', 0).attr('y', y(item.src)!)
          .attr('width', Math.max(2, x(item.adoption))).attr('height', y.bandwidth())
          .attr('fill', sourceColors[item.src]).attr('rx', 3).attr('opacity', 0.85);

        svg.append('text')
          .attr('x', x(item.adoption) + 6).attr('y', y(item.src)! + y.bandwidth()/2 + 4)
          .attr('font-size', '11px').attr('font-weight', '600').attr('fill', sourceColors[item.src])
          .text(`${item.adoption}%`);
      });
    }

    // ── Per-pair religious panel ──
    // Religious data is global per-source not per-pair-per-year, but each
    // source has a list of pairs it has mentions for. Show only the
    // denominations that have data for THIS pair.
    let _religiousCache: any = null;
    function getReligiousData() {
      if (_religiousCache !== null) return _religiousCache;
      const el = document.getElementById('religious-per-pair-data');
      if (!el || !el.textContent) { _religiousCache = {}; return _religiousCache; }
      try {
        _religiousCache = JSON.parse(el.textContent);
      } catch (e) {
        console.error('[drawPairReligious] failed to parse religious data:', e);
        _religiousCache = {};
      }
      return _religiousCache;
    }

    function drawPairReligious() {
      const container = document.getElementById('pair-religious-container');
      const body = document.getElementById('pair-religious-body');
      if (!container || !body) return;

      const rel = getReligiousData();
      const pid = activePairId;
      // For each denomination, find this pair's stats
      const rows = (rel.denominations || [])
        .map((d: any) => {
          const pp = (d.pairs || []).find((p: any) => p.pair_id === pid);
          return pp ? {...d, pair: pp} : null;
        })
        .filter(Boolean);

      if (rows.length === 0) {
        body.innerHTML = `<div style="font-size:0.7rem; color:var(--text-muted); padding:0.5rem 0;">No religious-press mentions for this pair across the 4 tracked institutions.</div>`;
        return;
      }

      // Sort by total mentions desc
      rows.sort((a: any, b: any) => (b.pair.ru + b.pair.ua) - (a.pair.ru + a.pair.ua));

      let html = '';
      html += `<div style="display:flex; flex-direction:column; gap:0.4rem;">`;
      for (const r of rows) {
        const pp = r.pair;
        const total = pp.ru + pp.ua;
        const uaPct = total > 0 ? (pp.ua / total * 100) : 0;
        html += `
          <div style="display:grid; grid-template-columns:140px 1fr 90px; gap:0.5rem; align-items:center; font-size:0.7rem;">
            <div style="display:flex; align-items:center; gap:0.4rem;">
              <span style="display:inline-block; width:8px; height:8px; border-radius:2px; background:${r.color}; flex-shrink:0;"></span>
              <span style="color:var(--text); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${r.short}</span>
            </div>
            <div style="display:flex; height:14px; border-radius:2px; overflow:hidden; background:#f0f0f0;">
              <div style="width:${uaPct}%; background:#0057B8;"></div>
              <div style="width:${100 - uaPct}%; background:#D52B1E;"></div>
            </div>
            <div style="font-family:monospace; font-size:0.6rem; color:var(--text-muted); text-align:right;">${pp.ua}/${total} (${uaPct.toFixed(0)}%)</div>
          </div>
        `;
      }
      html += `</div>`;
      html += `<div style="margin-top:0.6rem; font-size:0.6rem; color:var(--text-muted);"><span style="color:#0057B8;">●</span> Ukrainian spelling · <span style="color:#D52B1E;">●</span> Russian spelling</div>`;

      body.innerHTML = html;
    }

    // ── Per-pair LLM scan: 71 frontier models × 3 prompt variants for THIS pair ──
    // Astro doesn't bundle JSON imports into client scripts (works only in
    // server-side JSX expressions). Read the data from the inline JSON script
    // tag instead.
    let _llmPerPairCache: any = null;
    function getLlmPerPair() {
      if (_llmPerPairCache !== null) return _llmPerPairCache;
      const el = document.getElementById('llm-per-pair-data');
      if (!el || !el.textContent) {
        _llmPerPairCache = {};
        return _llmPerPairCache;
      }
      try {
        _llmPerPairCache = JSON.parse(el.textContent);
      } catch (e) {
        console.error('[drawPairLLM] failed to parse llm-per-pair-data:', e);
        _llmPerPairCache = {};
      }
      return _llmPerPairCache;
    }

    function drawPairLLM() {
      const container = document.getElementById('pair-llm-container');
      const body = document.getElementById('pair-llm-body');
      const nameEl = document.getElementById('pair-llm-pair-name');
      if (!container || !body) {
        console.warn('[drawPairLLM] container or body missing', {container, body});
        return;
      }

      const llmPerPair = getLlmPerPair();
      const pid = String(activePairId);
      const pp = llmPerPair.pairs?.[pid];
      if (!pp || !pp.models) {
        body.innerHTML = `<div style="font-size:0.7rem; color:var(--text-muted); padding:0.5rem 0;">No LLM data for pair ${pid}.</div>`;
        return;
      }
      container.style.display = '';

      const families = llmPerPair.families || {};
      const modelLabel = (key: string) => key
        .replace('claude-', '')
        .replace('gemini-', '')
        .replace('gemma-', 'g')
        .replace('gpt-', '')
        .replace('grok-', '');

      // Header label
      if (nameEl) nameEl.textContent = `${pp.russian} / ${pp.ukrainian}`;

      // Build the table HTML manually for max control
      const sum = pp.summary;
      const fmt = (v: any) => v == null ? '—' : (typeof v === 'number' ? v.toFixed(0) + '%' : String(v));

      // Sort models by tas descending
      const models = [...pp.models].sort((a, b) => (b.tas ?? -1) - (a.tas ?? -1));

      // Group by family for the per-family rollup row
      const familyOrder = Object.keys(sum.by_family || {}).sort((a, b) => sum.by_family[b].n - sum.by_family[a].n);

      let html = '';

      // Top: 3 big numbers (open / forced / TAS)
      html += `
        <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:0.5rem; margin-bottom:0.75rem;">
          <div style="padding:0.6rem 0.75rem; background:rgba(213,43,30,0.05); border-left:3px solid #D52B1E; border-radius:3px;">
            <div style="font-size:0.6rem; text-transform:uppercase; color:var(--text-muted); font-weight:700;">Free recall</div>
            <div style="font-size:1.4rem; font-weight:700; color:var(--text);">${fmt(sum.open_pct)}</div>
            <div style="font-size:0.6rem; color:var(--text-muted);">of models pick "${pp.ukrainian}" when generating</div>
          </div>
          <div style="padding:0.6rem 0.75rem; background:rgba(0,87,184,0.05); border-left:3px solid #0057B8; border-radius:3px;">
            <div style="font-size:0.6rem; text-transform:uppercase; color:var(--text-muted); font-weight:700;">Forced choice (avg)</div>
            <div style="font-size:1.4rem; font-weight:700; color:var(--text);">${fmt(((sum.forced_ru_pct || 0) + (sum.forced_ua_pct || 0)) / 2)}</div>
            <div style="font-size:0.6rem; color:var(--text-muted);">when shown both spellings</div>
          </div>
          <div style="padding:0.6rem 0.75rem; background:rgba(0,87,184,0.03); border-left:3px solid var(--text-muted); border-radius:3px;">
            <div style="font-size:0.6rem; text-transform:uppercase; color:var(--text-muted); font-weight:700;">TAS (weighted)</div>
            <div style="font-size:1.4rem; font-weight:700; color:var(--text);">${fmt(sum.tas_mean)}</div>
            <div style="font-size:0.6rem; color:var(--text-muted);">across ${sum.n_models} frontier models</div>
          </div>
        </div>
      `;

      // Per-family rollup mini-bars
      // Show concrete counts (e.g. "3/3" or "17/17") in addition to %
      // because "100%" with N=3 looks identical to "100%" with N=71 and
      // misleads users into thinking small samples are universal truths.
      html += `<div style="font-size:0.7rem; font-weight:700; color:var(--text); margin:0.75rem 0 0.4rem;">By family</div>`;
      const safePct = (v: any) => (typeof v === 'number' ? v : 0);
      // Per-family raw counts: walk pp.models and tally
      const famCounts: Record<string, {open_ua: number, open_n: number, forced_ua: number, forced_n: number}> = {};
      for (const m of pp.models) {
        const k = m.family;
        if (!famCounts[k]) famCounts[k] = {open_ua: 0, open_n: 0, forced_ua: 0, forced_n: 0};
        if (m.x_open === 1) famCounts[k].open_ua++;
        if (m.x_open != null) famCounts[k].open_n++;
        for (const v of [m.x_forced_ru_first, m.x_forced_ua_first]) {
          if (v === 1) famCounts[k].forced_ua++;
          if (v != null) famCounts[k].forced_n++;
        }
      }
      for (const fam of familyOrder) {
        const f = sum.by_family[fam];
        const counts = famCounts[fam] || {open_ua: 0, open_n: 0, forced_ua: 0, forced_n: 0};
        const color = families[fam]?.color || '#666';
        const opPct = safePct(f.open_pct);
        const fcPct = safePct(f.forced_pct);
        html += `
          <div style="display:grid; grid-template-columns:150px 1fr 1fr; gap:0.5rem; align-items:center; margin-bottom:0.3rem; font-size:0.65rem;">
            <div style="color:var(--text); display:flex; align-items:center; gap:0.35rem; min-width:0;">
              <span style="display:inline-block; width:8px; height:8px; border-radius:2px; background:${color}; flex-shrink:0;"></span>
              <span style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${fam}</span>
              <span style="color:var(--text-muted); font-family:monospace; flex-shrink:0;">×${f.n}</span>
            </div>
            <div style="display:flex; align-items:center; gap:0.4rem;">
              <div style="flex:1; height:12px; background:#f0f0f0; border-radius:2px; overflow:hidden;">
                <div style="width:${opPct}%; height:100%; background:#D52B1E; opacity:0.85;"></div>
              </div>
              <span style="font-family:monospace; color:var(--text-muted); font-size:0.6rem; width:36px; text-align:right;">${counts.open_ua}/${counts.open_n}</span>
            </div>
            <div style="display:flex; align-items:center; gap:0.4rem;">
              <div style="flex:1; height:12px; background:#f0f0f0; border-radius:2px; overflow:hidden;">
                <div style="width:${fcPct}%; height:100%; background:#0057B8; opacity:0.85;"></div>
              </div>
              <span style="font-family:monospace; color:var(--text-muted); font-size:0.6rem; width:42px; text-align:right;">${counts.forced_ua}/${counts.forced_n}</span>
            </div>
          </div>
        `;
      }
      html += `
        <div style="display:grid; grid-template-columns:150px 1fr 1fr; gap:0.5rem; font-size:0.55rem; color:var(--text-muted); margin-top:0.5rem; padding-top:0.4rem; border-top:1px solid rgba(0,0,0,0.06);">
          <div></div>
          <div style="display:flex; align-items:center; gap:0.3rem;"><span style="width:8px; height:8px; background:#D52B1E; display:inline-block; border-radius:1px;"></span>free recall — UA picks / total decisive</div>
          <div style="display:flex; align-items:center; gap:0.3rem;"><span style="width:8px; height:8px; background:#0057B8; display:inline-block; border-radius:1px;"></span>forced choice — UA picks / 2 trials per model</div>
        </div>
      `;

      // Per-model scatter plot — one circle per model, grouped by family on X,
      // TAS on Y. Replaces the giant table; hover shows model + TAS.
      html += `<div style="font-size:0.7rem; font-weight:700; color:var(--text); margin:1rem 0 0.25rem;">All ${models.length} models · TAS by family</div>`;
      html += `<div style="font-size:0.6rem; color:var(--text-muted); margin-bottom:0.4rem;">Each dot is one model. Y axis is TAS (0–100%). Hover for the model name and its three trial outcomes.</div>`;
      html += `<div id="pair-llm-scatter" style="width:100%; height:240px;"></div>`;

      body.innerHTML = html;

      // ── render the scatter into #pair-llm-scatter ──
      const scatterEl = document.getElementById('pair-llm-scatter');
      if (!scatterEl) return;
      const sw = scatterEl.clientWidth || 600;
      const sh = 240;
      const sm = {top: 12, right: 12, bottom: 44, left: 32};
      const innerW = sw - sm.left - sm.right;
      const innerH = sh - sm.top - sm.bottom;

      const svgScatter = d3.select('#pair-llm-scatter')
        .append('svg')
        .attr('width', sw)
        .attr('height', sh);
      const gScatter = svgScatter.append('g').attr('transform', `translate(${sm.left},${sm.top})`);

      const xScatter = d3.scaleBand<string>()
        .domain(familyOrder)
        .range([0, innerW])
        .padding(0.15);
      const yScatter = d3.scaleLinear().domain([0, 100]).range([innerH, 0]);

      // Y gridlines + axis labels
      [0, 25, 50, 75, 100].forEach((v) => {
        gScatter.append('line')
          .attr('x1', 0).attr('x2', innerW)
          .attr('y1', yScatter(v)).attr('y2', yScatter(v))
          .attr('stroke', '#eef0f3').attr('stroke-width', 1);
        gScatter.append('text')
          .attr('x', -6).attr('y', yScatter(v))
          .attr('text-anchor', 'end').attr('dominant-baseline', 'middle')
          .style('font-size', '9px').style('fill', '#9ca3af')
          .text(v + '%');
      });

      // X axis: family labels (rotated)
      familyOrder.forEach((fam: string) => {
        const cx = (xScatter(fam) || 0) + xScatter.bandwidth() / 2;
        gScatter.append('text')
          .attr('x', cx).attr('y', innerH + 14)
          .attr('text-anchor', 'end')
          .attr('transform', `rotate(-30, ${cx}, ${innerH + 14})`)
          .style('font-size', '9px').style('fill', 'var(--text-muted)')
          .text(fam);
      });

      // Tooltip
      const tip = d3.select('#pair-llm-scatter').append('div')
        .attr('id', 'pair-llm-scatter-tip')
        .style('position', 'absolute')
        .style('pointer-events', 'none')
        .style('background', 'rgba(17,24,39,0.95)')
        .style('color', '#fff')
        .style('padding', '5px 8px')
        .style('border-radius', '3px')
        .style('font-size', '10px')
        .style('font-family', 'monospace')
        .style('opacity', 0)
        .style('white-space', 'nowrap')
        .style('z-index', '10');
      scatterEl.style.position = 'relative';

      const trialChar = (v: any) => v === 1 ? 'UA' : (v === 0 ? 'RU' : '–');

      // Group dots per family and lay them out with simple jitter
      const byFam: Record<string, any[]> = {};
      for (const mdl of models) {
        if (mdl.tas == null) continue;
        if (!byFam[mdl.family]) byFam[mdl.family] = [];
        byFam[mdl.family].push(mdl);
      }
      const r = 4;
      familyOrder.forEach((fam: string) => {
        const list = byFam[fam] || [];
        const bandX = (xScatter(fam) || 0);
        const bw = xScatter.bandwidth();
        const color = families[fam]?.color || '#666';
        // simple beeswarm-ish: sort by tas, alternate left/right of center
        list.sort((a, b) => (b.tas ?? 0) - (a.tas ?? 0));
        list.forEach((mdl: any, i: number) => {
          // Deterministic jitter within band
          const t = list.length === 1 ? 0.5 : (i / (list.length - 1));
          // alternate around center for visual spread
          const offset = ((i % 2 === 0 ? 1 : -1) * (Math.floor(i / 2) + 1) * 5) % (bw / 2);
          const cx = bandX + bw / 2 + offset;
          const cy = yScatter((mdl.tas ?? 0) * 100);
          gScatter.append('circle')
            .attr('cx', cx).attr('cy', cy).attr('r', r)
            .attr('fill', color).attr('fill-opacity', 0.75)
            .attr('stroke', '#fff').attr('stroke-width', 1)
            .style('cursor', 'pointer')
            .on('mouseover', function(this: any, ev: any) {
              d3.select(this).attr('r', r + 2).attr('fill-opacity', 1);
              const pct = (mdl.tas * 100).toFixed(0);
              tip.html(
                `<b>${mdl.key}</b><br>` +
                `TAS ${pct}% · recall ${trialChar(mdl.x_open)} · RU-1st ${trialChar(mdl.x_forced_ru_first)} · UA-1st ${trialChar(mdl.x_forced_ua_first)}`
              ).style('opacity', 1);
            })
            .on('mousemove', function(ev: any) {
              const rect = (scatterEl as any).getBoundingClientRect();
              tip.style('left', (ev.clientX - rect.left + 10) + 'px')
                 .style('top', (ev.clientY - rect.top + 10) + 'px');
            })
            .on('mouseout', function(this: any) {
              d3.select(this).attr('r', r).attr('fill-opacity', 0.75);
              tip.style('opacity', 0);
            });
        });
      });
    }

    function drawMediaOrigin() {
      const wrapper = document.getElementById('media-origin-container');
      const spellingEl = document.getElementById('spelling-pie');
      const uaOriginEl = document.getElementById('ua-origin-pie');
      const ruOriginEl = document.getElementById('ru-origin-pie');
      if (!wrapper || !spellingEl || !uaOriginEl || !ruOriginEl) return;
      spellingEl.innerHTML = '';
      uaOriginEl.innerHTML = '';
      ruOriginEl.innerHTML = '';

      const pairData = (timeseriesData as any)[String(activePairId)];
      if (!pairData?.gdelt || pairData.gdelt.length === 0) {
        wrapper.style.display = 'none';
        return;
      }
      wrapper.style.display = 'grid';

      // 1. Overall spelling pie
      const recent = pairData.gdelt.slice(-24);
      const ukr = recent.reduce((s: number, d: any) => s + (d.ukr || 0), 0);
      const rus = recent.reduce((s: number, d: any) => s + (d.rus || 0), 0);
      drawPie(spellingEl, [
        {label: 'Ukrainian', value: ukr, color: '#0057B8'},
        {label: 'Russian', value: rus, color: '#dc2626'},
      ]);

      // Domain origin data
      const origins = (domainOrigins as any)[String(activePairId)];
      if (origins) {
        const intl = origins.intl || {ukr:0, rus:0, total:0};
        const ua = origins.ua || {ukr:0, rus:0, total:0};
        const ru = origins.ru || {ukr:0, rus:0, total:0};

        // 2. Ukrainian spelling sources — where do UA-form articles come from?
        drawPie(uaOriginEl, [
          {label: 'International', value: intl.ukr, color: '#059669'},
          {label: '.ua domains', value: ua.ukr, color: '#0057B8'},
          {label: '.ru domains', value: ru.ukr, color: '#dc2626'},
        ]);

        // 3. Russian spelling sources — where do RU-form articles come from?
        drawPie(ruOriginEl, [
          {label: 'International', value: intl.rus, color: '#059669'},
          {label: '.ua domains', value: ua.rus, color: '#0057B8'},
          {label: '.ru domains', value: ru.rus, color: '#dc2626'},
        ]);
      } else {
        uaOriginEl.innerHTML = '<div style="color:#9ca3af; font-size:0.75rem;">No data</div>';
        ruOriginEl.innerHTML = '';
      }
    }

    function drawPie(container: HTMLElement, slices: {label: string; value: number; color: string}[]) {
      const total = slices.reduce((s, d) => s + d.value, 0);
      if (total === 0) return;

      const size = 130;
      const r = size / 2 - 5;
      const cx = size / 2;
      const cy = size / 2;

      let svg = `<svg width="${size}" height="${size}" viewBox="0 0 ${size} ${size}">`;
      let startAngle = -Math.PI / 2;

      for (const slice of slices) {
        const pct = slice.value / total;
        const angle = pct * 2 * Math.PI;
        const endAngle = startAngle + angle;
        const large = angle > Math.PI ? 1 : 0;

        const x1 = cx + r * Math.cos(startAngle);
        const y1 = cy + r * Math.sin(startAngle);
        const x2 = cx + r * Math.cos(endAngle);
        const y2 = cy + r * Math.sin(endAngle);

        if (pct > 0.001) {
          svg += `<path d="M${cx},${cy} L${x1},${y1} A${r},${r} 0 ${large},1 ${x2},${y2} Z" fill="${slice.color}" opacity="0.85"/>`;
        }
        startAngle = endAngle;
      }
      svg += '</svg>';

      // Legend below
      let legend = '<div style="display:flex; flex-direction:column; gap:0.2rem; margin-top:0.3rem;">';
      for (const slice of slices) {
        const pct = total > 0 ? (slice.value / total * 100).toFixed(1) : '0';
        const fmtVal = slice.value >= 1e6 ? (slice.value/1e6).toFixed(1)+'M' : slice.value >= 1e3 ? (slice.value/1e3).toFixed(1)+'K' : String(slice.value);
        legend += `<div style="display:flex; align-items:center; gap:0.3rem; font-size:0.68rem;">`;
        legend += `<span style="width:8px; height:8px; border-radius:2px; background:${slice.color}; flex-shrink:0;"></span>`;
        legend += `<span style="color:var(--text);">${slice.label}</span>`;
        legend += `<span style="color:var(--text-muted); margin-left:auto;">${pct}% (${fmtVal})</span>`;
        legend += '</div>';
      }
      legend += '</div>';

      container.innerHTML = svg + legend;
    }

    function drawPairStats() {
      const container = document.getElementById('pair-stats');
      if (!container) return;
      container.innerHTML = '';

      const pairData = (timeseriesData as any)[String(activePairId)];
      if (!pairData) return;

      const srcOrder = ['trends', 'gdelt', 'wikipedia', 'reddit', 'youtube', 'ngrams', 'openalex'];
      for (const src of srcOrder) {
        const series = pairData[src];
        const card = document.createElement('div');
        card.className = 'stat-card mini';
        card.style.setProperty('--accent', sourceColors[src] || '#888');

        if (series && series.length > 0) {
          const total = series.reduce((s: number, d: any) => s + (d.ukr || 0) + (d.rus || 0), 0);
          const last = series[series.length - 1];
          const fmtN = (n: number) => n >= 1e6 ? (n/1e6).toFixed(1)+'M' : n >= 1e3 ? (n/1e3).toFixed(1)+'K' : String(n);
          card.innerHTML = `
            <div class="stat-value">${total > 0 ? fmtN(total) : last.adoption + '%'}</div>
            <div class="stat-label">${sourceLabels[src]}</div>
            <div class="stat-source">${series.length} data points</div>
          `;
        } else {
          // Determine why data is missing — expected vs gap
          const pair = (pairs as any).pairs.find((p: any) => p.id === activePairId);
          const cat = pair?.category || '';
          const pid = activePairId;
          const isNewPair = pid >= 80;
          // Sources that don't cover certain categories
          const gdeltNoData = ['food','landmarks','institutional','sports'].includes(cat) || ['people','historical'].includes(cat);
          const ngramsNoData = ['sports','institutional','landmarks'].includes(cat) || pid >= 60; // recent pairs
          const reason =
            isNewPair ? 'Data collection in progress' :
            (src === 'gdelt' && gdeltNoData) ? 'Not in news URLs' :
            (src === 'ngrams' && ngramsNoData) ? 'Not in book corpus' :
            (src === 'openalex' && ['food','sports','landmarks'].includes(cat)) ? 'Not in academic papers' :
            'No mentions found';
          card.innerHTML = `
            <div class="stat-value" style="color:#d1d5db;">—</div>
            <div class="stat-label">${sourceLabels[src]}</div>
            <div class="stat-source" title="${reason}">${reason}</div>
          `;
          card.style.opacity = '0.4';
        }
        container.appendChild(card);
      }

      // If most sources are empty, add a note
      const filledCount = srcOrder.filter(s => {
        const d = pairData[s];
        return d && d.length > 0 && d.reduce((t: number, r: any) => t + (r.ukr || 0) + (r.rus || 0), 0) > 0;
      }).length;
      const pair = (pairs as any).pairs.find((p: any) => p.id === activePairId);
      const isNewPair = activePairId >= 80;
      if (filledCount <= 3) {
        const note = document.createElement('div');
        note.style.cssText = 'grid-column: 1 / -1; font-size:0.65rem; color:var(--text-muted); padding:0.5rem 0.3rem; line-height:1.5; border-top:1px solid rgba(0,0,0,0.06); margin-top:0.3rem;';
        note.innerHTML = isNewPair
          ? `<strong>New pair.</strong> Data collection is in progress for this pair. Most sources are being scraped and will appear shortly.`
          : `<strong>Limited coverage.</strong> This pair (${pair?.category || ''}) has sparse data because it appears primarily in ${filledCount <= 1 ? 'a single source' : filledCount + ' sources'}. ${pair?.category === 'people' ? 'Person names appear mainly in Wikipedia and Google Trends, not in news-URL databases or book corpora.' : pair?.category === 'landmarks' || pair?.category === 'institutional' ? 'Institutional and landmark names rarely appear as standalone search terms in news databases.' : 'Niche pairs naturally have fewer data points across sources.'}`;
        container.appendChild(note);
      }
    }

    document.querySelectorAll('.sidebar-item').forEach(item => {
      item.addEventListener('click', () => {
        selectPair(parseInt((item as HTMLElement).dataset.pairId || '1'));
      });
    });

