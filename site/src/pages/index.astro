        // Two columns: RU words | UA words
        const cols = card.append('div')
          .style('display', 'grid')
          .style('grid-template-columns', '1fr 1fr')
          .style('gap', '0.5rem');

        // Russian collocates
        const ruCol = cols.append('div');
        ruCol.append('div')
          .style('font-size', '0.7rem')
          .style('color', '#ef4444')
          .style('font-weight', '600')
          .style('margin-bottom', '0.4rem')
          .style('text-transform', 'uppercase')
          .style('letter-spacing', '0.05em')
          .text('Russian form');

        const ruWords = pairData.russian.collocates
          .filter((c: any) => c.count >= 3)
          .slice(0, 8);
        const maxPmi = Math.max(...ruWords.map((c: any) => c.pmi), 1);

        for (const w of ruWords) {
          const row = ruCol.append('div')
            .style('display', 'flex')
            .style('align-items', 'center')
            .style('gap', '4px')
            .style('margin-bottom', '2px');

          row.append('div')
            .style('width', `${Math.max(8, (w.pmi / maxPmi) * 60)}%`)
            .style('height', '14px')
            .style('background', 'rgba(239, 68, 68, 0.3)')
            .style('border-radius', '2px')
            .style('display', 'flex')
            .style('align-items', 'center')
            .style('padding-left', '4px')
            .style('font-size', '0.7rem')
            .style('color', '#dc2626')
            .style('white-space', 'nowrap')
            .text(w.word);

          row.append('div')
            .style('font-size', '0.6rem')
            .style('color', '#64748b')
            .text(`(${w.count})`);
        }

        // Ukrainian collocates
        const uaCol = cols.append('div');
        uaCol.append('div')
          .style('font-size', '0.7rem')
          .style('color', '#3b82f6')
          .style('font-weight', '600')
          .style('margin-bottom', '0.4rem')
          .style('text-transform', 'uppercase')
          .style('letter-spacing', '0.05em')
          .text('Ukrainian form');

        const uaWords = pairData.ukrainian.collocates
          .filter((c: any) => c.count >= 3)
          .slice(0, 8);
        const maxPmiUa = Math.max(...uaWords.map((c: any) => c.pmi), 1);

        for (const w of uaWords) {
          const row = uaCol.append('div')
            .style('display', 'flex')
            .style('align-items', 'center')
            .style('gap', '4px')
            .style('margin-bottom', '2px');

          row.append('div')
            .style('width', `${Math.max(8, (w.pmi / maxPmiUa) * 60)}%`)
            .style('height', '14px')
            .style('background', 'rgba(59, 130, 246, 0.3)')
            .style('border-radius', '2px')
            .style('display', 'flex')
            .style('align-items', 'center')
            .style('padding-left', '4px')
            .style('font-size', '0.7rem')
            .style('color', '#2563eb')
            .style('white-space', 'nowrap')
            .text(w.word);

          row.append('div')
            .style('font-size', '0.6rem')
            .style('color', '#64748b')
            .text(`(${w.count})`);
        }
      }
    }

    function drawPairClContext() {
      const container = document.getElementById('pair-cl-body');
      if (!container) return;
      container.innerHTML = '';

      const cl = clAnalysis as any;
      const pid = String(activePairId);
      const ctx = cl.context_distribution?.[pid];
      const sent = cl.sentiment_comparison?.[pid];
      const coll = (clCollocations as any)?.[pid];

      if (!ctx && !sent && !coll) {
        container.innerHTML = '<div style="color:#64748b; font-size:0.8rem;">No CL data for this pair</div>';
        return;
      }

      const wrapper = d3.select(container);

      // Two columns: context bars + collocations
      const grid = wrapper.append('div')
        .style('display', 'grid')
        .style('grid-template-columns', '1fr 1fr')
        .style('gap', '1rem');

      // Left: context distribution bars
      if (ctx) {
        const left = grid.append('div');
        left.append('div').style('font-size', '0.75rem').style('font-weight', '600')
          .style('color', '#94a3b8').style('margin-bottom', '0.5rem').text('Context Distribution');

        const categories = ['war_conflict', 'academic_science', 'politics', 'history',
          'travel_tourism', 'sports', 'general_news', 'culture_arts', 'food_cuisine', 'business_economy'];
        const catLabels: Record<string, string> = {
          war_conflict: 'War', academic_science: 'Academic', politics: 'Politics',
          history: 'History', travel_tourism: 'Travel', sports: 'Sports',
          general_news: 'News', culture_arts: 'Culture', food_cuisine: 'Food', business_economy: 'Business',
        };

        for (const cat of categories) {
          const ruVal = ctx.russian?.[cat] || 0;
          const uaVal = ctx.ukrainian?.[cat] || 0;
          if (ruVal < 0.01 && uaVal < 0.01) continue;

          const row = left.append('div').style('margin-bottom', '3px');
          row.append('div').style('font-size', '0.65rem').style('color', '#64748b')
            .style('margin-bottom', '1px').text(catLabels[cat] || cat);

          const barRow = row.append('div').style('display', 'flex').style('gap', '2px').style('height', '10px');
          barRow.append('div').style('width', `${ruVal * 200}px`).style('max-width', '45%')
            .style('background', 'rgba(239,68,68,0.5)').style('border-radius', '2px');
          barRow.append('div').style('width', `${uaVal * 200}px`).style('max-width', '45%')
            .style('background', 'rgba(59,130,246,0.5)').style('border-radius', '2px');

          const diff = uaVal - ruVal;
          if (Math.abs(diff) > 0.03) {
            barRow.append('div').style('font-size', '0.6rem')
              .style('color', diff > 0 ? '#3b82f6' : '#ef4444')
              .style('align-self', 'center').style('margin-left', '4px')
              .text(`${diff > 0 ? '+' : ''}${(diff * 100).toFixed(0)}pp`);
          }
        }

        // Sentiment line
        if (sent) {
          left.append('div').style('font-size', '0.7rem').style('color', '#64748b')
            .style('margin-top', '0.5rem').style('border-top', '1px solid #1e293b').style('padding-top', '0.4rem')
            .html(`Sentiment: <span style="color:#ef4444">RU ${sent.russian?.mean_score?.toFixed(2) || '?'}</span> / <span style="color:#3b82f6">UA ${sent.ukrainian?.mean_score?.toFixed(2) || '?'}</span>`);
        }
      }

      // Right: collocations
      if (coll && (coll.russian?.collocates?.length || coll.ukrainian?.collocates?.length)) {
        const right = grid.append('div');
        right.append('div').style('font-size', '0.75rem').style('font-weight', '600')
          .style('color', '#94a3b8').style('margin-bottom', '0.5rem').text('Top Collocations');

        const cols = right.append('div').style('display', 'grid')
          .style('grid-template-columns', '1fr 1fr').style('gap', '0.5rem');

        for (const [variant, color, label] of [['russian', '#ef4444', 'RU'], ['ukrainian', '#3b82f6', 'UA']] as const) {
          const col = cols.append('div');
          col.append('div').style('font-size', '0.6rem').style('color', color)
            .style('font-weight', '600').style('margin-bottom', '3px').text(label);

          const words = coll[variant]?.collocates?.slice(0, 6) || [];
          for (const w of words) {
            col.append('div').style('font-size', '0.7rem').style('color', '#94a3b8')
              .style('margin-bottom', '1px')
              .html(`${w.word} <span style="color:#475569">(${w.count})</span>`);
          }
          if (words.length === 0) {
            col.append('div').style('font-size', '0.7rem').style('color', '#475569').text('—');
          }
        }
      }
    }

    function drawClContextChart() {
      const container = document.getElementById('cl-context-bars');
      if (!container) return;
      container.innerHTML = '';

      const cl = clAnalysis as any;
      if (!cl.context_distribution) return;

      const categories = ['war_conflict', 'academic_science', 'politics', 'history',
        'travel_tourism', 'sports', 'general_news', 'culture_arts', 'food_cuisine', 'business_economy'];
      const catLabels: Record<string, string> = {
        war_conflict: 'War', academic_science: 'Academic', politics: 'Politics',
        history: 'History', travel_tourism: 'Travel', sports: 'Sports',
        general_news: 'News', culture_arts: 'Culture', food_cuisine: 'Food', business_economy: 'Business',
      };

      const ruTotals: Record<string, number> = {};
      const uaTotals: Record<string, number> = {};
      for (const [pid, pairData] of Object.entries(cl.context_distribution)) {
        const pd = pairData as any;
        if (pd.russian) for (const [cat, val] of Object.entries(pd.russian)) ruTotals[cat] = (ruTotals[cat] || 0) + (val as number);
        if (pd.ukrainian) for (const [cat, val] of Object.entries(pd.ukrainian)) uaTotals[cat] = (uaTotals[cat] || 0) + (val as number);
      }
      const ruSum = Object.values(ruTotals).reduce((a, b) => a + b, 0);
      const uaSum = Object.values(uaTotals).reduce((a, b) => a + b, 0);

      // Compact horizontal bars using HTML (no SVG whitespace issues)
      const wrapper = d3.select(container);

      // Legend first
      wrapper.append('div').style('display', 'flex').style('gap', '1rem').style('margin-bottom', '0.5rem')
        .style('font-size', '0.7rem').style('color', 'var(--text-muted)')
        .html('<span style="display:inline-flex;align-items:center;gap:3px"><span style="width:8px;height:8px;background:#ef4444;border-radius:2px;opacity:0.7"></span>Russian</span>' +
              '<span style="display:inline-flex;align-items:center;gap:3px"><span style="width:8px;height:8px;background:#3b82f6;border-radius:2px;opacity:0.7"></span>Ukrainian</span>');

      const maxVal = Math.max(...categories.map(c => Math.max((ruTotals[c] || 0) / ruSum, (uaTotals[c] || 0) / uaSum)));

      categories.forEach(cat => {
        const ruPct = (ruTotals[cat] || 0) / ruSum;
        const uaPct = (uaTotals[cat] || 0) / uaSum;
        const diff = uaPct - ruPct;

        const row = wrapper.append('div').style('display', 'flex').style('align-items', 'center')
          .style('gap', '6px').style('margin-bottom', '2px');

        row.append('div').style('width', '55px').style('text-align', 'right')
          .style('font-size', '0.7rem').style('color', 'var(--text)').style('flex-shrink', '0')
          .text(catLabels[cat]);

        const bars = row.append('div').style('flex', '1').style('display', 'flex')
          .style('flex-direction', 'column').style('gap', '1px');

        bars.append('div').style('height', '8px').style('background', '#ef4444').style('opacity', '0.6')
          .style('border-radius', '2px').style('width', `${(ruPct / maxVal) * 100}%`);
        bars.append('div').style('height', '8px').style('background', '#3b82f6').style('opacity', '0.6')
          .style('border-radius', '2px').style('width', `${(uaPct / maxVal) * 100}%`);

        if (Math.abs(diff) > 0.015) {
          row.append('div').style('width', '40px').style('font-size', '0.65rem').style('font-weight', '600')
            .style('color', diff > 0 ? '#3b82f6' : '#ef4444').style('flex-shrink', '0')
            .text(`${diff > 0 ? '+' : ''}${(diff * 100).toFixed(1)}pp`);
        } else {
          row.append('div').style('width', '40px');
        }
      });
    }

    function drawClBenchmark() {
      const container = document.getElementById('cl-benchmark-table');
      if (!container) return;
      container.innerHTML = '';

      const cl = clAnalysis as any;
      if (!cl.benchmark || Object.keys(cl.benchmark).length === 0) return;

      const models = [
        { key: 'deberta-v3-large', name: 'DeBERTa-v3-large', params: '304M', desc: 'Best overall' },
        { key: 'xlm-roberta-large', name: 'XLM-RoBERTa-large', params: '550M', desc: 'Cross-lingual' },
        { key: 'mdeberta-v3-base', name: 'mDeBERTa-v3-base', params: '86M', desc: 'Lightweight' },
      ];

      const bestF1 = Math.max(...models.map(m => cl.benchmark[m.key]?.f1_macro || 0));

      const grid = d3.select(container).style('display', 'flex').style('flex-direction', 'column').style('gap', '0.4rem');

      models.forEach(m => {
        const data = cl.benchmark[m.key];
        if (!data) return;
        const isBest = data.f1_macro === bestF1;
        const f1pct = (data.f1_macro * 100).toFixed(1);

        const card = grid.append('div')
          .style('display', 'flex').style('align-items', 'center').style('gap', '0.75rem')
          .style('padding', '0.5rem 0.75rem')
          .style('border-radius', '6px')
          .style('border', isBest ? '1px solid #059669' : '1px solid var(--border)')
          .style('background', isBest ? 'rgba(5,150,105,0.06)' : 'transparent');

        // F1 score big number
        card.append('div')
          .style('font-size', '1.3rem').style('font-weight', '800').style('min-width', '55px')
          .style('color', isBest ? '#059669' : 'var(--text-muted)')
          .text(`${f1pct}%`);

        // Model info
        const info = card.append('div').style('flex', '1');
        info.append('div').style('font-size', '0.8rem').style('font-weight', isBest ? '700' : '500')
          .style('color', 'var(--text)').text(m.name);
        info.append('div').style('font-size', '0.65rem').style('color', 'var(--text-muted)')
          .text(`${m.params} params — ${m.desc}`);

        // Accuracy bar
        const accPct = (data.accuracy * 100);
        card.append('div').style('width', '80px').style('display', 'flex').style('flex-direction', 'column')
          .style('align-items', 'flex-end').style('gap', '2px')
          .html(`<div style="font-size:0.65rem;color:var(--text-muted)">Acc ${accPct.toFixed(1)}%</div>
                 <div style="width:100%;height:4px;background:var(--border);border-radius:2px">
                   <div style="width:${(accPct - 80) * 5}%;height:100%;background:${isBest ? '#059669' : '#94a3b8'};border-radius:2px"></div>
                 </div>`);
      });
    }
  </script>
</body>
</html>
