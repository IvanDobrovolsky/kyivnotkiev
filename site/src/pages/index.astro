    // ── Error Analysis chart ─────────────────────────────────
    function drawSearchPreview() {
      const container = document.getElementById('search-preview');
      if (!container) return;
      container.innerHTML = '';

      const pair = (pairs as any).pairs.find((p: any) => p.id === activePairId);
      if (!pair) return;

      const dc = (dictCombined as any)[String(activePairId)];
      if (!dc) { container.innerHTML = '<div style="font-size:0.75rem; color:#9ca3af;">No reference data</div>'; return; }

      const sources = [
        { key: 'wikipedia', name: 'Wikipedia', icon: '📖' },
        { key: 'wiktionary', name: 'Wiktionary', icon: '📝' },
        { key: 'britannica', name: 'Britannica', icon: '🔵' },
        { key: 'cambridge', name: 'Cambridge', icon: '📕' },
      ];

      let html = '<div style="display:grid; grid-template-columns: auto 1fr 1fr; gap:0; font-size:0.75rem;">';

      // Header
      html += '<div style="padding:0.35rem 0.5rem; font-weight:600; color:var(--text-muted); border-bottom:2px solid #e5e7eb;"></div>';
      html += `<div style="padding:0.35rem 0.5rem; font-weight:700; color:#9ca3af; border-bottom:2px solid #e5e7eb; text-decoration:line-through;">${pair.russian}</div>`;
      html += `<div style="padding:0.35rem 0.5rem; font-weight:700; color:#0057B8; border-bottom:2px solid #e5e7eb;">${pair.ukrainian}</div>`;

      for (const src of sources) {
        const data = dc[src.key];
        html += `<div style="padding:0.35rem 0.5rem; font-weight:500; border-bottom:1px solid #f3f4f6; display:flex; align-items:center; gap:0.3rem;"><span style="font-size:0.85rem;">${src.icon}</span>${src.name}</div>`;

        if (src.key === 'wikipedia') {
          html += refBadge(data?.russian_article, pair.russian, pair.ukrainian, 'wiki', true);
          html += refBadge(data?.ukrainian_article, pair.russian, pair.ukrainian, 'wiki', false);
        } else {
          const ruData = data?.russian ? {...data.russian, _isRussianCol: true} : data?.russian;
          const ukData = data?.ukrainian ? {...data.ukrainian, _isRussianCol: false} : data?.ukrainian;
          html += refBadge(ruData, pair.russian, pair.ukrainian, src.key);
          html += refBadge(ukData, pair.russian, pair.ukrainian, src.key);
        }
      }

      // Enforcement row — read per-pair from injected JSON
      // Hunspell: actually checked via pyenchant en_US per pair (script:
      // pipeline/analysis/verify_tools_per_pair.py). AP/BBC: only marked
      // when documented in their public stylebook entries. Grammarly and
      // Microsoft Word are intentionally omitted because they cannot be
      // verified per-pair without manual interaction with closed services.
      let toolsData: any = null;
      try {
        const tEl = document.getElementById('tools-per-pair-data');
        if (tEl && tEl.textContent) {
          toolsData = JSON.parse(tEl.textContent).pairs[String(activePairId)];
        }
      } catch (e) {
        console.error('[drawSearchPreview] tools data parse failed:', e);
      }

      html += '<div style="padding:0.4rem 0.5rem; font-weight:500; display:flex; align-items:center; gap:0.3rem;"><span style="font-size:0.85rem;">🔧</span>Tools</div>';
      html += '<div style="padding:0.4rem 0.5rem; grid-column: span 2; display:flex; gap:0.6rem; flex-wrap:wrap; align-items:center;">';

      if (toolsData) {
        // Hunspell — show RU vs UA verdict explicitly so the asymmetry is visible
        const hunRu = toolsData.hunspell.russian;
        const hunUa = toolsData.hunspell.ukrainian;
        const ruIcon = hunRu.accepted ? '✓' : '✗';
        const uaIcon = hunUa.accepted ? '✓' : '✗';
        const ruColor = hunRu.accepted ? '#059669' : '#dc2626';
        const uaColor = hunUa.accepted ? '#059669' : '#dc2626';
        const ruTitle = hunRu.accepted
          ? `hunspell en_US accepts "${hunRu.word_checked}"`
          : `hunspell en_US rejects "${hunRu.word_checked}"${hunRu.suggestions.length ? ` (suggests: ${hunRu.suggestions.join(', ')})` : ''}`;
        const uaTitle = hunUa.accepted
          ? `hunspell en_US accepts "${hunUa.word_checked}"`
          : `hunspell en_US rejects "${hunUa.word_checked}"${hunUa.suggestions.length ? ` (suggests: ${hunUa.suggestions.join(', ')})` : ''}`;
        html += `<span title="${ruTitle}">${badge(`Hunspell · ${pair.russian.split(' ')[0]}`, ruColor, ruIcon)}</span>`;
        html += `<span title="${uaTitle}">${badge(`Hunspell · ${pair.ukrainian.split(' ')[0]}`, uaColor, uaIcon)}</span>`;

        // AP / BBC — only show ✓ for documented entries; otherwise show "—"
        const apDoc = toolsData.ap_stylebook.documented;
        const bbcDoc = toolsData.bbc_style_guide.documented;
        html += `<span title="${apDoc ? 'AP Stylebook documents the Ukrainian form for this pair' : 'Not in AP Stylebook entries'}">`
          + badge('AP Stylebook', apDoc ? '#059669' : '#9ca3af', apDoc ? '✓' : '—')
          + '</span>';
        html += `<span title="${bbcDoc ? 'BBC News Style Guide documents the Ukrainian form for this pair' : 'Not in BBC News Style Guide entries'}">`
          + badge('BBC', bbcDoc ? '#059669' : '#9ca3af', bbcDoc ? '✓' : '—')
          + '</span>';
      } else {
        html += '<span style="font-size:0.65rem; color:#9ca3af;">tool data unavailable</span>';
      }
      html += '</div>';

      html += '</div>';
      container.innerHTML = html;
    }

    function badge(label: string, color: string, icon: string): string {
      return `<span style="display:inline-flex; align-items:center; gap:0.2rem; padding:0.15rem 0.4rem; border-radius:4px; background:${color}11; border:1px solid ${color}33; font-size:0.68rem; color:${color};"><strong>${icon}</strong> ${label}</span>`;
    }

    function refBadge(data: any, ru: string, uk: string, type: string, isRuCol?: boolean): string {
      const cell = 'padding:0.3rem 0.4rem; border-bottom:1px solid #f3f4f6; font-size:0.72rem;';

      if (type === 'wiki') {
        if (!data) return `<div style="${cell} color:#d1d5db;">—</div>`;
        const artClean = data.toLowerCase().replace(/[\s']/g, '');
        const ukClean = uk.toLowerCase().replace(/[\s']/g, '');
        const isUkr = artClean.includes(ukClean);
        // For wiki: if article uses Ukrainian form = ✅, otherwise ⚠️
        const icon = isUkr ? '✅' : '⚠️';
        return `<div style="${cell}">${icon} <strong>${data}</strong></div>`;
      }

      if (!data || !data.exists) return `<div style="${cell} color:#d1d5db;">✗ none</div>`;

      // Determine if this is a "good" (Ukrainian form) or "bad" (Russian form) entry
      // For the Russian column: entry exists = ⚠️ (still using old form)
      // We detect this from the parent call context via a hidden flag
      const isRussianColumn = data._isRussianCol;

      let label = '';
      let sub = '';
      if (type === 'wiktionary') {
        label = data.title || 'found';
        if (data.etymology) sub = data.etymology.slice(0, 45) + '…';
      } else if (type === 'britannica') {
        label = data.top_result || 'found';
      } else if (type === 'cambridge') {
        label = data.headword || 'found';
        if (data.definition) sub = data.definition.slice(0, 40) + '…';
        if (data.redirected) label += ' ↗';
      }

      const icon = isRussianColumn ? '⚠️' : '✅';
      let html = `<div style="${cell}">${icon} <strong>${label}</strong>`;
      if (sub) html += `<div style="font-size:0.58rem; color:#9ca3af; margin-top:0.1rem;">${sub}</div>`;
      html += '</div>';
      return html;
    }

    function drawErrorAnalysis() {
      const container = document.getElementById('error-analysis-chart');
      if (!container) return;
      container.innerHTML = '';

      const ea = errorAnalysis as any;
      // Pick 10 most interesting pairs (mix of high/low spread)
      const items = ea.disagreements
        .filter((d: any) => Object.keys(d.sources).length >= 3)
        .sort((a: any, b: any) => b.spread_pp - a.spread_pp)
        .slice(0, 10);

      const srcOrder = ['gdelt', 'trends', 'wikipedia', 'reddit', 'youtube', 'openalex'];

      const rowH = 36;
      const margin = { top: 25, right: 50, bottom: 10, left: 140 };
      const width = container.getBoundingClientRect().width - margin.left - margin.right;
      const height = items.length * rowH;

      const svg = d3.select('#error-analysis-chart')
        .append('svg')
        .attr('viewBox', `0 0 ${width + margin.left + margin.right} ${height + margin.top + margin.bottom}`)
        .append('g')
        .attr('transform', `translate(${margin.left},${margin.top})`);

      const x = d3.scaleLinear().domain([0, 100]).range([0, width]);
      const y = d3.scaleBand().domain(items.map((_: any, i: number) => String(i))).range([0, height]).padding(0.2);

      // Grid
      [0, 25, 50, 75, 100].forEach(v => {
        svg.append('line').attr('x1', x(v)).attr('x2', x(v)).attr('y1', -5).attr('y2', height)
          .attr('stroke', v === 50 ? '#d1d5db' : '#f0f0f0').attr('stroke-dasharray', v === 50 ? '3,3' : 'none');
        svg.append('text').attr('x', x(v)).attr('y', -10).attr('text-anchor', 'middle')
          .attr('font-size', '9px').attr('fill', '#9ca3af').text(v + '%');
      });

      items.forEach((item: any, i: number) => {
        const yi = y(String(i))!;
        const h = y.bandwidth();
        const barH = h / (srcOrder.length + 1);

        // Label
        svg.append('text')
          .attr('x', -6).attr('y', yi + h / 2 + 4)
          .attr('text-anchor', 'end').attr('font-size', '11px').attr('fill', 'var(--text)')
          .attr('font-weight', '500')
          .text(item.ukrainian.length > 18 ? item.ukrainian.slice(0, 16) + '...' : item.ukrainian);

        // One bar per source
        let barIdx = 0;
        for (const src of srcOrder) {
          const val = item.sources[src];
          if (val === undefined) continue;
          svg.append('rect')
            .attr('x', x(0)).attr('y', yi + barIdx * barH)
            .attr('width', Math.max(2, x(val))).attr('height', barH - 1)
            .attr('fill', sourceColors[src] || '#888')
            .attr('opacity', 0.8).attr('rx', 2);
          barIdx++;
        }

        // Spread label
        const vals = Object.values(item.sources) as number[];
        svg.append('text')
          .attr('x', x(Math.max(...vals)) + 6).attr('y', yi + h / 2 + 4)
          .attr('font-size', '10px').attr('fill', '#9ca3af').attr('font-weight', '600')
          .text(`${item.spread_pp}pp`);
      });

      // Legend
      const legend = d3.select('#error-analysis-chart').append('div')
        .style('display', 'flex').style('gap', '0.75rem').style('justify-content', 'center')
        .style('margin-top', '0.5rem').style('flex-wrap', 'wrap');

      for (const src of srcOrder) {
        legend.append('div')
          .style('display', 'flex').style('align-items', 'center').style('gap', '4px')
          .style('font-size', '11px').style('color', '#6b7280')
          .html(`<span style="width:8px;height:8px;border-radius:50%;background:${sourceColors[src] || '#888'};display:inline-block;"></span>${srcNames[src]}`);
      }
    }

    function drawClCollocations() {
      const container = document.getElementById('cl-collocations-grid');
      if (!container) return;
      container.innerHTML = '';

      const coll = clCollocations as any;
      const showPairs = (pairs as any).pairs
        .filter((p: any) => p.starred)
        .map((p: any) => ({
          id: String(p.id), ru: p.russian, ua: p.ukrainian, label: p.starred_label || '',
        }));

      const grid = d3.select(container)
        .style('display', 'grid')
        .style('grid-template-columns', 'repeat(3, 1fr)')
        .style('gap', '0.5rem');

      for (const pair of showPairs) {
        const pairData = coll[pair.id];
        if (!pairData) continue;
        const hasRu = pairData.russian?.collocates?.length > 0;
        const hasUa = pairData.ukrainian?.collocates?.length > 0;
        if (!hasRu && !hasUa) continue;

        const card = grid.append('div')
          .style('border', '1px solid var(--border)')
          .style('border-radius', '8px')
          .style('padding', '0.6rem 0.75rem')
          .style('cursor', 'pointer')
          .on('click', () => { selectPair(parseInt(pair.id)); });

        // Header
        card.append('div').style('font-size', '0.8rem').style('font-weight', '600')
          .style('color', 'var(--text)').style('margin-bottom', '0.15rem')
          .text(`${pair.ru} → ${pair.ua}`);
        card.append('div').style('font-size', '0.6rem').style('color', 'var(--text-muted)')
          .style('margin-bottom', '0.5rem').text(pair.label);

        // Contrastive words side by side
        for (const [variant, color, label] of [['russian', '#dc2626', 'RU-distinctive'], ['ukrainian', '#2563eb', 'UA-distinctive']] as const) {
          const words = pairData[variant]?.collocates?.slice(0, 5) || [];
          if (!words.length) {
            const row = card.append('div').style('margin-bottom', '0.35rem');
            row.append('span').style('font-size', '0.55rem').style('color', color)
              .style('font-weight', '700').style('text-transform', 'uppercase')
              .style('letter-spacing', '0.05em').style('margin-right', '0.3rem').text(label);
            row.append('span').style('font-size', '0.7rem').style('color', 'var(--text-muted)')
              .style('font-style', 'italic').text('insufficient data');
            continue;
          }

          const row = card.append('div').style('margin-bottom', '0.35rem');
          row.append('span').style('font-size', '0.55rem').style('color', color)
            .style('font-weight', '700').style('text-transform', 'uppercase')
            .style('letter-spacing', '0.05em').style('margin-right', '0.3rem').text(label);

          const tags = row.append('span').style('line-height', '1.8');
          words.forEach((w: any, i: number) => {
            const weight = i < 2 ? '700' : '400';
            tags.append('span')
              .style('font-size', '0.72rem')
              .style('color', color)
              .style('font-weight', weight)
              .style('margin-right', '0.3rem')
              .style('white-space', 'nowrap')
              .text(w.word);
          });
        }
      }
    }

    function drawPairClContext() {
      // Left card: context distribution
      const ctxContainer = document.getElementById('pair-cl-body');
      // Right card: collocations
      const collContainer = document.getElementById('pair-cl-coll-body');

      if (ctxContainer) ctxContainer.innerHTML = '';
      if (collContainer) collContainer.innerHTML = '';

      const cl = clAnalysis as any;
      const pid = String(activePairId);
      const ctx = cl.context_distribution?.[pid];
      const sent = cl.sentiment_comparison?.[pid];
      const coll = (clCollocations as any)?.[pid];

      // Left: context bars
      if (ctxContainer && ctx) {
        const left = d3.select(ctxContainer);

        // Derive categories from data — smart bucketing, max 10, sorted by total
        const allCats = new Set([
          ...Object.keys(ctx.russian || {}),
          ...Object.keys(ctx.ukrainian || {}),
        ]);
        const catScored = [...allCats].map(c => ({
          cat: c,
          total: (ctx.russian?.[c] || 0) + (ctx.ukrainian?.[c] || 0),
        })).sort((a, b) => b.total - a.total);
        let categories: {cat:string,total:number}[] = [];
        for (const thr of [0.04, 0.02, 0.01, 0]) {
          categories = catScored.filter(c => c.total > thr);
          if (categories.length >= 4) break;
        }
        categories = categories.slice(0, 10);

        const formatLabel = (s: string) => s.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase())
          .replace('War Conflict', 'War').replace('Academic Science', 'Academic')
          .replace('General News', 'News').replace('Travel Tourism', 'Travel')
          .replace('Culture Arts', 'Culture').replace('Food Cuisine', 'Food')
          .replace('Business Economy', 'Business');

        left.append('div').style('display', 'flex').style('gap', '0.75rem').style('margin-bottom', '0.4rem')
          .style('font-size', '0.65rem').style('color', 'var(--text-muted)')
          .html('<span style="display:inline-flex;align-items:center;gap:3px"><span style="width:7px;height:7px;background:#ef4444;border-radius:2px;opacity:0.7"></span>Russian</span>' +
                '<span style="display:inline-flex;align-items:center;gap:3px"><span style="width:7px;height:7px;background:#3b82f6;border-radius:2px;opacity:0.7"></span>Ukrainian</span>');

        const maxVal = Math.max(
          ...categories.map(c => Math.max(ctx.russian?.[c.cat] || 0, ctx.ukrainian?.[c.cat] || 0))
        ) || 0.3;

        for (const {cat} of categories) {
          const ruVal = ctx.russian?.[cat] || 0;
          const uaVal = ctx.ukrainian?.[cat] || 0;
          if (ruVal < 0.005 && uaVal < 0.005) continue;
          const diff = uaVal - ruVal;

          const row = left.append('div').style('display', 'flex').style('align-items', 'center')
            .style('gap', '4px').style('margin-bottom', '2px');
          row.append('div').style('width', '50px').style('text-align', 'right')
            .style('font-size', '0.65rem').style('color', 'var(--text)').style('flex-shrink', '0')
            .text(formatLabel(cat));
          const bars = row.append('div').style('flex', '1').style('display', 'flex')
            .style('flex-direction', 'column').style('gap', '1px');
          bars.append('div').style('height', '7px').style('background', '#ef4444').style('opacity', '0.6')
            .style('border-radius', '2px').style('width', `${(ruVal / maxVal) * 100}%`);
          bars.append('div').style('height', '7px').style('background', '#3b82f6').style('opacity', '0.6')
            .style('border-radius', '2px').style('width', `${(uaVal / maxVal) * 100}%`);
          if (Math.abs(diff) > 0.02) {
            row.append('div').style('width', '35px').style('font-size', '0.6rem').style('font-weight', '600')
              .style('color', diff > 0 ? '#3b82f6' : '#ef4444').style('flex-shrink', '0')
              .text(`${diff > 0 ? '+' : ''}${(diff * 100).toFixed(0)}pp`);
          } else {
            row.append('div').style('width', '35px');
          }
        }

        if (sent) {
          left.append('div').style('font-size', '0.65rem').style('color', 'var(--text-muted)')
            .style('margin-top', '0.4rem').style('border-top', '1px solid var(--border)').style('padding-top', '0.3rem')
            .html(`Sentiment: <span style="color:#ef4444">RU ${sent.russian?.mean_score?.toFixed(2) || '?'}</span> / <span style="color:#3b82f6">UA ${sent.ukrainian?.mean_score?.toFixed(2) || '?'}</span>`);
        }
      } else if (ctxContainer) {
        ctxContainer.innerHTML = '<div style="color:var(--text-muted); font-size:0.75rem;">No context data</div>';
      }

      // Right: contrastive analysis (log-odds ratio, Monroe et al. 2008)
      if (collContainer && coll) {
        const right = d3.select(collContainer);
        const method = coll.method === 'log_odds_ratio_dirichlet' ? 'Log-odds ratio (z-score)' : 'Contrastive';
        right.append('div').style('font-size', '0.55rem').style('color', 'var(--text-dim)')
          .style('margin-bottom', '0.5rem').text(method);

        for (const [variant, color, label, sign] of [
          ['russian', '#dc2626', 'Russian-distinctive', '+'],
          ['ukrainian', '#2563eb', 'Ukrainian-distinctive', '−']
        ] as const) {
          const words = coll[variant]?.collocates?.slice(0, 10) || [];
          const section = right.append('div').style('margin-bottom', '0.5rem');
          section.append('div').style('font-size', '0.6rem').style('color', color)
            .style('font-weight', '700').style('text-transform', 'uppercase')
            .style('letter-spacing', '0.04em').style('margin-bottom', '0.2rem').text(label);

          if (!words.length) {
            section.append('div').style('font-size', '0.7rem').style('color', 'var(--text-muted)')
              .style('font-style', 'italic').text('insufficient data');
            continue;
          }

          const maxZ = Math.max(...words.map((w: any) => Math.abs(w.z || w.pmi || 1)));
          words.forEach((w: any, i: number) => {
            const z = Math.abs(w.z || w.pmi || 0);
            const barW = Math.max(5, (z / maxZ) * 100);
            const row = section.append('div').style('display', 'flex').style('align-items', 'center')
              .style('gap', '4px').style('margin-bottom', '1px');
            row.append('div').style('width', '65px').style('text-align', 'right')
              .style('font-size', '0.68rem').style('color', 'var(--text)').style('flex-shrink', '0')
              .style('font-weight', i < 3 ? '700' : '400').text(w.word);
            row.append('div').style('flex', '1').style('height', '8px').style('background', 'var(--border)')
              .style('border-radius', '4px').style('overflow', 'hidden')
              .append('div').style('height', '100%').style('width', `${barW}%`)
              .style('background', color).style('opacity', '0.7').style('border-radius', '4px');
            row.append('div').style('width', '30px').style('font-size', '0.55rem')
              .style('color', 'var(--text-muted)').style('flex-shrink', '0')
              .text(`z=${z.toFixed(0)}`);
          });
        }
      } else if (collContainer) {
        collContainer.innerHTML = '<div style="color:var(--text-muted); font-size:0.75rem;">No contrastive data</div>';
      }
    }

    function drawClContextChart() {
      const container = document.getElementById('cl-context-bars');
      if (!container) return;
      container.innerHTML = '';

      const cl = clAnalysis as any;
      if (!cl.context_distribution) return;

      // Aggregate context data from all pairs — derive categories from data
      const ruTotals: Record<string, number> = {};
      const uaTotals: Record<string, number> = {};
      for (const [pid, pairData] of Object.entries(cl.context_distribution)) {
        const pd = pairData as any;
        if (pd.russian) for (const [cat, val] of Object.entries(pd.russian)) ruTotals[cat] = (ruTotals[cat] || 0) + (val as number);
        if (pd.ukrainian) for (const [cat, val] of Object.entries(pd.ukrainian)) uaTotals[cat] = (uaTotals[cat] || 0) + (val as number);
      }
      const ruSum = Object.values(ruTotals).reduce((a, b) => a + b, 0) || 1;
      const uaSum = Object.values(uaTotals).reduce((a, b) => a + b, 0) || 1;

      // Smart bucketing: sorted by total, 20%+ first then relax, max 10
      const aggCats = [...new Set([...Object.keys(ruTotals), ...Object.keys(uaTotals)])]
        .map(c => ({ cat: c, total: (ruTotals[c] || 0) + (uaTotals[c] || 0) }))
        .sort((a, b) => b.total - a.total);
      let categories: string[] = [];
      for (const thr of [0.04, 0.02, 0.01, 0]) {
        const totalAll = aggCats.reduce((s, c) => s + c.total, 0) || 1;
        categories = aggCats.filter(c => c.total / totalAll > thr).map(c => c.cat);
        if (categories.length >= 4) break;
      }
      categories = categories.slice(0, 10);

      const formatLabel = (s: string) => s.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase())
        .replace('War Conflict', 'War').replace('Academic Science', 'Academic')
        .replace('General News', 'News').replace('Travel Tourism', 'Travel')
        .replace('Culture Arts', 'Culture').replace('Food Cuisine', 'Food')
        .replace('Business Economy', 'Business');

      // Compact horizontal bars using HTML (no SVG whitespace issues)
      const wrapper = d3.select(container);

      // Legend first
      wrapper.append('div').style('display', 'flex').style('gap', '1rem').style('margin-bottom', '0.5rem')
        .style('font-size', '0.7rem').style('color', 'var(--text-muted)')
        .html('<span style="display:inline-flex;align-items:center;gap:3px"><span style="width:8px;height:8px;background:#ef4444;border-radius:2px;opacity:0.7"></span>Russian</span>' +
              '<span style="display:inline-flex;align-items:center;gap:3px"><span style="width:8px;height:8px;background:#3b82f6;border-radius:2px;opacity:0.7"></span>Ukrainian</span>');

      const maxVal = Math.max(...categories.map(c => Math.max((ruTotals[c] || 0) / ruSum, (uaTotals[c] || 0) / uaSum)));

      categories.forEach(cat => {
        const ruPct = (ruTotals[cat] || 0) / ruSum;
        const uaPct = (uaTotals[cat] || 0) / uaSum;
        const diff = uaPct - ruPct;

        const row = wrapper.append('div').style('display', 'flex').style('align-items', 'center')
          .style('gap', '6px').style('margin-bottom', '2px');

        row.append('div').style('width', '55px').style('text-align', 'right')
          .style('font-size', '0.7rem').style('color', 'var(--text)').style('flex-shrink', '0')
          .text(formatLabel(cat));

        const bars = row.append('div').style('flex', '1').style('display', 'flex')
          .style('flex-direction', 'column').style('gap', '1px');

        bars.append('div').style('height', '8px').style('background', '#ef4444').style('opacity', '0.6')
          .style('border-radius', '2px').style('width', `${(ruPct / maxVal) * 100}%`);
        bars.append('div').style('height', '8px').style('background', '#3b82f6').style('opacity', '0.6')
          .style('border-radius', '2px').style('width', `${(uaPct / maxVal) * 100}%`);

        if (Math.abs(diff) > 0.015) {
          row.append('div').style('width', '40px').style('font-size', '0.65rem').style('font-weight', '600')
            .style('color', diff > 0 ? '#3b82f6' : '#ef4444').style('flex-shrink', '0')
            .text(`${diff > 0 ? '+' : ''}${(diff * 100).toFixed(1)}pp`);
        } else {
          row.append('div').style('width', '40px');
        }
      });
    }

    function drawClBenchmark() {
      const container = document.getElementById('cl-benchmark-table');
      if (!container) return;
      container.innerHTML = '';

      const cl = clAnalysis as any;
      if (!cl.benchmark || Object.keys(cl.benchmark).length === 0) return;

      // Dynamic subtitle from data
      const benchSub = document.getElementById('benchmark-subtitle');
      if (benchSub) {
        const nModels = Object.keys(cl.benchmark).length;
        const nClasses = Object.keys(cl.context_distribution?.[Object.keys(cl.context_distribution)[0]]?.russian || {}).length || 11;
        const corpusSize = (manifest as any).cl_corpus || 0;
        benchSub.textContent = `${nModels} models trained on Claude Haiku 4.5 annotations, ${corpusSize.toLocaleString()} texts, ${nClasses} categories`;
      }

      // Read model list directly from the benchmark data, not hardcoded.
      // Sort by f1_macro descending so the best model is at the top.
      // Display name and metadata are derived from the JSON key.
      const niceNameMap: Record<string, string> = {
        'deberta-v3-large': 'DeBERTa-v3-large',
        'xlm-roberta-large': 'XLM-RoBERTa-large',
        'mdeberta-v3-base': 'mDeBERTa-v3-base',
      };
      const models = Object.keys(cl.benchmark)
        .map(k => {
          const e = cl.benchmark[k];
          return {
            key: k,
            name: e.name || niceNameMap[k] || k,
            params: e.params || '',
            desc: e.description || e.desc || '',
            data: e,
          };
        })
        .sort((a, b) => (b.data.f1_macro || 0) - (a.data.f1_macro || 0));

      const bestF1 = Math.max(...models.map(m => m.data.f1_macro || 0));

      const grid = d3.select(container).style('display', 'flex').style('flex-direction', 'column').style('gap', '0.4rem');

      models.forEach(m => {
        const data = cl.benchmark[m.key];
        if (!data) return;
        const isBest = data.f1_macro === bestF1;
        const f1pct = (data.f1_macro * 100).toFixed(1);

        const card = grid.append('div')
          .style('display', 'flex').style('align-items', 'center').style('gap', '0.75rem')
          .style('padding', '0.5rem 0.75rem')
          .style('border-radius', '6px')
          .style('border', isBest ? '1px solid #059669' : '1px solid var(--border)')
          .style('background', isBest ? 'rgba(5,150,105,0.06)' : 'transparent');

        // F1 score big number
        card.append('div')
          .style('font-size', '1.3rem').style('font-weight', '800').style('min-width', '55px')
          .style('color', isBest ? '#059669' : 'var(--text-muted)')
          .text(`${f1pct}%`);

        // Model info
        const info = card.append('div').style('flex', '1');
        info.append('div').style('font-size', '0.8rem').style('font-weight', isBest ? '700' : '500')
          .style('color', 'var(--text)').text(m.name);
        info.append('div').style('font-size', '0.65rem').style('color', 'var(--text-muted)')
          .text(`${m.params} params — ${m.desc}`);

        // Accuracy bar
        const accPct = (data.accuracy * 100);
        card.append('div').style('width', '80px').style('display', 'flex').style('flex-direction', 'column')
          .style('align-items', 'flex-end').style('gap', '2px')
          .html(`<div style="font-size:0.65rem;color:var(--text-muted)">Acc ${accPct.toFixed(1)}%</div>
                 <div style="width:100%;height:4px;background:var(--border);border-radius:2px">
                   <div style="width:${(accPct - 80) * 5}%;height:100%;background:${isBest ? '#059669' : '#94a3b8'};border-radius:2px"></div>
                 </div>`);
      });
    }

    function drawConfusionMatrix() {
      const container = document.getElementById('cl-confusion-matrix');
      if (!container) return;
      container.innerHTML = '';

      const cm = confusionMatrix as any;
      const labels = cm.labels;
      const matrix = cm.matrix;
      const n = labels.length;
      const short: Record<string,string> = {
        academic:'Acad', culture:'Cult', economy:'Econ', food:'Food',
        general:'Gen', history:'Hist', politics:'Pol', religion:'Rel',
        sports:'Sport', travel:'Trav', war:'War'
      };

      const cell = 40, padL = 48, padT = 42;
      const w = padL + n * cell + 10, h = padT + n * cell + 22;
      const rowSums = matrix.map((r: number[]) => r.reduce((a: number, b: number) => a + b, 0));
      const maxOff = Math.max(...matrix.flatMap((r: number[], i: number) => r.map((v: number, j: number) => i === j ? 0 : v / (rowSums[i] || 1) * 100)));

      const svg = d3.select(container).append('svg')
        .attr('viewBox', `0 0 ${w} ${h}`)
        .style('max-width', '520px').style('width', '100%');

      // Axis labels
      svg.append('text').attr('x', padL + n*cell/2).attr('y', h - 2)
        .attr('text-anchor', 'middle').attr('font-size', 9).attr('fill', '#9ca3af').text(`Predicted (DeBERTa-v3-large) — F1=${((confusionMatrix as any).f1_macro || 0).toFixed(3)}`);
      svg.append('text').attr('x', 8).attr('y', padT + n*cell/2)
        .attr('text-anchor', 'middle').attr('font-size', 9).attr('fill', '#9ca3af')
        .attr('transform', `rotate(-90,8,${padT + n*cell/2})`).text('True (Haiku)');

      // Headers
      labels.forEach((l: string, j: number) => {
        svg.append('text').attr('x', padL + j*cell + cell/2).attr('y', padT - 8)
          .attr('text-anchor', 'middle').attr('font-size', 9).attr('fill', '#6b7280')
          .attr('transform', `rotate(-35,${padL + j*cell + cell/2},${padT - 8})`).text(short[l] || l);
        svg.append('text').attr('x', padL - 4).attr('y', padT + j*cell + cell/2 + 3)
          .attr('text-anchor', 'end').attr('font-size', 9).attr('fill', '#6b7280').text(short[l] || l);
      });

      // Cells
      for (let i = 0; i < n; i++) {
        for (let j = 0; j < n; j++) {
          const x = padL + j * cell, y = padT + i * cell;
          const raw = matrix[i][j];
          const pct = raw / (rowSums[i] || 1) * 100;
          let fill, textFill;
          if (i === j) {
            const t = pct / 100;
            fill = `rgb(${Math.round(240 - t*190)},${Math.round(240 - t*50)},${Math.round(240 - t*190)})`;
            textFill = pct > 70 ? '#fff' : '#374151';
          } else if (raw === 0) {
            fill = '#fafafa'; textFill = '#d1d5db';
          } else {
            const t = Math.min(pct / (maxOff || 1), 1);
            fill = `rgb(255,${Math.round(255 - t*140)},${Math.round(255 - t*140)})`;
            textFill = pct > 2 ? '#991b1b' : '#9ca3af';
          }
          svg.append('rect').attr('x', x).attr('y', y).attr('width', cell-1).attr('height', cell-1)
            .attr('fill', fill).attr('rx', 3);
          if (i === j) {
            svg.append('text').attr('x', x + cell/2).attr('y', y + cell/2 + 4)
              .attr('text-anchor', 'middle').attr('font-size', 10).attr('fill', textFill)
              .attr('font-weight', 700).text(`${pct.toFixed(0)}%`);
          } else if (raw > 0) {
            svg.append('text').attr('x', x + cell/2).attr('y', y + cell/2 + 4)
              .attr('text-anchor', 'middle').attr('font-size', 9).attr('fill', textFill).text(raw);
          }
        }
      }
    }

    // Call it on load
    drawConfusionMatrix();
    // CM subtitle from data
    const cmSub = document.getElementById('cm-subtitle');
    if (cmSub) {
      const cm = confusionMatrix as any;
      cmSub.textContent = `DeBERTa-v3-large test set — ${(cm.n_total || 0).toLocaleString()} texts · ${((cm.accuracy || 0) * 100).toFixed(1)}% accuracy · macro F1 = ${(cm.f1_macro || 0).toFixed(3)}`;
    }

    // Statistical Analysis — rendered from data, not hardcoded
    (function renderStatAnalysis() {
      const an = analysisData as any;
      const rp = regexPrecision as any;
      const ea = errorAnalysis as any;

      const reg = an.regression || {};
      const kw = an.kruskal_wallis || {};
      const inv = an.invasion_effect || {};

      // Best invasion effect (highest Cohen's d)
      let bestInv = { d: 0, p: 1, src: '' };
      for (const [src, res] of Object.entries(inv)) {
        const r = res as any;
        if (Math.abs(r.cohens_d) > Math.abs(bestInv.d)) {
          bestInv = { d: r.cohens_d, p: r.p, src };
        }
      }

      const grid = document.getElementById('stat-analysis-grid');
      if (!grid) return;

      const cards = [
        { value: `R²=${(reg.r_squared || 0).toFixed(2)}`, label: 'Regression fit', sub: `β=${(reg.beta || 0).toFixed(2)}, n=${reg.n || 0}`, bg: '#f0f9ff', color: '#0057B8' },
        { value: bestInv.p < 0.001 ? 'p<0.001' : `p=${bestInv.p.toFixed(3)}`, label: 'Invasion effect', sub: `Wilcoxon; d=${bestInv.d.toFixed(2)}`, bg: '#fef2f2', color: '#dc2626' },
        { value: `${rp.overall_precision || 0}%`, label: 'Regex precision', sub: `${rp.total_false_positives || 0} FP / ${(rp.total_sampled || 0).toLocaleString()}`, bg: '#f0fdf4', color: '#059669' },
        { value: kw.p < 0.001 ? 'p<0.001' : `p=${(kw.p || 0).toFixed(3)}`, label: 'Category test', sub: `H=${(kw.H || 0).toFixed(2)}`, bg: '#fefce8', color: '#d97706' },
      ];

      grid.innerHTML = cards.map(c => `
        <div style="padding:0.6rem 0.4rem;background:${c.bg};border-radius:6px;text-align:center;">
          <div style="font-size:1.2rem;font-weight:700;color:${c.color};">${c.value}</div>
          <div style="font-size:0.65rem;color:#6b7280;">${c.label}</div>
          <div style="font-size:0.58rem;color:#9ca3af;">${c.sub}</div>
        </div>
      `).join('');

      // Findings row — from data
      const spread = ea.summary?.median_spread_pp || 54;
      const p70 = (manifest as any).pairs?.find((p:any) => p.id === 70);
      const p10 = (manifest as any).pairs?.find((p:any) => p.id === 10);
      const p1 = (manifest as any).pairs?.find((p:any) => p.id === 1);

      const findings = [
        { title: 'Cross-source spread', text: `Median ${spread}pp — highly domain-dependent` },
        { title: 'Historical identity', text: `Kyiv ${(p1?.adoption || 0).toFixed(0)}% but Volodymyr the Great ${(p70?.adoption || 0).toFixed(0)}%` },
        { title: 'Disaster brand', text: `Chernobyl: ${(p10?.adoption || 0).toFixed(0)}% overall adoption` },
        { title: 'Recognition vs recall', text: `72 LLMs: 90%+ forced, 65–78% free` },
      ];

      const findingsEl = document.getElementById('stat-analysis-findings');
      if (findingsEl) {
        findingsEl.innerHTML = findings.map(f => `
          <div style="padding:0.4rem 0.6rem;background:#f8f9fb;border-radius:5px;">
            <div style="font-size:0.72rem;font-weight:600;color:var(--text);">${f.title}</div>
            <div style="font-size:0.65rem;color:#6b7280;">${f.text}</div>
          </div>
        `).join('');
      }
    })();
  </script>
</body>
</html>
